@*
 * Views/Shared/_EnrollmentComponent.cshtml
 * Unified Enrollment UI Component
 *
 * CRITICAL FIX: CameraViewModel.Id must be set to "enroll" so that
 * _Camera.cshtml generates video element with id="enrollVideo"
 * (videoId = Model.Id + "Video" = "enroll" + "Video" = "enrollVideo")
 *
 * The inline <script> block has been REMOVED. enrollment-ui.js
 * (loaded via ~/bundles/enrollment in each view) handles all behavior.
 *
 * Required ViewBag:
 *   ViewBag.EmployeeId        string  - employee/visitor ID
 *   ViewBag.ScanUrl           string  - URL for ScanFrame AJAX endpoint
 *   ViewBag.EnrollUrl         string  - URL for Enroll AJAX endpoint
 *   ViewBag.RedirectUrl       string  - URL after enrollment success
 *   ViewBag.Mode              string  - "admin" | "mobile" | "visitor"
 *   ViewBag.MinFrames         int     - minimum good frames required (default 10)
 *   ViewBag.LivenessThreshold double  - per-frame liveness threshold (default 0.75)
 *@

@using FaceAttend.Models.ViewModels.Shared
@using FaceAttend.Models.ViewModels

@{
    var mode         = (string)(ViewBag.Mode ?? "admin");
    var isMobile     = (mode == "mobile");
    var minFrames    = (int)(ViewBag.MinFrames ?? 10);
    var maxFrames    = (int)(ViewBag.MaxFrames ?? 10);
    var liveTh       = (double)(ViewBag.LivenessThreshold ?? 0.75);
    var surfaceClass = isMobile ? "mobile-surface" : "admin-surface";
    var liveThStr    = liveTh.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);

    @*
     * CRITICAL: Id must be "enroll" so _Camera.cshtml generates:
     *   containerId = "enroll"
     *   videoId     = "enroll" + "Video" = "enrollVideo"   ← required by enrollment-ui.js
     *@
    var cameraModel = new CameraViewModel
    {
        Id          = "enroll",        // ← CRITICAL: generates id="enroll" container + id="enrollVideo" video
        VideoId     = "enrollVideo",   // explicit VideoId for clarity
        ShowGuide   = true,
        GuideType   = "circle",
        GuideText   = "Center your face in the circle",
        Mirror      = true,
        AspectRatio = "4/3",
        AutoStart   = false,           // enrollment-ui.js controls start/stop
        ShowStatus  = false            // we have our own status element below
    };

    var progressModel = new FaceProgressViewModel
    {
        MinFrames       = minFrames,
        CurrentFrames   = 0,
        CapturedBuckets = new System.Collections.Generic.List<string>()
    };
}

<div id="enrollRoot"
     class="enroll-container @surfaceClass"
     data-employee-id="@ViewBag.EmployeeId"
     data-mode="@mode"
     data-scan-url="@ViewBag.ScanUrl"
     data-enroll-url="@ViewBag.EnrollUrl"
     data-redirect-url="@ViewBag.RedirectUrl"
     data-min-frames="@minFrames"
     data-max-frames="@maxFrames"
     data-liveness-th="@liveThStr">

    @* ── Camera ──────────────────────────────────────────────────────────── *@
    <div class="enroll-camera-wrap" id="enrollCameraWrap">
        @Html.Partial("~/Views/Shared/Components/_Camera.cshtml", cameraModel)

        @* Processing overlay — shown during server save *@
        <div class="enroll-processing-overlay enroll-hidden" id="enrollProcessing">
            <i class="fa-solid fa-circle-notch enroll-processing-spinner"></i>
            <span class="enroll-processing-text" id="enrollProcessingStatus">Processing...</span>
        </div>
    </div>

    @* ── Angle Guidance ──────────────────────────────────────────────────── *@
    <div class="enroll-angle-guidance" id="enrollAngleGuidance">
        <i class="enroll-angle-icon fa-solid fa-circle-dot" id="angleIcon"></i>
        <span class="enroll-angle-prompt" id="anglePrompt">Preparing camera...</span>
    </div>

    @* ── Progress (diversity dots + bar) ─────────────────────────────────── *@
    @Html.Partial("~/Views/Shared/Components/_FaceProgress.cshtml", progressModel)

    @* ── Liveness Bar ────────────────────────────────────────────────────── *@
    <div class="enroll-liveness-wrap">
        <span class="enroll-liveness-label">Liveness</span>
        <div class="enroll-liveness-track">
            <div class="enroll-liveness-fill" id="enrollLivenessBar"></div>
        </div>
        <span class="enroll-liveness-val" id="enrollLivenessVal">0%</span>
    </div>

    @* ── Status message ──────────────────────────────────────────────────── *@
    <div class="enroll-status enroll-status--info" id="enrollStatus">Initializing...</div>

    @*
     * ── Controls ─────────────────────────────────────────────────────────
     * NOTE: enrollStartBtn is a LEGACY button kept for backward compat.
     * enrollment-ui.js hides it immediately on load.
     * The camera auto-starts when showLive() calls window.FaceAttendEnrollment.start().
     * Confirm and Retake are shown/hidden programmatically.
     *@
    <div class="enroll-controls">
        <button class="btn btn-primary" id="enrollStartBtn" type="button" style="display:none;">
            <i class="fa-solid fa-camera"></i> Start Enrollment
        </button>
        <button class="btn btn-success enroll-hidden" id="enrollConfirmBtn" type="button">
            <i class="fa-solid fa-check"></i> Save Enrollment
        </button>
        <button class="btn btn-secondary enroll-hidden" id="enrollRetakeBtn" type="button">
            <i class="fa-solid fa-rotate-left"></i> Retake
        </button>
    </div>

</div>
@*
 * NO INLINE SCRIPT HERE.
 * enrollment-ui.js (from ~/bundles/enrollment) handles all enrollment logic.
 * Each view that uses this partial MUST load ~/bundles/enrollment.
 * See: Employees/Enroll.cshtml, Visitors/Enroll.cshtml @section scripts.
 *@
