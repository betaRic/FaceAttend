@*
 * REPLACE the Step 2 wizard pane in Views/MobileRegistration/Enroll.cshtml
 *
 * The original passed "TEMP_" + Guid as EmployeeId to the component.
 * The component then submits that fake ID to the server.
 * The mobile flow reads the REAL EmployeeId from the form field separately,
 * so the component's empId is irrelevant for mobile — it never calls its own
 * enroll endpoint. We pass an empty string so the component renders cleanly
 * and we intercept submission ourselves via window.enrollCallbacks.
 *
 * Also: use full path for partial to avoid silent fallback ambiguity.
 *@

@* Step 2: Capture - Using Shared Enrollment Component *@
<div class="wizard-pane" id="step2">
    <div class="hint-box">
        <i class="fa-solid fa-circle-info"></i>
        <strong>10 Face Samples Required.</strong> Follow the angle prompts: center, left, right, up, down.
    </div>

    @Html.Partial("~/Views/Shared/_EnrollmentComponent.cshtml", new ViewDataDictionary {
        ["EmployeeId"]        = "",
        ["ScanUrl"]           = "/MobileRegistration/ScanFrame",
        ["EnrollUrl"]         = "",
        ["RedirectUrl"]       = "",
        ["Mode"]              = "mobile",
        ["MinFrames"]         = 10,
        ["LivenessThreshold"] = 0.75f
    })

    <div class="wizard-actions">
        <button type="button" class="btn btn-primary" id="btnToReview" disabled>
            <i class="fa-solid fa-arrow-right"></i> Review and Submit
        </button>
        <button type="button" class="btn btn-secondary" id="btnBackToDetails">
            <i class="fa-solid fa-arrow-left"></i> Back to Details
        </button>
    </div>
</div>
