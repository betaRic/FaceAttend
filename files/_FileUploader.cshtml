@using FaceAttend.Models.ViewModels.Shared
@model FaceAttend.Models.ViewModels.Shared.FileUploaderViewModel
@*
    FileUploader Component - Drag-and-drop file upload with validation
    
    FIXES in this version:
    1. fa-uploader__error div has inline style="display:none" — guarantees
       it is hidden regardless of CSS load order or bundle state
    2. fa-uploader__input has no z-index/pointer issues with visible content
    3. fa-uploader__files container pre-wired for chip rendering
    4. Removed data-on-selected attribute — JS init from host view only
       (prevents double-initialization conflict)
    
    USAGE:
    @Html.Partial("~/Views/Shared/Components/_FileUploader.cshtml", new FileUploaderViewModel {
        Id = "employeeUploader",
        Accept = "image/*",
        MaxFiles = 5,
        MaxSizeMB = 10,
        AllowedTypes = new[] { ".jpg", ".jpeg", ".png" },
        OnFilesSelected = "handleFilesSelected",
        Title = "Drop photos here or click to browse",
        Description = "Select 1 to 5 clear, well-lit face photos."
    })
    
    JAVASCRIPT (in host view @section scripts):
    var uploader = FaceAttend.UI.Uploader.init('employeeUploader', {
        maxFiles: 5,
        maxSize: 10 * 1024 * 1024,
        allowedTypes: ['image/jpeg', 'image/png', 'image/jpg'],
        onFilesSelected: function(files) { ... },
        onError: function(errors) { ... }
    });
*@

@{
    var containerClass = "fa-uploader";
    if (Model.Variant == UploaderVariant.Compact) {
        containerClass += " fa-uploader--compact";
    } else if (Model.Variant == UploaderVariant.Borderless) {
        containerClass += " fa-uploader--borderless";
    }

    var acceptAttr = string.Join(",", Model.AllowedTypes);
}

<div class="@containerClass" id="@Model.Id"
     data-max-files="@Model.MaxFiles"
     data-max-size="@(Model.MaxSizeMB * 1024 * 1024)"
     data-accept="@acceptAttr">
    @*
     * NOTE: data-on-selected attribute REMOVED deliberately.
     * It was causing the Uploader JS to attempt a second init via
     * attribute-based initialization, which conflicted with the explicit
     * FaceAttend.UI.Uploader.init() call in the host view scripts section.
     * Always initialize via FaceAttend.UI.Uploader.init() explicitly.
     *@

    <div class="fa-uploader__dropzone" id="@(Model.Id)_dropzone">
        <input type="file"
               class="fa-uploader__input"
               id="@(Model.Id)_input"
               accept="@acceptAttr"
               @(Model.Multiple ? "multiple" : "")
               aria-label="File upload" />

        <div class="fa-uploader__icon">
            <i class="fa-solid fa-cloud-arrow-up"></i>
        </div>
        <div class="fa-uploader__title">@Model.Title</div>
        <div class="fa-uploader__desc">@Model.Description</div>
        <div class="fa-uploader__rules">
            <span>
                <i class="fa-solid fa-file-image"></i>
                @string.Join(", ", Model.AllowedTypes)
            </span>
            @if (Model.MaxFiles > 1)
            {
                <span><i class="fa-solid fa-images"></i> Up to @Model.MaxFiles files</span>
            }
            else
            {
                <span><i class="fa-solid fa-image"></i> 1 file only</span>
            }
            <span><i class="fa-solid fa-weight-hanging"></i> Max @Model.MaxSizeMB MB</span>
        </div>
    </div>

    @*
     * File chip list — populated by FaceAttend.UI.Uploader JS
     * after files are selected. Each file gets a .fa-uploader__chip element.
     *@
    <div class="fa-uploader__files" id="@(Model.Id)_files"></div>

    @*
     * Error message area — MUST start hidden.
     * inline style="display:none" is a HARD guarantee regardless of
     * CSS bundle load order. The .fa-uploader__error CSS rule in uploader.css
     * also sets display:none but this inline style is the safety net.
     *
     * The Uploader JS adds class "is-visible" to show this div on error.
     *@
    <div class="fa-uploader__error"
         id="@(Model.Id)_error"
         style="display:none;"
         role="alert"
         aria-live="polite"></div>
</div>
