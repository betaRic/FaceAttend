<?xml version="1.0"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <system.web>
    <!-- Release build: siguraduhing walang debug compilation sa production. -->
    <compilation debug="false"
                 xdt:Transform="SetAttributes(debug)" />

    <!--
      RemoteOnly = remote users get safe generic errors, pero local/RDP admin
      makakakita pa rin ng detailed yellow-screen error page para sa mabilis na
      troubleshooting sa production server.
    -->
    <customErrors mode="RemoteOnly"
                  xdt:Transform="SetAttributes(mode)" />
  </system.web>

  <appSettings>
    <add key="Security:HstsEnabled"
         value="true"
         xdt:Transform="SetAttributes(value)"
         xdt:Locator="Match(key)" />

    <add key="Security:CspReportOnly"
         value="false"
         xdt:Transform="SetAttributes(value)"
         xdt:Locator="Match(key)" />

    <add key="Biometrics:Debug"
         value="false"
         xdt:Transform="SetAttributes(value)"
         xdt:Locator="Match(key)" />
  </appSettings>
</configuration>
