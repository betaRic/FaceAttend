<!doctype html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - FaceAttend Admin</title>
    
    <!-- Inter Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    @Styles.Render("~/Content/css")
    @Styles.Render("~/Content/fa-system")      @* Design System Tokens (v3) *@
    @Styles.Render("~/bundles/vendor-css")
    @Styles.Render("~/Content/admin")
    @Styles.Render("~/Content/fa-components")  @* Component CSS *@
    @RenderSection("head", required: false)
    @RenderSection("styles", required: false)
</head>
<body class="admin-body">

    <!-- Page loading overlay — visible until DOM ready, shown again on navigation -->
    <div id="pageLoader" aria-hidden="true">
        <div class="page-loader-spinner">
            <svg viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
                <circle cx="25" cy="25" r="20" fill="none" stroke-width="4"
                        stroke="currentColor" stroke-linecap="round"
                        stroke-dasharray="80 40" />
            </svg>
            <span>Loading</span>
        </div>
    </div>
    <style>
        #pageLoader {
            position: fixed; inset: 0; z-index: 99999;
            display: flex; align-items: center; justify-content: center;
            background: var(--fa-surface, #f8fafc);
            transition: opacity .25s ease, visibility .25s ease;
        }
        #pageLoader.loader-hidden {
            opacity: 0; visibility: hidden; pointer-events: none;
        }
        .page-loader-spinner {
            display: flex; flex-direction: column; align-items: center; gap: .75rem;
        }
        .page-loader-spinner svg {
            width: 44px; height: 44px;
            color: var(--fa-primary, #3b82f6);
            animation: loader-spin .9s linear infinite;
        }
        .page-loader-spinner span {
            font-size: .82rem; font-weight: 500;
            color: var(--fa-text-muted, #64748b);
            letter-spacing: .03em;
        }
        @@keyframes loader-spin { to { transform: rotate(360deg); } }
    </style>

    <!-- Topbar -->
    <header class="admin-topbar">
        <div class="container-fluid h-100">
            <div class="d-flex align-items-center justify-content-between h-100">
                <!-- Left: Menu toggle + Brand -->
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-link text-light d-lg-none p-1"
                            type="button"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#adminSidebar"
                            aria-controls="adminSidebar"
                            aria-label="Open menu">
                        <i class="fa-solid fa-bars fa-lg"></i>
                    </button>

                    <a class="admin-brand" href="@Url.Action("Index","Dashboard", new { area = "Admin" })">
                        <span class="admin-brand-mark" aria-hidden="true">D</span>
                        <span>FaceAttend</span>
                    </a>
                </div>

                <!-- Right: Actions -->
                <div class="d-flex align-items-center gap-2">
                    <a class="btn btn-outline-light btn-sm"
                       href="@Url.Action("Index","Kiosk", new { area = "" })"
                       title="Open Kiosk">
                        <i class="fa-solid fa-desktop"></i>
                        <span class="d-none d-sm-inline ms-1">Kiosk</span>
                    </a>

                    <button id="btnRefresh"
                            type="button"
                            class="btn btn-outline-light btn-sm d-none d-md-inline-flex"
                            title="Refresh Page">
                        <i class="fa-solid fa-rotate"></i>
                    </button>

                    <!-- Admin dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-light btn-sm dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            <i class="fa-solid fa-user-shield d-sm-none"></i>
                            <span class="d-none d-sm-inline">Admin</span>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2">
                            <li>
                                <h6 class="dropdown-header">System</h6>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index","Settings", new { area = "Admin" })">
                                    <i class="fa-solid fa-gear fa-fw me-2 text-muted"></i>Settings
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                @using (Html.BeginForm("Lock", "Kiosk", new { area = "" }, FormMethod.Post, new { @class = "d-block" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="dropdown-item text-warning"
                                            data-confirm="Return to kiosk?"
                                            data-confirm-text="You will be taken to the kiosk. You can return to admin without re-entering your PIN for the rest of the workday."
                                            data-confirm-icon="info">
                                        <i class="fa-solid fa-desktop fa-fw me-2"></i>Go to Kiosk
                                    </button>
                                }
                            </li>
                            <li>
                                @using (Html.BeginForm("FullLock", "Kiosk", new { area = "" }, FormMethod.Post, new { @class = "d-block" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="dropdown-item text-danger"
                                            data-confirm="Sign out completely?"
                                            data-confirm-text="This will end your admin session. You will need to re-enter your PIN to access admin again."
                                            data-confirm-icon="warning">
                                        <i class="fa-solid fa-right-from-bracket fa-fw me-2"></i>Sign Out
                                    </button>
                                }
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Page -->
    <div class="admin-shell">
        <!-- Sidebar: Offcanvas on mobile, fixed on desktop -->
        <div class="offcanvas-lg offcanvas-start admin-sidebar"
             tabindex="-1"
             id="adminSidebar"
             aria-labelledby="adminSidebarLabel">
            <div class="offcanvas-header d-lg-none">
                <h5 class="offcanvas-title" id="adminSidebarLabel">Menu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>

            <div class="offcanvas-body p-0">
                @Html.Partial("~/Areas/Admin/Views/Shared/_AdminNav.cshtml")
            </div>
        </div>

        <!-- Main -->
        <main class="admin-main">
            <div class="admin-content container-fluid">
                
                @* Inline error alerts - shown when TempData["Error"] is set *@
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                        <i class="fa-solid fa-circle-xmark me-2"></i>
                        <strong>Error:</strong> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                
                @* Inline success alerts - shown when TempData["Success"] is set *@
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i>
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                
                @* Inline module error - shown when ViewBag.ModuleError is set *@
                @if (ViewBag.ModuleError != null)
                {
                    <div class="ea-page mt-3">
                        <div class="ea-alert danger mb-0">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i>
                            @ViewBag.ModuleError
                        </div>
                    </div>
                }
                
                @RenderBody()

                <footer class="admin-footer">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <span class="text-muted">FaceAttend Admin</span>
                        <span class="text-muted" id="footerYear"></span>
                    </div>
                </footer>
            </div>
        </main>
    </div>

    <!-- Idle overlay (front-end only) -->
    <div id="idleOverlay" class="idle-overlay d-none" role="dialog" aria-modal="true" aria-label="Idle">
        <div class="idle-card">
            <div class="idle-title">
                <i class="fa-regular fa-moon me-2" aria-hidden="true"></i>
                Idle
            </div>
            <div class="idle-text">Click to continue.</div>
        </div>
    </div>

    @if (TempData["msg"] != null)
    {
        <script>
            window.__toastMsg = "@System.Web.HttpUtility.JavaScriptStringEncode(TempData["msg"].ToString())";
        </script>
    }

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/toastr")
    @Scripts.Render("~/bundles/sweetalert")
    @Scripts.Render("~/bundles/vendor")
    @Scripts.Render("~/bundles/admin")
    
    <!-- Backdrop cleanup for Bootstrap offcanvas -->
    <script>
        (function () {
            'use strict';
            var sidebar = document.getElementById('adminSidebar');
            if (!sidebar) return;

            // Bootstrap offcanvas-lg fires these events correctly - use them
            sidebar.addEventListener('hidden.bs.offcanvas', function () {
                // Bootstrap handles backdrop removal - just clean up body state
                document.body.style.overflow = '';
                document.body.style.paddingRight = '';
            });
        })();
    </script>
    
    @RenderSection("scripts", required: false)

    <script>
        (function () {
            'use strict';
            var loader = document.getElementById('pageLoader');
            function hideLoader() {
                if (loader) loader.classList.add('loader-hidden');
            }
            // Hide as soon as DOM is interactive
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', hideLoader);
            } else {
                hideLoader();
            }
            // Show again when navigating away (gives immediate feedback on slow pages)
            window.addEventListener('beforeunload', function () {
                if (loader) loader.classList.remove('loader-hidden');
            });
            // Also show on anchor navigation that changes the page
            document.addEventListener('click', function (e) {
                var a = e.target.closest('a[href]');
                if (!a) return;
                var href = a.getAttribute('href');
                // Skip: anchors, javascript:, external links, new-tab, download
                if (!href || href.charAt(0) === '#' || href.indexOf('javascript:') === 0) return;
                if (a.target === '_blank' || a.hasAttribute('download')) return;
                try {
                    var url = new URL(href, window.location.href);
                    if (url.origin !== window.location.origin) return;
                } catch (ex) { return; }
                if (loader) loader.classList.remove('loader-hidden');
            });
        })();
    </script>

    <script>
        (function () {
            'use strict';

            var HEARTBEAT_MS  = 5 * 60 * 1000;
            var WARN_BEFORE_S = 5 * 60;
            var heartbeatUrl  = '@Url.Action("Heartbeat", "Settings", new { area = "Admin" })';
            var banner;

            function ensureBanner() {
                if (banner) return banner;
                banner = document.createElement('div');
                banner.id = 'session-expiry-warning';
                banner.style.cssText = [
                    'display:none',
                    'position:fixed',
                    'bottom:1rem',
                    'right:1rem',
                    'z-index:9999',
                    'background:#dc3545',
                    'color:#fff',
                    'padding:.65rem 1.1rem',
                    'border-radius:.5rem',
                    'font-size:.87rem',
                    'box-shadow:0 4px 16px rgba(0,0,0,.25)',
                    'cursor:pointer'
                ].join(';');
                banner.addEventListener('click', sendHeartbeat);
                document.body.appendChild(banner);
                return banner;
            }

            function showWarning(secondsLeft) {
                var el = ensureBanner();
                el.style.display = 'block';
                el.innerHTML = '⚠ Admin session expires in <strong>' +
                    Math.ceil(secondsLeft / 60) + ' min</strong>. ' +
                    '<span style="text-decoration:underline;cursor:pointer">Click to extend.</span>';
            }

            function hideWarning() {
                if (banner) banner.style.display = 'none';
            }

            function sendHeartbeat() {
                var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                var body = tokenInput ? '__RequestVerificationToken=' + encodeURIComponent(tokenInput.value) : '';

                return fetch(heartbeatUrl, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: body
                }).then(function (res) {
                    if (res.redirected || res.status === 302 || res.status === 401 || res.status === 403) {
                        showWarning(0);
                        setTimeout(function () { window.location.reload(); }, 1500);
                        return null;
                    }
                    return res.json();
                }).then(function (data) {
                    if (!data) return;
                    if (data.ok) {
                        if (data.expiresIn && data.expiresIn <= WARN_BEFORE_S) showWarning(data.expiresIn);
                        else hideWarning();
                    }
                }).catch(function (err) {
                    console.warn('[FaceAttend] heartbeat failed', err);
                });
            }

            setInterval(sendHeartbeat, HEARTBEAT_MS);
        })();
    </script>
</body>
</html>
