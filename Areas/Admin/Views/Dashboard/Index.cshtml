@* ============================================================================
   Areas/Admin/Views/Dashboard/Index.cshtml
   
   Main admin dashboard view for FaceAttend.
   
   DEPENDENCIES (ViewModel):
     FaceAttend.Areas.Admin.Models.DashboardViewModel
     — KPI counts, recent logs, system health flags, circuit breaker flags
   
   SECTIONS:
     @section styles  — page-scoped CSS (health dots, mini-bar chart)
     @section scripts — AJAX KPI refresh + circuit-breaker JS (bottom of page)
   
   AJAX REFRESH:
     KPI numbers are refreshed every 2 minutes via fetch() against:
       GET /Admin/Dashboard/KpiJson
     The full page is never auto-reloaded — only the 5 number elements are
     patched in-place.  Element IDs must match kpiMap in the scripts section.
   ============================================================================ *@

@model FaceAttend.Areas.Admin.Models.DashboardViewModel
@{
    ViewBag.Title = "Dashboard";
}

@* ── Page-scoped styles ───────────────────────────────────────────────────── *@
@section styles {
<style>
    /* ── System health indicator dots ──────────────────────────────────────── */
    .ea-health-dot {
        width: .65rem;
        height: .65rem;
        border-radius: 50%;
        flex-shrink: 0;
        display: inline-block;
    }
    .ea-health-dot.ok   { background: #198754; }
    .ea-health-dot.warn { background: #fd7e14; }
    .ea-health-dot.fail { background: #dc3545; }

    /* ── Mini bar-chart widget (reserved for future 7-day attendance bar) ─── */
    .ea-mini-bar-track {
        display: flex;
        align-items: flex-end;
        gap: 3px;
        height: 56px;
    }
    .ea-mini-bar {
        flex: 1;
        border-radius: 4px 4px 0 0;
        min-width: 6px;
        min-height: 3px;
        transition: opacity .15s;
    }
    .ea-mini-bar:hover { opacity: .75; }
    .ea-mini-bar-label {
        font-size: .58rem;
        text-align: center;
        color: #6c757d;
        margin-top: 2px;
        overflow: hidden;
        white-space: nowrap;
    }
</style>
}

<div class="ea-page">

    @* ── Page header ────────────────────────────────────────────────────────── *@
    <div class="ea-page-header">
        <div>
            <h1 class="ea-page-title">
                <i class="fa-solid fa-gauge-high" aria-hidden="true"></i>
                Dashboard
            </h1>
            @* TodayDateDisplay is computed in the ViewModel using the configured
                Philippine timezone (Asia/Manila) so it always shows local date. *@
            <div class="ea-page-subtitle">@Model.TodayDateDisplay</div>
        </div>
        <div class="ea-page-actions">
            <a class="btn btn-outline-secondary btn-sm"
               href="@Url.Action("Index", "Attendance", new { area = "Admin", from = "today" })">
                <i class="fa-solid fa-clock-rotate-left me-1" aria-hidden="true"></i>Today's Logs
            </a>
        </div>
    </div>

    @* ── Circuit-breaker warning banner ─────────────────────────────────────
       Hidden by default (display:none).
       Shown immediately on page load if circuit was open at render time.
       Also toggled by the AJAX refresh loop (see @section scripts below).
       The Reset Circuit button posts to DashboardController.ResetLivenessCircuit.
    ─────────────────────────────────────────────────────────────────────────── *@
    <div id="circuit-breaker-warning"
         class="alert alert-danger d-flex align-items-center gap-2 mb-3"
         style="display:none !important;"
         role="alert">
        <i class="fa-solid fa-triangle-exclamation fa-lg flex-shrink-0" aria-hidden="true"></i>
        <div class="flex-grow-1">
            <strong>Liveness Detection Problem!</strong>
            The liveness circuit breaker is open — employees cannot scan at the kiosk.
            Check system logs and reset when the issue is resolved.
        </div>
        @using (Html.BeginForm("ResetLivenessCircuit", "Dashboard", new { area = "Admin" }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-light btn-sm flex-shrink-0">
                <i class="fa-solid fa-rotate-right me-1" aria-hidden="true"></i>Reset Circuit
            </button>
        }
    </div>

    @* ── Pending-review alert ─────────────────────────────────────────────────
       Shown only when attendance records are flagged NeedsReview = true.
       Count is rendered server-side on page load; AJAX does not refresh this
       banner — a manual page reload picks up changes after the admin reviews.
    ─────────────────────────────────────────────────────────────────────────── *@
    @if (Model.PendingReviews > 0)
    {
        <div class="ea-alert warning mb-3">
            <i class="fa-solid fa-triangle-exclamation fa-sm flex-shrink-0" aria-hidden="true"></i>
            <div>
                <strong>@Model.PendingReviews attendance @(Model.PendingReviews == 1 ? "record" : "records")</strong>
                flagged for review.
                <a href="@Url.Action("Index", "Attendance", new { area = "Admin", needsReview = true })"
                   class="fw-semibold ms-1">
                    Review now <i class="fa-solid fa-arrow-right ms-1 fa-xs" aria-hidden="true"></i>
                </a>
            </div>
        </div>
    }

    @* ── KPI cards ────────────────────────────────────────────────────────────
       IMPORTANT: The id attributes on ea-kpi-num spans MUST match kpiMap
       in the @section scripts below.  If you rename an id here, update
       kpiMap in the script too.
    ─────────────────────────────────────────────────────────────────────────── *@
    <div class="row g-3 mb-3">

        @* Active Employees *@
        <div class="col-6 col-xl-3">
            <a class="ea-kpi" href="@Url.Action("Index", "Employees", new { area = "Admin" })">
                <div class="ea-kpi-icon primary">
                    <i class="fa-solid fa-users" aria-hidden="true"></i>
                </div>
                <div class="ea-kpi-body">
                    <div class="ea-kpi-num" id="kpi-total-employees">@Model.TotalEmployees</div>
                    <div class="ea-kpi-label">Active Employees</div>
                </div>
            </a>
        </div>

        @* Time-Ins Today *@
        <div class="col-6 col-xl-3">
            <a class="ea-kpi" href="@Url.Action("Index", "Attendance", new { area = "Admin", from = "today", eventType = "IN" })">
                <div class="ea-kpi-icon success">
                    <i class="fa-solid fa-arrow-right-to-bracket" aria-hidden="true"></i>
                </div>
                <div class="ea-kpi-body">
                    <div class="ea-kpi-num" id="kpi-today-ins">@Model.TodayTimeIns</div>
                    <div class="ea-kpi-label">Time-Ins Today</div>
                </div>
            </a>
        </div>

        @* Time-Outs Today *@
        <div class="col-6 col-xl-3">
            <a class="ea-kpi" href="@Url.Action("Index", "Attendance", new { area = "Admin", from = "today", eventType = "OUT" })">
                <div class="ea-kpi-icon warning">
                    <i class="fa-solid fa-arrow-right-from-bracket" aria-hidden="true"></i>
                </div>
                <div class="ea-kpi-body">
                    <div class="ea-kpi-num" id="kpi-today-outs">@Model.TodayTimeOuts</div>
                    <div class="ea-kpi-label">Time-Outs Today</div>
                </div>
            </a>
        </div>

        @* Known Visitors *@
        <div class="col-6 col-xl-3">
            <a class="ea-kpi" href="@Url.Action("Index", "Visitors", new { area = "Admin" })">
                <div class="ea-kpi-icon" style="background:rgba(111,66,193,.1);color:#6f42c1;">
                    <i class="fa-solid fa-user-check" aria-hidden="true"></i>
                </div>
                <div class="ea-kpi-body">
                    <div class="ea-kpi-num" id="kpi-total-visitors">@Model.TotalVisitors</div>
                    <div class="ea-kpi-label">Known Visitors</div>
                </div>
            </a>
        </div>

    </div>

    @* ── Lower row: recent logs (left) + system health / quick links (right) ─ *@
    <div class="row g-3">

        @* -- Recent attendance table ----------------------------------------- *@
        <div class="col-12 col-xl-8">
            <div class="ea-table-card h-100">
                <div class="ea-table-header">
                    <div class="ea-table-title">
                        <i class="fa-solid fa-clock-rotate-left text-primary" aria-hidden="true"></i>
                        Recent Attendance
                    </div>
                    <a class="btn btn-outline-secondary btn-sm"
                       href="@Url.Action("Index", "Attendance", new { area = "Admin" })">
                        View all <i class="fa-solid fa-arrow-right fa-xs ms-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="table-responsive">
                    @if (Model.RecentLogs == null || !Model.RecentLogs.Any())
                    {
                        <div class="ea-empty" style="padding:3rem 2rem;">
                            <i class="fa-solid fa-clock" aria-hidden="true"></i>
                            <div class="ea-empty-title">No records yet</div>
                            <div class="ea-empty-desc">Attendance logs will appear here after the first kiosk scan.</div>
                        </div>
                    }
                    else
                    {
                        <table class="ea-table table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Employee</th>
                                    <th>Event</th>
                                    <th>Office</th>
                                    <th class="text-end">Flag</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.RecentLogs)
                                {
                                    var isIn = string.Equals(row.EventType, "IN", StringComparison.OrdinalIgnoreCase);
                                    <tr class="@(row.NeedsReview ? "table-warning" : "")">

                                        @* Timestamp (local Philippine time) *@
                                        <td class="text-nowrap">
                                            <span class="fw-semibold" style="font-size:.85rem;">
                                                @row.TimestampLocalDisplay
                                            </span>
                                        </td>

                                        @* Employee name + ID *@
                                        <td>
                                            <div class="fw-semibold" style="font-size:.875rem;">@row.EmployeeFullName</div>
                                            @if (!string.IsNullOrWhiteSpace(row.EmployeeId))
                                            {
                                                <div class="ea-cell-muted">@row.EmployeeId</div>
                                            }
                                        </td>

                                        @* IN / OUT badge *@
                                        <td>
                                            @if (isIn)
                                            {
                                                <span class="ea-badge time-in">
                                                    <i class="fa-solid fa-arrow-right-to-bracket fa-xs"></i>IN
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="ea-badge time-out">
                                                    <i class="fa-solid fa-arrow-right-from-bracket fa-xs"></i>OUT
                                                </span>
                                            }
                                        </td>

                                        @* Office name (snapshot stored on the log row) *@
                                        <td class="ea-cell-muted" style="font-size:.82rem;">
                                            @(string.IsNullOrWhiteSpace(row.OfficeName) ? "-" : row.OfficeName)
                                        </td>

                                        @* NeedsReview flag *@
                                        <td class="text-end">
                                            @if (row.NeedsReview)
                                            {
                                                <span class="ea-badge review">
                                                    <i class="fa-solid fa-flag fa-xs"></i>Review
                                                </span>
                                            }
                                        </td>

                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        @* -- Right column: system health + quick links ----------------------- *@
        <div class="col-12 col-xl-4">

            @* System health card *@
            <div class="ea-card mb-3">
                <div class="ea-card-body">
                    <div class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <i class="fa-solid fa-heart-pulse text-primary" aria-hidden="true"></i>
                        System Health
                    </div>

                    @{
                        /*
                         * healthItems drives the health-check rows.
                         * To add a new check, append a row here — no other HTML needed.
                         * The DB health dot (id="db-health-indicator") is updated by
                         * the AJAX refresh loop when it receives a new dbHealthy value.
                         */
                        var healthItems = new[]
                        {
                            new { Label = "Database",       Ok = Model.DatabaseHealthy,     Icon = "fa-database",    DomId = "db-health-indicator" },
                            new { Label = "Liveness model", Ok = Model.LivenessModelLoaded, Icon = "fa-eye",         DomId = ""                    },
                            new { Label = "Dlib models",    Ok = Model.DlibModelsLoaded,    Icon = "fa-face-smile",  DomId = ""                    },
                            new { Label = "Offline assets", Ok = Model.OfflineAssetsOk,     Icon = "fa-wifi",        DomId = ""                    },
                        };
                    }

                    <div class="d-flex flex-column gap-2">
                        @foreach (var item in healthItems)
                        {
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="d-flex align-items-center gap-2 text-muted" style="font-size:.85rem;">
                                    <i class="fa-solid @item.Icon fa-fw fa-sm" aria-hidden="true"></i>
                                    @item.Label
                                </span>
                                <span class="d-flex align-items-center gap-1"
                                      style="font-size:.78rem;font-weight:600;"
                                      id="@(string.IsNullOrEmpty(item.DomId) ? null : item.DomId)"
                                      title="@(item.Ok ? item.Label + " OK" : item.Label + " Error")">
                                    <span class="ea-health-dot @(item.Ok ? "ok" : "fail")"></span>
                                    <span class="@(item.Ok ? "text-success" : "text-danger")">
                                        @(item.Ok ? "OK" : "Error")
                                    </span>
                                </span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Pending reviews KPI (also refreshed by AJAX) *@
            <div class="ea-card mb-3">
                <div class="ea-card-body d-flex align-items-center justify-content-between">
                    <span class="d-flex align-items-center gap-2 text-muted" style="font-size:.85rem;">
                        <i class="fa-solid fa-flag fa-fw fa-sm text-warning" aria-hidden="true"></i>
                        Pending Reviews
                    </span>
                    <span id="kpi-pending-reviews"
                          class="fw-bold @(Model.PendingReviews > 0 ? "text-warning" : "text-success")"
                          style="font-size:1.1rem;">
                        @Model.PendingReviews
                    </span>
                </div>
            </div>

            @* Quick links card *@
            <div class="ea-card">
                <div class="ea-card-body">
                    <div class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <i class="fa-solid fa-bolt text-primary" aria-hidden="true"></i>
                        Quick Actions
                    </div>
                    <div class="d-flex flex-column gap-2">
                        <a class="btn btn-outline-primary btn-sm text-start"
                           href="@Url.Action("Index", "Employees", new { area = "Admin" })">
                            <i class="fa-solid fa-users me-2 fa-fw" aria-hidden="true"></i>Manage Employees
                        </a>
                        <a class="btn btn-outline-secondary btn-sm text-start"
                           href="@Url.Action("SummaryReport", "Attendance", new { area = "Admin", from = "thismonth" })">
                            <i class="fa-solid fa-chart-column me-2 fa-fw" aria-hidden="true"></i>Monthly Summary
                        </a>
                        <a class="btn btn-outline-secondary btn-sm text-start"
                           href="@Url.Action("Index", "Offices", new { area = "Admin" })">
                            <i class="fa-solid fa-building me-2 fa-fw" aria-hidden="true"></i>Office Setup
                        </a>
                        <a class="btn btn-outline-secondary btn-sm text-start"
                           href="@Url.Action("Index", "Settings", new { area = "Admin" })">
                            <i class="fa-solid fa-gear me-2 fa-fw" aria-hidden="true"></i>Settings
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@* ============================================================================
   SCRIPTS SECTION
   ─────────────────────────────────────────────────────────────────────────────
   WHAT THIS DOES:
     • Replaces the old  setTimeout(location.reload, 60000)  full-page reload.
     • Every 2 minutes, fires a lightweight AJAX request to /Admin/Dashboard/KpiJson
       that runs 5 COUNT queries and returns ~200 bytes of JSON.
     • Only the 5 KPI number elements are patched in-place — no full redraw,
       no scroll-position loss, no interruption to the admin working in other tabs.

   ELEMENT IDs THAT MUST EXIST ON THE PAGE (mapped in kpiMap below):
     kpi-total-employees   — Active Employees card number
     kpi-today-ins         — Time-Ins Today card number
     kpi-today-outs        — Time-Outs Today card number
     kpi-total-visitors    — Known Visitors card number
     kpi-pending-reviews   — Pending Reviews badge (right column)

   CIRCUIT BREAKER:
     If the server reports  livenessCircuitOpen = true  or
     livenessCircuitStuck = true, the #circuit-breaker-warning banner is shown.
     It is hidden again as soon as both flags go false.
   ============================================================================ *@
@section scripts {
<script>
(function () {
    'use strict';

    // ─────────────────────────────────────────────────────────────────────────
    // CONFIGURATION
    // ─────────────────────────────────────────────────────────────────────────

    /**
     * How often (milliseconds) to poll the KpiJson endpoint.
     * 2 minutes is a good balance: fresh enough for an admin watching the
     * dashboard, cheap enough to not hammer the DB.
     * 120_000 == 120 seconds.
     */
    var REFRESH_MS = 120000;

    /**
     * URL of the lightweight KPI endpoint.
     * Razor resolves this at render time to the correct routed URL.
     */
    var kpiUrl = '@Url.Action("KpiJson", "Dashboard", new { area = "Admin" })';

    /**
     * Map of JSON field names returned by KpiJson  →  DOM element IDs.
     * If you add a new KPI card, add its entry here AND give the number
     * element the matching id in the HTML above.
     */
    var kpiMap = {
        totalEmployees : 'kpi-total-employees',
        todayIns       : 'kpi-today-ins',
        todayOuts      : 'kpi-today-outs',
        totalVisitors  : 'kpi-total-visitors',
        pendingReviews : 'kpi-pending-reviews'
    };

    // ─────────────────────────────────────────────────────────────────────────
    // CIRCUIT BREAKER: show warning banner on initial page load if needed
    // This runs synchronously — the Razor @if block emits the JS call only
    // when the circuit was already open when the page was rendered.
    // ─────────────────────────────────────────────────────────────────────────
    @if (Model.LivenessCircuitOpen || Model.LivenessCircuitStuck)
    {
        <text>
        document.addEventListener('DOMContentLoaded', function () {
            var warn = document.getElementById('circuit-breaker-warning');
            if (warn) warn.style.removeProperty('display');
        });
        </text>
    }

    // ─────────────────────────────────────────────────────────────────────────
    // CORE REFRESH FUNCTION
    // Called on a fixed interval — never on page load (the server-rendered
    // HTML already has fresh data at load time).
    // ─────────────────────────────────────────────────────────────────────────

    /**
     * Fetches KpiJson and patches KPI number elements and status indicators.
     * All failures are swallowed silently — stale numbers are better than
     * error dialogs appearing in front of an admin doing other work.
     */
    function refreshKpis() {
        fetch(kpiUrl, {
            method      : 'GET',
            credentials : 'same-origin',
            headers     : { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function (res) {
            if (!res.ok) throw new Error('HTTP ' + res.status);
            return res.json();
        })
        .then(function (data) {

            // Server signals a DB error — leave existing numbers unchanged.
            if (!data.ok) return;

            // ── Patch KPI number elements ──────────────────────────────────
            Object.keys(kpiMap).forEach(function (key) {
                var el = document.getElementById(kpiMap[key]);
                if (el && data[key] !== undefined) {
                    el.textContent = data[key].toLocaleString();
                }
            });

            // ── Patch DB health indicator ──────────────────────────────────
            // The health dot + text are inside the element with id="db-health-indicator".
            // We update its title so screenreaders / tooltips stay accurate;
            // full dot/color re-rendering would require more DOM surgery.
            var dbHealth = document.getElementById('db-health-indicator');
            if (dbHealth) {
                dbHealth.title = data.dbHealthy ? 'Database OK' : 'Database Error';
            }

            // ── Circuit-breaker warning banner ────────────────────────────
            var circuitWarn = document.getElementById('circuit-breaker-warning');
            if (circuitWarn) {
                var circuitOpen = data.livenessCircuitOpen || data.livenessCircuitStuck;
                if (circuitOpen) {
                    circuitWarn.style.removeProperty('display');
                } else {
                    circuitWarn.style.setProperty('display', 'none', 'important');
                }
            }

            // ── Server time display (optional) ────────────────────────────
            // Uncomment if you add an element with id="server-time" to the page.
            // var timeEl = document.getElementById('server-time');
            // if (timeEl && data.serverTimeLocal) {
            //     timeEl.textContent = data.serverTimeLocal;
            // }
        })
        .catch(function (err) {
            // Silent failure — do not interrupt the admin with an alert.
            // Numbers stay at their last-known values until the next interval.
            if (window.console) {
                console.warn('[FaceAttend Dashboard] KPI refresh failed:', err);
            }
        });
    }

    // ─────────────────────────────────────────────────────────────────────────
    // START THE REFRESH LOOP
    // setInterval (not setTimeout) so it keeps ticking without chaining.
    // The first tick fires after REFRESH_MS, not immediately, because the
    // page render already contains the freshest data.
    // ─────────────────────────────────────────────────────────────────────────
    setInterval(refreshKpis, REFRESH_MS);

})();
</script>
}
