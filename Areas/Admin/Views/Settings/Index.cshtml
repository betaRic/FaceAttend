@model FaceAttend.Models.ViewModels.Admin.SettingsVm
@{
    ViewBag.Title = "Settings";
}

<style>
    .settings-tabs { position: sticky; top: 0; z-index: 5; display: flex; gap: .5rem; overflow-x: auto; padding: .5rem; margin-bottom: .75rem; background: var(--ea-page-bg, #f8fafc); border: 1px solid rgba(15,23,42,.08); border-radius: 14px; }
    .settings-tab { white-space: nowrap; border: 0; border-radius: 999px; padding: .45rem .9rem; background: #e5e7eb; color: #334155; font-weight: 700; font-size: .85rem; }
    .settings-tab.active { background: #0f172a; color: #fff; }
    .settings-form-shell .ea-form-body { max-height: calc(100vh - 330px); overflow: auto; }
    .settings-form-shell .ea-form-footer { position: sticky; bottom: 0; z-index: 6; background: rgba(255,255,255,.96); backdrop-filter: blur(10px); border-top: 1px solid rgba(15,23,42,.08); box-shadow: 0 -10px 30px rgba(15,23,42,.08); }
    .settings-dirty { display: none; color: #b45309; font-weight: 700; margin-right: auto; }
    .settings-dirty.active { display: inline-flex; align-items: center; }
    .ea-settings-section[hidden], .settings-security-card[hidden] { display: none !important; }
</style>

<div class="ea-page">

    <div class="ea-page-header">
        <div>
            <h1 class="ea-page-title">
                <i class="fa-solid fa-gear" aria-hidden="true"></i>
                Settings
            </h1>
            <div class="ea-page-subtitle">
                Override system values. Changes apply immediately across kiosk and admin.
            </div>
        </div>
        <div class="ea-page-actions">
            <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
                <i class="fa-solid fa-gauge-high me-1" aria-hidden="true"></i>Dashboard
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.WarningMessage))
    {
        <div class="ea-alert warning mb-3">
            <i class="fa-solid fa-triangle-exclamation fa-sm" aria-hidden="true"></i>
            @Model.WarningMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.SavedMessage))
    {
        <div class="ea-alert success mb-3">
            <i class="fa-solid fa-circle-check fa-sm" aria-hidden="true"></i>
            @Model.SavedMessage
        </div>
    }

    @using (Html.BeginForm("Save", "Settings", new { area = "Admin" }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="settings-tabs" role="tablist" aria-label="Settings sections">
            <button class="settings-tab" type="button" data-settings-tab="attendance">Attendance</button>
            <button class="settings-tab" type="button" data-settings-tab="recognition">Recognition</button>
            <button class="settings-tab" type="button" data-settings-tab="antiSpoof">Anti-spoof</button>
            <button class="settings-tab" type="button" data-settings-tab="location">Location &amp; Devices</button>
            <button class="settings-tab" type="button" data-settings-tab="visitors">Visitors</button>
            <button class="settings-tab" type="button" data-settings-tab="security">Security/Ops</button>
        </div>

        <input type="hidden" id="settingsActiveTab" name="activeTab" value="" />

        <div class="ea-form-card settings-form-shell">
            <div class="ea-form-header">
                <div class="ea-form-title">
                    <i class="fa-solid fa-sliders" aria-hidden="true"></i>
                    System Configuration
                </div>
            </div>

            <div class="ea-form-body">

                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                <div class="row g-4">

                    @* ── LEFT COLUMN ───────────────────────────────────────────── *@
                    <div class="col-12 col-xl-6">

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-face-smile" aria-hidden="true"></i>
                                Biometrics
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.RecognitionTolerance, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.RecognitionTolerance, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            step = "0.01",
                                            min = "0.20",
                                            max = "1.00"
                                        })
                                        @Html.ValidationMessageFor(m => m.RecognitionTolerance, "", new { @class = "text-danger small" })
                                        <div class="form-text">Lower is stricter. Typical range: 0.55 to 0.65.</div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.AntiSpoofThreshold, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.AntiSpoofThreshold, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            step = "0.01",
                                            min = "0",
                                            max = "1"
                                        })
                                        @Html.ValidationMessageFor(m => m.AntiSpoofThreshold, "", new { @class = "text-danger small" })
                                        <div class="form-text">Higher is stricter for anti-spoof.</div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-gauge-high" aria-hidden="true"></i>
                                Performance
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.BallTreeThreshold, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.BallTreeThreshold, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            min = "10",
                                            max = "5000"
                                        })
                                        @Html.ValidationMessageFor(m => m.BallTreeThreshold, "", new { @class = "text-danger small" })
                                        <div class="form-text">Build BallTree when enrolled users reach this count.</div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.BallTreeLeafSize, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.BallTreeLeafSize, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            min = "4",
                                            max = "64"
                                        })
                                        @Html.ValidationMessageFor(m => m.BallTreeLeafSize, "", new { @class = "text-danger small" })
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.MaxImageDimension, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.MaxImageDimension, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            min = "320",
                                            max = "4096"
                                        })
                                        @Html.ValidationMessageFor(m => m.MaxImageDimension, "", new { @class = "text-danger small" })
                                        <div class="form-text">Images larger than this are resized before detection.</div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.PreprocessJpegQuality, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.PreprocessJpegQuality, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            min = "40",
                                            max = "95"
                                        })
                                        @Html.ValidationMessageFor(m => m.PreprocessJpegQuality, "", new { @class = "text-danger small" })
                                        <div class="form-text">Quality used for resized temp JPEGs.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    @* ── RIGHT COLUMN ──────────────────────────────────────────── *@
                    <div class="col-12 col-xl-6">

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-clock" aria-hidden="true"></i>
                                Attendance Policy
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.MinGapSeconds, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.MinGapSeconds, new { @class = "form-control form-control-sm", type = "number", min = "1", max = "600" })
                                        @Html.ValidationMessageFor(m => m.MinGapSeconds, "", new { @class = "text-danger small" })
                                        <div class="form-text">Anti double-tap floor (applies to all transitions).</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.MinGapInToOutSeconds, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.MinGapInToOutSeconds, new { @class = "form-control form-control-sm", type = "number", min = "300", max = "14400" })
                                        @Html.ValidationMessageFor(m => m.MinGapInToOutSeconds, "", new { @class = "text-danger small" })
                                        <div class="form-text">Minimum wait after Time-In before Time-Out is allowed (default 1800s = 30 min).</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.MinGapOutToInSeconds, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.MinGapOutToInSeconds, new { @class = "form-control form-control-sm", type = "number", min = "60", max = "3600" })
                                        @Html.ValidationMessageFor(m => m.MinGapOutToInSeconds, "", new { @class = "text-danger small" })
                                        <div class="form-text">Minimum wait after Time-Out before Time-In is allowed (default 300s = 5 min).</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.GraceMinutes, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.GraceMinutes, new { @class = "form-control form-control-sm", type = "number", min = "0", max = "60" })
                                        @Html.ValidationMessageFor(m => m.GraceMinutes, "", new { @class = "text-danger small" })
                                        <div class="form-text">Minutes after work start before a scan is marked late.</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.FullDayHours, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.FullDayHours, new { @class = "form-control form-control-sm", type = "number", step = "0.5", min = "1", max = "24" })
                                        @Html.ValidationMessageFor(m => m.FullDayHours, "", new { @class = "text-danger small" })
                                        <div class="form-text">Hours required for a full-day record.</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.HalfDayHours, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.HalfDayHours, new { @class = "form-control form-control-sm", type = "number", step = "0.5", min = "0.5", max = "12" })
                                        @Html.ValidationMessageFor(m => m.HalfDayHours, "", new { @class = "text-danger small" })
                                        <div class="form-text">Hours threshold for a half-day record.</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.LunchDeductAfterHours, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.LunchDeductAfterHours, new { @class = "form-control form-control-sm", type = "number", step = "0.5", min = "0", max = "12" })
                                        @Html.ValidationMessageFor(m => m.LunchDeductAfterHours, "", new { @class = "text-danger small" })
                                        <div class="form-text">Deduct lunch only when hours worked exceed this value.</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.LunchMinutes, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.LunchMinutes, new { @class = "form-control form-control-sm", type = "number", min = "0", max = "120" })
                                        @Html.ValidationMessageFor(m => m.LunchMinutes, "", new { @class = "text-danger small" })
                                        <div class="form-text">Minutes deducted for lunch break.</div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.FlexiRequiredHours, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.FlexiRequiredHours, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            step = "0.5",
                                            min = "1",
                                            max = "12"
                                        })
                                        @Html.ValidationMessageFor(m => m.FlexiRequiredHours, "", new { @class = "text-danger small" })
                                        <div class="form-text">Required hours for flexi employees.</div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.WorkStart, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.WorkStart, new { @class = "form-control form-control-sm", type = "time" })
                                        @Html.ValidationMessageFor(m => m.WorkStart, "", new { @class = "text-danger small" })
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.WorkEnd, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.WorkEnd, new { @class = "form-control form-control-sm", type = "time" })
                                        @Html.ValidationMessageFor(m => m.WorkEnd, "", new { @class = "text-danger small" })
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.LunchStart, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.LunchStart, new { @class = "form-control form-control-sm", type = "time" })
                                        @Html.ValidationMessageFor(m => m.LunchStart, "", new { @class = "text-danger small" })
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.LunchEnd, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.LunchEnd, new { @class = "form-control form-control-sm", type = "time" })
                                        @Html.ValidationMessageFor(m => m.LunchEnd, "", new { @class = "text-danger small" })
                                    </div>

                                    <div class="col-12">
                                        <div class="form-check">
                                            @Html.CheckBoxFor(m => m.NoGracePeriod, new { @class = "form-check-input", id = "NoGracePeriod" })
                                            <label class="form-check-label small" for="NoGracePeriod">
                                                No grace period. Any time after work start is late.
                                            </label>
                                        </div>
                                        @Html.ValidationMessageFor(m => m.NoGracePeriod, "", new { @class = "text-danger small d-block" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                                Location &amp; Wi-Fi
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.GPSAccuracyRequired, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.GPSAccuracyRequired, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            min = "5",
                                            max = "5000"
                                        })
                                        @Html.ValidationMessageFor(m => m.GPSAccuracyRequired, "", new { @class = "text-danger small" })
                                        <div class="form-text">Required GPS accuracy in meters.</div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.GPSRadiusDefault, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.GPSRadiusDefault, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            min = "10",
                                            max = "10000"
                                        })
                                        @Html.ValidationMessageFor(m => m.GPSRadiusDefault, "", new { @class = "text-danger small" })
                                        <div class="form-text">Default office radius in meters.</div>
                                    </div>

                                    <div class="col-12">
                                        @Html.LabelFor(m => m.FallbackOfficeId, new { @class = "form-label" })
                                        @Html.DropDownListFor(m => m.FallbackOfficeId,
                                            Model.OfficeOptions,
                                            new { @class = "form-select form-select-sm" })
                                        @Html.ValidationMessageFor(m => m.FallbackOfficeId, "", new { @class = "text-danger small" })
                                        <div class="form-text">Used when GPS does not match any office.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
                                Review Queue Thresholds
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.NeedsReviewNearMatchRatio, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.NeedsReviewNearMatchRatio, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            step = "0.01",
                                            min = "0.50",
                                            max = "0.99"
                                        })
                                        @Html.ValidationMessageFor(m => m.NeedsReviewNearMatchRatio, "", new { @class = "text-danger small" })
                                        <div class="form-text">Near face threshold.</div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.NeedsReviewAntiSpoofMargin, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.NeedsReviewAntiSpoofMargin, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            step = "0.01",
                                            min = "0",
                                            max = "0.20"
                                        })
                                        @Html.ValidationMessageFor(m => m.NeedsReviewAntiSpoofMargin, "", new { @class = "text-danger small" })
                                        <div class="form-text">Near anti-spoof threshold.</div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.NeedsReviewGpsMargin, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.NeedsReviewGpsMargin, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            min = "0",
                                            max = "200"
                                        })
                                        @Html.ValidationMessageFor(m => m.NeedsReviewGpsMargin, "", new { @class = "text-danger small" })
                                        <div class="form-text">Near GPS limit.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-sliders" aria-hidden="true"></i>
                                Recognition Tolerances
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.AttendanceTolerance, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.AttendanceTolerance, new { @class = "form-control form-control-sm", type = "number", step = "0.01", min = "0.40", max = "0.65" })
                                        @Html.ValidationMessageFor(m => m.AttendanceTolerance, "", new { @class = "text-danger small" })
                                        <div class="form-text">Face distance for attendance scans. Higher = more lenient (default 0.65). <strong>Maximum effective value is 0.65</strong> — values above are clamped by the recognition engine.</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.EnrollmentStrictTolerance, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.EnrollmentStrictTolerance, new { @class = "form-control form-control-sm", type = "number", step = "0.01", min = "0.20", max = "0.70" })
                                        @Html.ValidationMessageFor(m => m.EnrollmentStrictTolerance, "", new { @class = "text-danger small" })
                                        <div class="form-text">Duplicate face detection during enrollment. Lower = stricter (default 0.45).</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.VisitorRecognitionTolerance, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.VisitorRecognitionTolerance, new { @class = "form-control form-control-sm", type = "number", step = "0.01", min = "0.40", max = "0.90" })
                                        @Html.ValidationMessageFor(m => m.VisitorRecognitionTolerance, "", new { @class = "text-danger small" })
                                        <div class="form-text">Face distance for visitor recognition at kiosk (default 0.65).</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
                                Enrollment
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.EnrollCaptureTarget, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.EnrollCaptureTarget, new { @class = "form-control form-control-sm", type = "number", min = "5", max = "25" })
                                        @Html.ValidationMessageFor(m => m.EnrollCaptureTarget, "", new { @class = "text-danger small" })
                                        <div class="form-text">Frames collected per enrollment session (default 25).</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.EnrollMaxStoredVectors, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.EnrollMaxStoredVectors, new { @class = "form-control form-control-sm", type = "number", min = "1", max = "25" })
                                        @Html.ValidationMessageFor(m => m.EnrollMaxStoredVectors, "", new { @class = "text-danger small" })
                                        <div class="form-text">Face vectors stored per employee after diversity selection (default 25). Higher = better angle coverage. Must not exceed capture target.</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.EnrollSharpnessThreshold, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.EnrollSharpnessThreshold, new { @class = "form-control form-control-sm", type = "number", step = "1", min = "10", max = "500" })
                                        @Html.ValidationMessageFor(m => m.EnrollSharpnessThreshold, "", new { @class = "text-danger small" })
                                        <div class="form-text">Minimum image sharpness score (desktop webcam, default 35). High values reject too many frames — keep at 35–45.</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.EnrollSharpnessThresholdMobile, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.EnrollSharpnessThresholdMobile, new { @class = "form-control form-control-sm", type = "number", step = "1", min = "10", max = "100" })
                                        @Html.ValidationMessageFor(m => m.EnrollSharpnessThresholdMobile, "", new { @class = "text-danger small" })
                                        <div class="form-text">Minimum image sharpness score (mobile camera, default 28). Mobile cameras are sharper — keep at 25–35.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-server" aria-hidden="true"></i>
                                Server Capacity
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="alert alert-warning small py-2 mb-3">
                                    <i class="fa-solid fa-triangle-exclamation me-1"></i>
                                    Engine timeout controls how long MVC waits for face analysis before failing closed.
                                </div>
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.EngineAnalyzeTimeoutMs, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.EngineAnalyzeTimeoutMs, new { @class = "form-control form-control-sm", type = "number", min = "500", max = "30000", step = "100" })
                                        @Html.ValidationMessageFor(m => m.EngineAnalyzeTimeoutMs, "", new { @class = "text-danger small" })
                                        <div class="form-text">Maximum wait for a single biometric engine analysis call. Default 5000 ms.</div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.MaxConcurrentScans, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.MaxConcurrentScans, new { @class = "form-control form-control-sm", type = "number", min = "1", max = "32" })
                                        @Html.ValidationMessageFor(m => m.MaxConcurrentScans, "", new { @class = "text-danger small" })
                                        <div class="form-text">Maximum simultaneous attendance scans before 503 is returned. Default 4.</div>
                                    </div>
                                    <div class="col-12">
                                        @Html.LabelFor(m => m.BiometricModelHashes, new { @class = "form-label" })
                                        @Html.TextAreaFor(m => m.BiometricModelHashes, new
                                        {
                                            @class = "form-control form-control-sm font-monospace",
                                            rows = "3",
                                            spellcheck = "false",
                                            placeholder = "face-detector.onnx=...;face-recognizer.onnx=...;anti-spoof.onnx=..."
                                        })
                                        @Html.ValidationMessageFor(m => m.BiometricModelHashes, "", new { @class = "text-danger small" })
                                        <div class="form-text">Stored in database. Change only when replacing ONNX model files.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-person-walking-arrow-right" aria-hidden="true"></i>
                                Visitor Sign-In
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <div class="form-check form-switch">
                                            @Html.CheckBoxFor(m => m.VisitorEnabled, new { @class = "form-check-input", role = "switch", id = "VisitorEnabled" })
                                            <label class="form-check-label" for="VisitorEnabled">
                                                Enable visitor sign-in at kiosk
                                            </label>
                                        </div>
                                        <div class="form-text">
                                            When disabled, unrecognized faces show "Not recognized" instead of opening the visitor form.
                                            Changes apply immediately  no restart needed.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="ea-settings-section">
                            <div class="ea-settings-section-head">
                                <i class="fa-solid fa-user-check" aria-hidden="true"></i>
                                Visitor Retention
                            </div>
                            <div class="ea-settings-section-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.VisitorMaxRecords, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.VisitorMaxRecords, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            min = "100",
                                            max = "500000"
                                        })
                                        @Html.ValidationMessageFor(m => m.VisitorMaxRecords, "", new { @class = "text-danger small" })
                                        <div class="form-text">Soft cap for visitor log rows.</div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        @Html.LabelFor(m => m.VisitorRetentionYears, new { @class = "form-label" })
                                        @Html.TextBoxFor(m => m.VisitorRetentionYears, new
                                        {
                                            @class = "form-control form-control-sm",
                                            type = "number",
                                            min = "1",
                                            max = "20",
                                            step = "1"
                                        })
                                        @Html.ValidationMessageFor(m => m.VisitorRetentionYears, "", new { @class = "text-danger small" })
                                        <div class="form-text">
                                            Logs older than this are deleted on cleanup. Run cleanup from the
                                            <a href="@Url.Action("Index", "Visitors", new { area = "Admin" })">Visitors page</a>.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>

            </div>

            <div class="ea-form-footer">
                <span class="settings-dirty" id="settingsDirty">Unsaved changes</span>
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1" aria-hidden="true"></i>Save Settings
                </button>

                <a class="btn btn-outline-secondary" href="@Url.Action("Index")">
                    <i class="fa-solid fa-rotate me-1" aria-hidden="true"></i>Reload
                </a>

                <a class="btn btn-outline-primary" href="@Url.Action("Index", "Attendance", new { area = "Admin" })">
                    <i class="fa-solid fa-clock me-1" aria-hidden="true"></i>Attendance
                </a>
            </div>
        </div>
    }

    <div class="ea-form-card mt-3 settings-security-card">
        <div class="ea-form-header">
            <div class="ea-form-title">
                <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                Security Maintenance
            </div>
        </div>
        <div class="ea-form-body">
            <div class="mb-4">
                <h6 class="mb-3">
                    <i class="fa-solid fa-key me-2"></i>Admin PIN
                </h6>
                <div class="row g-3">
                    <div class="col-md-5">
                        <div class="card bg-light h-100">
                            <div class="card-body">
                                <h6 class="card-title">Current Storage</h6>
                                <dl class="row mb-0" style="font-size: 0.85rem;">
                                    <dt class="col-6">Database:</dt>
                                    <dd class="col-6">
                                        @if (Model.AdminPinStoredInDatabase)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Not set</span>
                                        }
                                    </dd>
                                    <dt class="col-6">Legacy env:</dt>
                                    <dd class="col-6">
                                        @if (Model.AdminPinUsingLegacyEnvironmentFallback)
                                        {
                                            <span class="badge bg-secondary">Fallback</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No</span>
                                        }
                                    </dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        @using (Html.BeginForm("ChangePin", "Settings", new { area = "Admin" }, FormMethod.Post, new { autocomplete = "off" }))
                        {
                            @Html.AntiForgeryToken()
                            <div class="row g-2">
                                <div class="col-12">
                                    <label class="form-label">Current PIN</label>
                                    <input type="password" name="currentPin" class="form-control form-control-sm" required minlength="6" autocomplete="current-password" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">New PIN</label>
                                    <input type="password" name="newPin" class="form-control form-control-sm" required minlength="6" autocomplete="new-password" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">Confirm new PIN</label>
                                    <input type="password" name="confirmPin" class="form-control form-control-sm" required minlength="6" autocomplete="new-password" />
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-outline-primary btn-sm">
                                        <i class="fa-solid fa-key me-1"></i>Change PIN
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            @* ── TOTP 2FA Section ── *@
            <div class="mb-4">
                <h6 class="mb-3">
                    <i class="fa-solid fa-mobile-screen me-2"></i>Two-Factor Authentication (TOTP)
                </h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title">Current Status</h6>
                                <dl class="row mb-0" style="font-size: 0.85rem;">
                                    <dt class="col-6">Status:</dt>
                                    <dd class="col-6">
                                        @if (Model.TotpEnabled)
                                        {
                                            <span class="badge bg-success">Enabled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Disabled</span>
                                        }
                                    </dd>
                                    <dt class="col-6">Configured:</dt>
                                    <dd class="col-6">
                                        @if (Model.TotpConfigured)
                                        {
                                            <span class="text-success"><i class="fa-solid fa-check"></i> Yes</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted"><i class="fa-solid fa-minus"></i> Not setup</span>
                                        }
                                    </dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        @if (Model.TotpEnabled)
                        {
                            <div class="d-grid gap-2">
                                <a href="@Url.Action("SetupTotp", "Settings")" class="btn btn-outline-primary">
                                    <i class="fa-solid fa-rotate me-1"></i>Re-setup 2FA
                                </a>
                                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#disableTotpModal">
                                    <i class="fa-solid fa-ban me-1"></i>Disable 2FA
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="d-grid">
                                <a href="@Url.Action("SetupTotp", "Settings")" class="btn btn-primary">
                                    <i class="fa-solid fa-shield-halved me-1"></i>Enable 2FA
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="small text-muted mb-3">
                One-time migration ito para i-encrypt ang mga lumang face encodings na naka-plain pa sa database.
                Safe ito sa mixed data. Lalaktawan nito ang rows na encrypted na.
            </div>

            @using (Html.BeginForm("MigrateBiometricEncryption", "Settings", new { area = "Admin" }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger"
                        onclick="return confirm('Run one-time biometric encryption migration now?');">
                    <i class="fa-solid fa-lock me-1" aria-hidden="true"></i>Encrypt Existing Biometric Rows
                </button>
            }
        </div>
    </div>

    @* Disable TOTP Modal *@
    @if (Model.TotpEnabled)
    {
        <div class="modal fade" id="disableTotpModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Disable Two-Factor Authentication</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to disable 2FA? This will make your admin account less secure.</p>
                        <div class="mb-3">
                            <label class="form-label">Enter your PIN to confirm</label>
                            <input type="password" name="pin" class="form-control" required minlength="6" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        @using (Html.BeginForm("DisableTotp", "Settings", new { area = "Admin" }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="pin" id="modalPinInput" />
                            <button type="submit" class="btn btn-danger">Disable 2FA</button>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <script>
            document.getElementById('disableTotpModal').addEventListener('submit', function(e) {
                var form = e.target;
                var pinInput = form.querySelector('input[name="pin"]');
                var modalPinInput = document.getElementById('modalPinInput');
                modalPinInput.value = pinInput.value;
            });
        </script>
    }

    @* Anti-spoof diagnostics *@
    <div class="ea-form-card mt-4 settings-antiSpoof-card">
        <div class="ea-form-header">
            <div class="ea-form-title">
                <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                Anti-spoof Detection
            </div>
        </div>
        <div class="ea-form-body">
            <div class="small text-muted mb-3">
                Anti-spoof detection helps catch photo and screen spoofing. If scans are failing frequently,
                check biometric engine health before changing thresholds.
            </div>
            
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card bg-light">
                        <div class="card-body">
                            <h6 class="card-title">Current Settings</h6>
                            <dl class="row mb-0" style="font-size: 0.85rem;">
                                <dt class="col-6">Threshold:</dt>
                                <dd class="col-6">@Model.AntiSpoofThreshold</dd>
                                <dt class="col-6">Inference owner:</dt>
                                <dd class="col-6">In-process biometric engine</dd>
                            </dl>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="alert alert-warning" style="font-size: 0.85rem;">
                        <strong>Troubleshooting:</strong>
                        <ul class="mb-0 mt-2">
                            <li>Very low score: check model health, input crop, lighting, and spoof sample type</li>
                            <li>Gray-zone score: review pilot samples before changing thresholds</li>
                            <li>High score: expected to pass unless another guard fails</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <div class="mt-3 d-flex gap-2">
                <a href="@Url.Action("Index", "Operations", new { area = "Admin" })" class="btn btn-outline-warning btn-sm">
                    <i class="fa-solid fa-rotate-right me-1"></i>Open Operations
                </a>
                <span class="text-muted" style="font-size: 0.75rem; align-self: center;">
                    (Use if anti-spoof is stuck failing)
                </span>
            </div>
        </div>
    </div>


    </div>

</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        (function () {
            var storageKey = 'FaceAttend.Settings.ActiveTab';
            var tabs = Array.prototype.slice.call(document.querySelectorAll('.settings-tab'));
            var sections = Array.prototype.slice.call(document.querySelectorAll('.ea-settings-section'));
            var securityCards = Array.prototype.slice.call(document.querySelectorAll('.settings-security-card'));
            var antiSpoofCards = Array.prototype.slice.call(document.querySelectorAll('.settings-antiSpoof-card'));
            var hidden = document.getElementById('settingsActiveTab');
            var dirty = document.getElementById('settingsDirty');

            var map = [
                { match: 'Attendance Policy', tab: 'attendance' },
                { match: 'Review Queue', tab: 'attendance' },
                { match: 'Biometrics', tab: 'recognition' },
                { match: 'Recognition Tolerances', tab: 'recognition' },
                { match: 'Enrollment', tab: 'recognition' },
                { match: 'Advanced Anti-spoof', tab: 'antiSpoof' },
                { match: 'Location', tab: 'location' },
                { match: 'Server Capacity', tab: 'security' },
                { match: 'Performance', tab: 'security' },
                { match: 'Visitor', tab: 'visitors' }
            ];

            sections.forEach(function (section) {
                var text = (section.querySelector('.ea-settings-section-head') || section).textContent || '';
                var found = map.find(function (item) { return text.indexOf(item.match) >= 0; });
                section.setAttribute('data-settings-tab-panel', found ? found.tab : 'attendance');
            });

            function activate(tab) {
                tab = tab || 'attendance';
                tabs.forEach(function (btn) {
                    btn.classList.toggle('active', btn.getAttribute('data-settings-tab') === tab);
                });
                sections.forEach(function (section) {
                    section.hidden = section.getAttribute('data-settings-tab-panel') !== tab;
                });
                securityCards.forEach(function (card) { card.hidden = tab !== 'security'; });
                antiSpoofCards.forEach(function (card) { card.hidden = tab !== 'antiSpoof'; });
                if (hidden) hidden.value = tab;
                try { localStorage.setItem(storageKey, tab); } catch (e) {}
            }

            tabs.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    activate(btn.getAttribute('data-settings-tab'));
                });
            });

            document.querySelectorAll('.settings-form-shell input, .settings-form-shell select').forEach(function (el) {
                el.addEventListener('change', function () {
                    if (dirty) dirty.classList.add('active');
                });
            });

            var initial = 'attendance';
            try { initial = localStorage.getItem(storageKey) || initial; } catch (e) {}
            activate(initial);
        })();
    </script>
}
