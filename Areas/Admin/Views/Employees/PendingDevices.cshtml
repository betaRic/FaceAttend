@model List<FaceAttend.Device>
@{
    ViewBag.Title = "Pending Devices";
    var total = Model?.Count ?? 0;
}

<div class="ea-page">

    @* -- Page header -- *@
    <div class="ea-page-header">
        <div>
            <h1 class="ea-page-title">
                <i class="fa-solid fa-clock" aria-hidden="true"></i>
                Pending Device Registrations
            </h1>
            <div class="ea-page-subtitle">
                @total device registration@(total == 1 ? "" : "s") awaiting approval
            </div>
        </div>
        <div class="ea-page-actions">
            <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Devices", "Employees", new { area = "Admin" })">
                <i class="fa-solid fa-mobile-screen me-1" aria-hidden="true"></i>All Devices
            </a>
        </div>
    </div>

    @* -- Flash messages -- *@
    @if (TempData["Success"] != null)
    {
        <div class="ea-alert success">
            <i class="fa-solid fa-circle-check fa-sm" aria-hidden="true"></i>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="ea-alert danger">
            <i class="fa-solid fa-circle-xmark fa-sm" aria-hidden="true"></i>
            @TempData["Error"]
        </div>
    }

    @* -- Table card -- *@
    <div class="ea-table-card">
        <div class="ea-table-header">
            <div class="ea-table-title">
                <i class="fa-solid fa-list-ul text-primary" aria-hidden="true"></i>
                Pending Registrations
            </div>
            @if (total > 0)
            {
                <span class="badge bg-warning-subtle text-warning border border-warning-subtle" style="font-size:.75rem;">
                    @total pending
                </span>
            }
        </div>

        <div class="table-responsive">
            @if (Model == null || Model.Count == 0)
            {
                <div class="ea-empty">
                    <i class="fa-solid fa-clipboard-check" aria-hidden="true"></i>
                    <div class="ea-empty-title">No pending devices</div>
                    <div class="ea-empty-desc">
                        All device registrations have been processed.
                    </div>
                </div>
            }
            else
            {
                <table class="ea-table table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Device</th>
                            <th>Employee</th>
                            <th>Type</th>
                            <th>Registered</th>
                            <th>IP Address</th>
                            <th style="width:200px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var device in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold" style="font-size:.88rem;">@device.DeviceName</div>
                                    <div class="ea-cell-muted" title="@device.Fingerprint">
                                        ID: @(device.Fingerprint?.Length > 12 ? device.Fingerprint.Substring(0, 12) + "..." : device.Fingerprint)
                                    </div>
                                </td>
                                <td>
                                    <div style="font-size:.85rem;">
                                        @(device.Employee != null ? device.Employee.FirstName + " " + device.Employee.LastName : "-")
                                    </div>
                                    @if (device.Employee != null)
                                    {
                                        <div class="ea-cell-muted">@device.Employee.EmployeeId</div>
                                    }
                                </td>
                                <td>
                                    <span class="ea-badge info">@device.DeviceType</span>
                                </td>
                                <td class="ea-cell-muted" style="font-size:.82rem;white-space:nowrap;">
                                    @device.RegisteredAt.ToString("MMM dd, yyyy HH:mm")
                                </td>
                                <td>
                                    <code style="font-size:.75rem;">@device.RegisteredFromIp</code>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <form method="post" action="@Url.Action("ApproveDevice", "Employees", new { area = "Admin" })" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@device.Id" />
                                            <button type="submit" class="btn btn-sm btn-success"
                                                    data-confirm="Approve this device?"
                                                    data-confirm-text="This will allow the employee to use this device for attendance."
                                                    title="Approve">
                                                <i class="fa-solid fa-check" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                        <form method="post" action="@Url.Action("RejectDevice", "Employees", new { area = "Admin" })" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@device.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    data-confirm="Reject this device?"
                                                    data-confirm-text="This will block the employee from using this device for attendance."
                                                    title="Reject">
                                                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

</div>
