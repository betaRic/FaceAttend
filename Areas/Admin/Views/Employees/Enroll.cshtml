@model Employee
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Enroll Face - " + Model.LastName + ", " + Model.FirstName;

    var fullName = Model.LastName + ", " + Model.FirstName
                  + (string.IsNullOrWhiteSpace(Model.MiddleName) ? "" : " " + Model.MiddleName);
}

@section styles{
    @Styles.Render("~/Content/enrollment")
}

<div class="fa-enroll-page">
    <div class="container-xl" style="max-width: 1000px;">

        @* Header *@
        <div class="d-flex align-items-center gap-3 mb-4">
            <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Employees", new { area = "Admin" })">
                <i class="fa-solid fa-arrow-left me-2"></i>Back
            </a>
            <div>
                <h2 class="mb-0 fw-bold">Enroll Face</h2>
                <p class="text-muted mb-0">@fullName <span class="badge bg-secondary ms-2">@Model.EmployeeId</span></p>
            </div>
        </div>

        @* Wizard Steps *@
        <div class="enroll-wizard-steps mb-4" id="wizardSteps">
            <div class="enroll-wizard-step is-active" data-step="1">
                <span class="enroll-wizard-step__num">1</span>
                <span>Method</span>
            </div>
            <div class="enroll-wizard-step__line"></div>
            <div class="enroll-wizard-step" data-step="2">
                <span class="enroll-wizard-step__num">2</span>
                <span>Capture</span>
            </div>
            <div class="enroll-wizard-step__line"></div>
            <div class="enroll-wizard-step" data-step="3">
                <span class="enroll-wizard-step__num">3</span>
                <span>Done</span>
            </div>
        </div>

        @* Main Content *@
        <div class="card shadow-sm">
            <div class="card-body p-4">

                @* Hidden CSRF *@
                @using (Html.BeginForm("", "", FormMethod.Post, new { id = "hiddenForm", @class = "d-none" }))
                {
                    @Html.AntiForgeryToken()
                }

                @* Method Selection Pane *@
                <div id="methodPane">
                    <h4 class="text-center mb-4">Select Enrollment Method</h4>
                    
                    <div class="fa-method-grid">
                        @* Live Camera *@
                        <div class="fa-method-card" onclick="showLive()">
                            <span class="fa-method__badge">Recommended</span>
                            <div class="fa-method__icon">
                                <i class="fa-solid fa-camera"></i>
                            </div>
                            <h5 class="fa-method__title">Live Camera</h5>
                            <p class="fa-method__desc">Real-time face capture with automatic liveness detection</p>
                        </div>

                        @* Upload Photos *@
                        <div class="fa-method-card" onclick="showUpload()">
                            <div class="fa-method__icon">
                                <i class="fa-solid fa-cloud-arrow-up"></i>
                            </div>
                            <h5 class="fa-method__title">Upload Photos</h5>
                            <p class="fa-method__desc">Upload 1-5 clear photos for quick enrollment</p>
                        </div>
                    </div>
                </div>

                @* Live Camera Pane *@
                <div id="livePane" class="enroll-hidden">
                    <button class="btn btn-outline-secondary mb-3" onclick="showMethod()">
                        <i class="fa-solid fa-chevron-left me-2"></i>Back
                    </button>

                    <div class="row g-4">
                        @* Camera Column *@
                        <div class="col-lg-8">
                            <div class="enroll-camera-wrap">
                                <video id="enrollVideo" class="enroll-video" autoplay playsinline muted></video>
                                
                                @* Face Guide *@
                                <div class="enroll-face-guide" id="faceGuide">
                                    <div class="enroll-face-guide__corner enroll-face-guide__corner--tl"></div>
                                    <div class="enroll-face-guide__corner enroll-face-guide__corner--tr"></div>
                                    <div class="enroll-face-guide__corner enroll-face-guide__corner--bl"></div>
                                    <div class="enroll-face-guide__corner enroll-face-guide__corner--br"></div>
                                </div>

                                @* Status Badge *@
                                <div class="enroll-camera-status">
                                    <span class="enroll-camera-status__dot"></span>
                                    <span id="cameraStatusText">Camera Active</span>
                                </div>
                            </div>
                        </div>

                        @* Stats Column *@
                        <div class="col-lg-4">
                            <div class="enroll-stats-panel">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="fw-semibold"><i class="fa-solid fa-bullseye me-2 text-primary"></i>Progress</span>
                                    <span class="fs-4 fw-bold text-primary"><span id="captureCount">0</span><small class="text-muted fs-6">/5</small></span>
                                </div>

                                @* Progress Bar *@
                                <div class="progress mb-3" style="height: 8px;">
                                    <div class="progress-bar" id="captureProgress" style="width: 0%"></div>
                                </div>

                                @* Angles Grid *@
                                <div class="enroll-angles-grid">
                                    <div class="enroll-angle-item" data-angle="center">
                                        <i class="fa-solid fa-circle-dot"></i>
                                        <span>Center</span>
                                    </div>
                                    <div class="enroll-angle-item" data-angle="left">
                                        <i class="fa-solid fa-arrow-left"></i>
                                        <span>Left</span>
                                    </div>
                                    <div class="enroll-angle-item" data-angle="right">
                                        <i class="fa-solid fa-arrow-right"></i>
                                        <span>Right</span>
                                    </div>
                                    <div class="enroll-angle-item" data-angle="up">
                                        <i class="fa-solid fa-arrow-up"></i>
                                        <span>Up</span>
                                    </div>
                                    <div class="enroll-angle-item" data-angle="down">
                                        <i class="fa-solid fa-arrow-down"></i>
                                        <span>Down</span>
                                    </div>
                                </div>

                                @* Liveness *@
                                <div class="enroll-liveness-mini">
                                    <div class="d-flex justify-content-between mb-1">
                                        <small class="fw-semibold">Liveness</small>
                                        <small id="livenessText">0%</small>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar bg-warning" id="livenessBar" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>

                            @* Action Buttons *@
                            <div class="d-grid gap-2 mt-3">
                                <button class="btn btn-success" id="saveBtn" onclick="saveEnrollment()" disabled>
                                    <i class="fa-solid fa-check me-2"></i>Save Enrollment
                                </button>
                                <button class="btn btn-outline-secondary" onclick="retake()">
                                    <i class="fa-solid fa-rotate-left me-2"></i>Retake
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                @* Upload Pane *@
                <div id="uploadPane" class="enroll-hidden">
                    <button class="btn btn-outline-secondary mb-3" onclick="showMethod()">
                        <i class="fa-solid fa-chevron-left me-2"></i>Back
                    </button>

                    @* Dropzone *@
                    <div class="enroll-dropzone" id="dropzone">
                        <input type="file" id="fileInput" multiple accept="image/*" class="d-none">
                        <div class="enroll-dropzone__icon">
                            <i class="fa-solid fa-cloud-arrow-up"></i>
                        </div>
                        <h5>Drop photos here or click to browse</h5>
                        <p class="text-muted mb-2">Upload 1 to 5 clear, well-lit face photos</p>
                        <span class="badge bg-light text-dark border">
                            <i class="fa-solid fa-file-image me-1"></i>JPG, PNG up to 10MB
                        </span>
                    </div>

                    @* File Grid *@
                    <div class="enroll-file-grid" id="fileGrid"></div>

                    @* Upload Button *@
                    <div class="text-center mt-4">
                        <button class="btn btn-primary btn-lg" id="uploadBtn" onclick="processUpload()" disabled>
                            <i class="fa-solid fa-upload me-2"></i>Upload & Enroll
                        </button>
                    </div>
                </div>

                @* Success Pane *@
                <div id="successPane" class="enroll-hidden text-center py-5">
                    <div class="enroll-success-icon mb-3">
                        <i class="fa-solid fa-check"></i>
                    </div>
                    <h3 class="fw-bold mb-2">Enrollment Complete!</h3>
                    <p class="text-muted mb-4">Face biometric successfully enrolled for <strong>@fullName</strong></p>
                    <div class="d-flex justify-content-center gap-2">
                        <a href="@Url.Action("Index", "Employees", new { area = "Admin" })" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-arrow-left me-2"></i>Back to List
                        </a>
                        <a href="@Url.Action("Edit", "Employees", new { area = "Admin", id = Model.Id })" class="btn btn-primary">
                            <i class="fa-solid fa-pen me-2"></i>Edit Employee
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section scripts{
    @Scripts.Render("~/bundles/facescan-core")
    @Scripts.Render("~/bundles/enrollment")

    <script>
    (function() {
        'use strict';

        var capturedFrames = [];
        var selectedFiles = [];
        var minFrames = 5;

        // Navigation
        window.showMethod = function() {
            document.getElementById('methodPane').classList.remove('enroll-hidden');
            document.getElementById('livePane').classList.add('enroll-hidden');
            document.getElementById('uploadPane').classList.add('enroll-hidden');
            document.getElementById('successPane').classList.add('enroll-hidden');
            updateWizard(1);
            stopCamera();
        };

        window.showLive = function() {
            document.getElementById('methodPane').classList.add('enroll-hidden');
            document.getElementById('livePane').classList.remove('enroll-hidden');
            document.getElementById('uploadPane').classList.add('enroll-hidden');
            document.getElementById('successPane').classList.add('enroll-hidden');
            updateWizard(2);
            startCamera();
        };

        window.showUpload = function() {
            document.getElementById('methodPane').classList.add('enroll-hidden');
            document.getElementById('livePane').classList.add('enroll-hidden');
            document.getElementById('uploadPane').classList.remove('enroll-hidden');
            document.getElementById('successPane').classList.add('enroll-hidden');
            updateWizard(2);
        };

        function showSuccess() {
            document.getElementById('methodPane').classList.add('enroll-hidden');
            document.getElementById('livePane').classList.add('enroll-hidden');
            document.getElementById('uploadPane').classList.add('enroll-hidden');
            document.getElementById('successPane').classList.remove('enroll-hidden');
            updateWizard(3);
        }

        function updateWizard(step) {
            document.querySelectorAll('.enroll-wizard-step').forEach(function(el, idx) {
                var stepNum = idx + 1;
                el.classList.remove('is-active', 'is-complete');
                if (stepNum === step) {
                    el.classList.add('is-active');
                } else if (stepNum < step) {
                    el.classList.add('is-complete');
                    el.querySelector('.enroll-wizard-step__num').innerHTML = '<i class="fa-solid fa-check"></i>';
                } else {
                    el.querySelector('.enroll-wizard-step__num').textContent = stepNum;
                }
            });
        }

        // FIX-004: Real enrollment pipeline
        if (typeof FaceAttend === 'undefined' || typeof FaceAttend.Enrollment === 'undefined') {
            console.error('[Employees/Enroll] FaceAttend.Enrollment not available.');
        }

        var liveEnrollment = (typeof FaceAttend !== 'undefined' && FaceAttend.Enrollment)
            ? FaceAttend.Enrollment.create({
                empId:             '@Model.EmployeeId',
                scanUrl:           '@Url.Content("~/api/scan/frame")',
                enrollUrl:         '@Url.Content("~/api/enrollment/enroll")',
                redirectUrl:       '',
                minGoodFrames:     minFrames,
                maxKeepFrames:     8,
                perFrameThreshold: 0.75,
                enablePreview:     false
              })
            : null;

        function updateLiveCaptureUI(frameCount, target) {
            var countEl = document.getElementById('captureCount');
            if (countEl) countEl.textContent = frameCount;

            var progressEl = document.getElementById('captureProgress');
            if (progressEl) {
                progressEl.style.width = Math.round((frameCount / (target || minFrames)) * 100) + '%';
            }

            var saveBtn = document.getElementById('saveBtn');
            if (saveBtn) saveBtn.disabled = frameCount < minFrames;

            var faceGuide = document.getElementById('faceGuide');
            if (faceGuide) {
                faceGuide.classList.toggle('enroll-face-guide--good', frameCount >= minFrames);
            }
        }

        function updateLiveAngleDots(goodFrames) {
            var captured = {};
            if (goodFrames) {
                for (var i = 0; i < goodFrames.length; i++) {
                    var b = goodFrames[i].poseBucket;
                    if (b && b !== 'other') captured[b] = true;
                }
            }
            ['center', 'left', 'right', 'up', 'down'].forEach(function(angle) {
                var item = document.querySelector('[data-angle="' + angle + '"]');
                if (item) item.classList.toggle('is-captured', !!captured[angle]);
            });
        }

        if (liveEnrollment) {
            liveEnrollment.callbacks.onStatus = function(msg, kind) {
                var el = document.getElementById('cameraStatusText');
                if (el) el.textContent = msg || '';
            };

            liveEnrollment.callbacks.onLivenessUpdate = function(pct, kind) {
                var bar = document.getElementById('livenessBar');
                if (bar) bar.style.width = pct + '%';
                var txt = document.getElementById('livenessText');
                if (txt) txt.textContent = pct + '%';
            };

            liveEnrollment.callbacks.onCaptureProgress = function(current, target) {
                capturedFrames = liveEnrollment.goodFrames.slice();
                updateLiveCaptureUI(current, target);
                updateLiveAngleDots(liveEnrollment.goodFrames);
            };

            liveEnrollment.callbacks.onAngleUpdate = function(next) {
                if (!next || next.bucket === 'other') return;
                var el = document.getElementById('cameraStatusText');
                if (el && next.prompt) el.textContent = next.prompt;
            };

            liveEnrollment.callbacks.onReadyToConfirm = function(data) {
                // Show confirmation dialog
                var thumbPromises = data.frames.slice(0, 3).map(function(frame) {
                    return new Promise(function(resolve) {
                        if (!frame || !frame.blob) { resolve(null); return; }
                        var reader = new FileReader();
                        reader.onload = function(e) { resolve(e.target.result); };
                        reader.onerror = function() { resolve(null); };
                        reader.readAsDataURL(frame.blob);
                    });
                });

                Promise.all(thumbPromises).then(function(dataUrls) {
                    var thumbHtml = '';
                    dataUrls.forEach(function(url) {
                        if (url) {
                            thumbHtml += '<img src="' + url + '" style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:2px solid rgba(255,255,255,0.15);flex-shrink:0;" />';
                        }
                    });

                    var angleStatusHtml = data.allAngles
                        ? '<span style="color:#22c55e;"><i class="fa-solid fa-circle-check" style="margin-right:6px;"></i>All 5 angles captured</span>'
                        : '<span style="color:#f59e0b;"><i class="fa-solid fa-triangle-exclamation" style="margin-right:6px;"></i>' + data.angleCount + ' / 5 angles captured</span>';

                    var summaryHtml =
                        '<div style="display:flex;justify-content:center;gap:8px;margin-bottom:14px;flex-wrap:wrap;">' + thumbHtml + '</div>' +
                        '<div style="background:rgba(255,255,255,0.05);border-radius:10px;padding:12px 16px;text-align:left;font-size:0.875rem;line-height:2;">' +
                            '<div><i class="fa-solid fa-layer-group" style="margin-right:8px;color:#3b82f6;"></i><strong>' + data.frameCount + '</strong> frames captured</div>' +
                            '<div>' + angleStatusHtml + '</div>' +
                            '<div><i class="fa-solid fa-shield-heart" style="margin-right:8px;color:#22c55e;"></i>Best liveness: <strong>' + data.bestLiveness + '%</strong></div>' +
                        '</div>';

                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            title: 'Ready to Enroll',
                            html: summaryHtml,
                            icon: 'success',
                            showCancelButton: true,
                            confirmButtonText: '<i class="fa-solid fa-check" style="margin-right:6px;"></i>Confirm Enrollment',
                            cancelButtonText: '<i class="fa-solid fa-rotate-left" style="margin-right:6px;"></i>Retake',
                            confirmButtonColor: '#22c55e',
                            cancelButtonColor: '#475569',
                            background: '#0f172a',
                            color: '#f8fafc',
                            allowOutsideClick: false,
                            allowEscapeKey: false
                        }).then(function(result) {
                            if (result.isConfirmed) {
                                var saveBtn = document.getElementById('saveBtn');
                                if (saveBtn) {
                                    saveBtn.disabled = true;
                                    saveBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin me-2"></i>Saving...';
                                }
                                liveEnrollment.performEnrollment();
                            } else {
                                liveEnrollment.startAutoEnrollment();
                                updateLiveCaptureUI(0, minFrames);
                                updateLiveAngleDots([]);
                                var saveBtn = document.getElementById('saveBtn');
                                if (saveBtn) {
                                    saveBtn.disabled = true;
                                    saveBtn.innerHTML = '<i class="fa-solid fa-check me-2"></i>Save Enrollment';
                                }
                                var faceGuide = document.getElementById('faceGuide');
                                if (faceGuide) faceGuide.classList.remove('enroll-face-guide--good');
                            }
                        });
                    }
                });
            };

            liveEnrollment.callbacks.onEnrollmentComplete = function(vecCount) {
                showSuccess();
            };

            liveEnrollment.callbacks.onEnrollmentError = function(result) {
                var saveBtn = document.getElementById('saveBtn');
                if (saveBtn) {
                    saveBtn.disabled = false;
                    saveBtn.innerHTML = '<i class="fa-solid fa-check me-2"></i>Save Enrollment';
                }

                var msg = typeof liveEnrollment.describeEnrollError === 'function'
                    ? liveEnrollment.describeEnrollError(result)
                    : ((result && (result.message || result.error)) || 'Enrollment failed.');

                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: 'Enrollment Failed',
                        html: '<div style="font-size:.9rem;text-align:left;">' + msg + '</div>',
                        confirmButtonText: 'Try Again',
                        confirmButtonColor: '#ef4444',
                        background: '#0f172a',
                        color: '#f8fafc'
                    });
                }
            };
        }

        function startCamera() {
            if (!liveEnrollment) {
                console.error('[Employees/Enroll] liveEnrollment not initialized.');
                return;
            }
            var videoEl = document.getElementById('enrollVideo');
            if (!videoEl) {
                console.error('[Employees/Enroll] video element not found.');
                return;
            }

            updateLiveCaptureUI(0, minFrames);
            updateLiveAngleDots([]);
            capturedFrames = [];

            var cameraStatus = document.getElementById('cameraStatusText');

            liveEnrollment.startCamera(videoEl)
                .then(function() {
                    if (cameraStatus) cameraStatus.textContent = 'Camera active - look straight ahead';
                    liveEnrollment.startAutoEnrollment();
                })
                .catch(function(e) {
                    var msg = (e && e.message) || 'Could not access camera.';
                    if (cameraStatus) cameraStatus.textContent = 'Camera error: ' + msg;
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: 'Camera Error',
                            text: msg,
                            background: '#0f172a',
                            color: '#f8fafc'
                        });
                    }
                });
        }

        function stopCamera() {
            if (liveEnrollment) {
                liveEnrollment.stopCamera();
            }
            capturedFrames = [];
        }

        window.retake = function() {
            if (!liveEnrollment) return;
            liveEnrollment.startAutoEnrollment();
            updateLiveCaptureUI(0, minFrames);
            updateLiveAngleDots([]);
            capturedFrames = [];
            var faceGuide = document.getElementById('faceGuide');
            if (faceGuide) faceGuide.classList.remove('enroll-face-guide--good');
            var saveBtn = document.getElementById('saveBtn');
            if (saveBtn) {
                saveBtn.disabled = true;
                saveBtn.innerHTML = '<i class="fa-solid fa-check me-2"></i>Save Enrollment';
            }
        };

        window.saveEnrollment = function() {
            if (!liveEnrollment) return;
            if (!liveEnrollment.goodFrames || liveEnrollment.goodFrames.length < minFrames) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Not Ready',
                        text: 'Please wait for at least ' + minFrames + ' frames to be captured.',
                        background: '#0f172a',
                        color: '#f8fafc'
                    });
                }
                return;
            }
            liveEnrollment.stopAutoEnrollment();
            liveEnrollment._fireReadyToConfirm();
        };

        window.addEventListener('beforeunload', stopCamera);

        // Upload handlers
        var dropzone = document.getElementById('dropzone');
        var fileInput = document.getElementById('fileInput');

        if (dropzone) {
            dropzone.addEventListener('click', function() { fileInput.click(); });
            dropzone.addEventListener('dragover', function(e) { 
                e.preventDefault(); 
                this.classList.add('is-dragover'); 
            });
            dropzone.addEventListener('dragleave', function() { 
                this.classList.remove('is-dragover'); 
            });
            dropzone.addEventListener('drop', function(e) {
                e.preventDefault();
                this.classList.remove('is-dragover');
                handleFiles(e.dataTransfer.files);
            });
        }

        if (fileInput) {
            fileInput.addEventListener('change', function() { handleFiles(this.files); });
        }

        function handleFiles(files) {
            Array.from(files).forEach(function(file) {
                if (selectedFiles.length >= 5) return;
                if (!file.type.startsWith('image/')) return;
                selectedFiles.push(file);
                addFileCard(file);
            });
            var uploadBtn = document.getElementById('uploadBtn');
            if (uploadBtn) uploadBtn.disabled = selectedFiles.length === 0;
        }

        function addFileCard(file) {
            var index = selectedFiles.length - 1;
            var card = document.createElement('div');
            card.className = 'enroll-file-card';
            card.innerHTML = 
                '<div class="enroll-file-card__thumb">' +
                    '<img id="preview-' + index + '">' +
                '</div>' +
                '<div class="enroll-file-card__info">' +
                    '<div class="enroll-file-card__name">' + file.name + '</div>' +
                    '<div class="enroll-file-card__size">' + formatSize(file.size) + '</div>' +
                '</div>' +
                '<button type="button" class="enroll-file-card__remove" onclick="removeFile(' + index + ')">' +
                    '<i class="fa-solid fa-times"></i>' +
                '</button>';
            var fileGrid = document.getElementById('fileGrid');
            if (fileGrid) fileGrid.appendChild(card);

            var reader = new FileReader();
            reader.onload = function(e) { 
                var preview = document.getElementById('preview-' + index);
                if (preview) preview.src = e.target.result; 
            };
            reader.readAsDataURL(file);
        }

        window.removeFile = function(index) {
            selectedFiles.splice(index, 1);
            renderFiles();
            var uploadBtn = document.getElementById('uploadBtn');
            if (uploadBtn) uploadBtn.disabled = selectedFiles.length === 0;
        };

        function renderFiles() {
            var fileGrid = document.getElementById('fileGrid');
            if (fileGrid) fileGrid.innerHTML = '';
            selectedFiles.forEach(function(file) { addFileCard(file); });
        }

        function formatSize(bytes) {
            if (bytes === 0) return '0 B';
            var k = 1024;
            var sizes = ['B', 'KB', 'MB'];
            var i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
        }

        window.processUpload = function() {
            var btn = document.getElementById('uploadBtn');
            if (!selectedFiles || selectedFiles.length === 0) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'warning',
                        title: 'No Files Selected',
                        text: 'Please select at least one photo before uploading.',
                        confirmButtonColor: '#3b82f6'
                    });
                }
                return;
            }

            if (typeof FaceAttend === 'undefined' || typeof FaceAttend.Enrollment === 'undefined') {
                console.error('[processUpload] FaceAttend.Enrollment not available.');
                return;
            }

            var originalBtnHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin me-2"></i>Uploading...';

            var uploadEnrollment = FaceAttend.Enrollment.create({
                empId: '@Model.EmployeeId',
                enrollUrl: '/api/enrollment/enroll',
                enablePreview: false
            });

            uploadEnrollment.callbacks.onEnrollmentComplete = function(vecCount) {
                btn.disabled = false;
                btn.innerHTML = originalBtnHtml;
                showSuccess();
            };

            uploadEnrollment.callbacks.onEnrollmentError = function(result) {
                btn.disabled = false;
                btn.innerHTML = originalBtnHtml;

                var msg = typeof uploadEnrollment.describeEnrollError === 'function'
                    ? uploadEnrollment.describeEnrollError(result)
                    : ((result && (result.message || result.error)) || 'Upload failed.');

                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: 'Enrollment Failed',
                        html: msg,
                        confirmButtonText: 'Try Again',
                        confirmButtonColor: '#ef4444'
                    });
                }
            };

            uploadEnrollment.enrollFromFiles(selectedFiles, { maxImages: 5 })
                .catch(function(e) {
                    btn.disabled = false;
                    btn.innerHTML = originalBtnHtml;

                    var errorMsg = e && e.message ? e.message : 'Upload failed.';
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: 'Upload Error',
                            html: errorMsg,
                            confirmButtonText: 'OK',
                            confirmButtonColor: '#ef4444'
                        });
                    }
                });
        };
    })();
    </script>
}
