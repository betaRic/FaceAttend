@model Employee

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Enroll Face" + Model.LastName + ", " + Model.FirstName;


    var fullName = Model.LastName + ", " + Model.FirstName
                  + (string.IsNullOrWhiteSpace(Model.MiddleName) ? "" : " " + Model.MiddleName);
    var perFrame = ViewBag.PerFrameMs ?? 700;
}

@section styles{
    <link rel="stylesheet" href="@Url.Content("~/Content/enrollment.css")" />
    <style>
        /* Page-specific wizard styles (not part of enrollment component) */
        .fa-enroll-page { padding: 1.25rem 0; }
        .fa-enroll-header { margin-bottom: 1rem; }
        .fa-stepbar {
            display: flex; align-items: center; justify-content: center;
            gap: .5rem; margin-bottom: 1.25rem;
        }
        .fa-step {
            display: flex; align-items: center; gap: .4rem;
            padding: .45rem .7rem; border-radius: 999px;
            background: #f1f5f9; color: #64748b; font-size: .85rem;
            transition: all .2s ease;
        }
        .fa-step.active { background: #0d6efd; color: #fff; box-shadow: 0 6px 20px rgba(13,110,253,.25); }
        .fa-step.done { background: #198754; color: #fff; }
        .fa-step-num {
            width: 22px; height: 22px; border-radius: 50%;
            background: rgba(0,0,0,.15); display: grid; place-items: center;
            font-size: .72rem; font-weight: 700;
        }
        .fa-step-divider { width: 32px; height: 2px; background: #e2e8f0; border-radius: 2px; }
        .fa-step-divider.done { background: #198754; }
        
        /* Method selection cards */
        .fa-method-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem; max-width: 720px; margin: 0 auto;
        }
        .fa-method-card {
            position: relative; border: 2px solid #e2e8f0; border-radius: 16px;
            padding: 1.25rem; text-align: center; cursor: pointer;
            transition: all .2s ease; background: #fff;
        }
        .fa-method-card:hover { border-color: #94a3b8; transform: translateY(-2px); box-shadow: 0 10px 25px rgba(0,0,0,.06); }
        .fa-method-card:focus-visible { outline: 3px solid #0d6efd; outline-offset: 2px; }
        .fa-method-icon { width: 56px; height: 56px; border-radius: 14px; background: linear-gradient(135deg, #f8fafc, #e2e8f0); color: #0d6efd; display: grid; place-items: center; font-size: 1.5rem; margin: 0 auto .75rem; }
        .fa-method-title { font-weight: 700; margin-bottom: .35rem; }
        .fa-method-desc { font-size: .82rem; color: #64748b; line-height: 1.35; }
        .fa-method-rec { position: absolute; top: 10px; right: 10px; background: #0d6efd; color: #fff; font-size: .65rem; font-weight: 600; padding: .2rem .5rem; border-radius: 999px; display: flex; align-items: center; }
        
        /* Success overlay */
        .fa-success-overlay {
            position: fixed; inset: 0; background: rgba(255,255,255,.95);
            display: grid; place-items: center; z-index: 9999;
            animation: fadeIn .3s ease;
        }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .fa-success-content { text-align: center; padding: 2rem; }
        .fa-success-icon { font-size: 5rem; color: #198754; margin-bottom: 1rem; animation: scaleIn .4s ease; }
        @@keyframes scaleIn { from { transform: scale(.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .fa-success-title { font-size: 1.75rem; font-weight: 700; margin-bottom: .5rem; }
        .fa-success-message { color: #64748b; margin-bottom: 1.5rem; }
        .fa-success-details { background: #f8fafc; border-radius: 12px; padding: 1rem; margin-bottom: 1.5rem; font-size: .9rem; color: #475569; }
        .fa-success-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
        
        /* Upload pane styles */
        .fa-dropzone {
            border: 2px dashed #cbd5e1; border-radius: 16px;
            padding: 2rem; text-align: center; cursor: pointer;
            transition: all .2s ease;
        }
        .fa-dropzone:hover, .fa-dropzone.drag-over { border-color: #0d6efd; background: #f8fafc; }
        .fa-dropzone-icon { font-size: 3rem; color: #94a3b8; margin-bottom: 1rem; }
        .fa-dropzone-title { font-weight: 600; margin-bottom: .5rem; }
        .fa-dropzone-desc { color: #64748b; font-size: .9rem; margin-bottom: 1rem; }
        .fa-dropzone-rules { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; font-size: .78rem; color: #94a3b8; }
        .fa-dropzone-rules span { display: flex; align-items: center; gap: .35rem; }
        .fa-file-strip { display: flex; gap: .5rem; flex-wrap: wrap; margin-top: 1rem; }
        .fa-file-chip { background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 8px; padding: .4rem .7rem; font-size: .85rem; display: flex; align-items: center; gap: .4rem; }
        
        /* Pane visibility */
        .fa-pane { display: none; }
        .fa-pane.active { display: block; animation: slideIn .25s ease; }
        @@keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .fa-back-btn { background: #f1f5f9; border: none; border-radius: 8px; padding: .5rem 1rem; font-size: .85rem; color: #475569; cursor: pointer; transition: all .2s ease; }
        .fa-back-btn:hover { background: #e2e8f0; }
        
        /* Processing modal */
        .fa-processing-modal {
            position: fixed; inset: 0; background: rgba(255,255,255,.95);
            display: grid; place-items: center; z-index: 10000;
        }
        .fa-processing-content { text-align: center; padding: 2rem; max-width: 400px; }
        .fa-processing-spinner { font-size: 3rem; color: #0d6efd; margin-bottom: 1rem; }
        .fa-processing-title { font-size: 1.25rem; font-weight: 600; margin-bottom: .5rem; }
        .fa-processing-status { color: #64748b; margin-bottom: 1rem; }
        .fa-processing-progress { height: 6px; background: #e2e8f0; border-radius: 3px; overflow: hidden; margin-bottom: .5rem; }
        .fa-processing-bar { height: 100%; background: linear-gradient(90deg, #0d6efd, #0dcaf0); width: 0; transition: width .3s ease; }
    </style>
}

<div class="fa-enroll-page">
    <div class="container-xl">
    
        @* Header *@
        <div class="fa-enroll-header">
            <div class="d-flex align-items-center gap-3 mb-2">
                <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Index", "Employees", new { area = "Admin" })">
                    <i class="fa-solid fa-arrow-left me-1"></i> Back
                </a>
                <h2 class="mb-0" style="font-weight:700;">
                    <i class="fa-solid fa-id-card me-2 text-primary"></i>Enroll Face
                </h2>
            </div>
            <p class="text-muted mb-0">
                Employee: <strong>@fullName</strong> <span class="text-secondary">|</span> 
                ID: <code>@Model.EmployeeId</code>
            </p>
        </div>

        @* Step indicator *@
        <div class="fa-stepbar" id="stepBar">
            <div class="fa-step active" data-step="1">
                <span class="fa-step-num">1</span>
                <span>Method</span>
            </div>
            <div class="fa-step-divider" id="divider1"></div>
            <div class="fa-step" data-step="2">
                <span class="fa-step-num">2</span>
                <span>Capture</span>
            </div>
            <div class="fa-step-divider" id="divider2"></div>
            <div class="fa-step" data-step="3">
                <span class="fa-step-num"><i class="fa-solid fa-check fa-xs"></i></span>
                <span>Done</span>
            </div>
        </div>

        @* Main Card *@
        <div class="card shadow-sm">
            <div class="card-body p-4">
                
                @* Hidden CSRF token for JS *@
                @using (Html.BeginForm("", "", FormMethod.Post, new { id = "hiddenForm", @class = "d-none" }))
                { @Html.AntiForgeryToken() }

                <div id="enrollContainer">
                    
                    @* Wizard: choose method *@
                    <div id="enrollWizard">
                        <div class="text-center mb-4">
                            <div class="fw-bold fs-5 mb-1">Select Enrollment Method</div>
                            <div class="text-muted" style="font-size:.86rem;">
                                Choose how to capture the face biometric for this employee.
                            </div>
                        </div>

                        <div class="fa-method-grid">
                            @* Camera card *@
                            <div class="fa-method-card" role="button" tabindex="0" data-enroll-mode="live">
                                <div class="fa-method-icon">
                                    <i class="fa-solid fa-camera"></i>
                                </div>
                                <div class="fa-method-title">Live Camera</div>
                                <div class="fa-method-desc">
                                    Real-time face capture with automatic liveness detection.
                                </div>
                                <span class="fa-method-rec">
                                    <i class="fa-solid fa-star fa-xs me-1"></i>Recommended
                                </span>
                            </div>

                            @* Upload card *@
                            <div class="fa-method-card" role="button" tabindex="0" data-enroll-mode="upload">
                                <div class="fa-method-icon">
                                    <i class="fa-solid fa-cloud-arrow-up"></i>
                                </div>
                                <div class="fa-method-title">Upload Photos</div>
                                <div class="fa-method-desc">
                                    Choose 1-5 clear existing photos. Auto-verified and enrolled.
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Live camera pane - using shared enrollment component *@
                    <div id="livePane" class="fa-pane">
                        <button class="fa-back-btn mb-3" id="backFromLive" type="button">
                            <i class="fa-solid fa-chevron-left fa-xs"></i> Choose another method
                        </button>
                        
                        @Html.Partial("_EnrollmentComponent", new ViewDataDictionary {
                            ["EmployeeId"] = Model.EmployeeId,
                            ["ScanUrl"] = Url.Content("~/Biometrics/ScanFrame"),
                            ["EnrollUrl"] = Url.Content("~/Biometrics/Enroll"),
                            ["RedirectUrl"] = Url.Action("Index", "Employees", new { area = "Admin" }),
                            ["Mode"] = "admin",
                            ["MinFrames"] = 5,
                            ["MaxFrames"] = 10,
                            ["LivenessThreshold"] = 0.85f
                        })
                    </div>

                    @* Upload pane *@
                    <div id="uploadPane" class="fa-pane">
                        <button class="fa-back-btn mb-3" id="backFromUpload" type="button">
                            <i class="fa-solid fa-chevron-left fa-xs"></i> Choose another method
                        </button>

                        @using (Html.BeginForm("", "", FormMethod.Post, new { id = "uploadForm", enctype = "multipart/form-data" }))
                        {
                            @Html.AntiForgeryToken()
                            <div class="fa-dropzone" id="dropzone" role="button">
                                <input type="file" id="file" accept="image/*" multiple style="display:none;" />
                                <div class="fa-dropzone-icon">
                                    <i class="fa-solid fa-cloud-arrow-up"></i>
                                </div>
                                <div class="fa-dropzone-title">Drop photos here or click to browse</div>
                                <div class="fa-dropzone-desc">
                                    Select 1 to 5 clear, well-lit face photos.
                                </div>
                                <div class="fa-dropzone-rules">
                                    <span><i class="fa-solid fa-user-check"></i>Main face in photo</span>
                                    <span><i class="fa-solid fa-images"></i>Up to 5 files</span>
                                    <span><i class="fa-brands fa-jpg"></i>JPG / PNG</span>
                                </div>
                            </div>
                        }
                        <div class="fa-file-strip" id="fileStrip"></div>
                        <div id="upStatus" class="mt-3"></div>
                        <div class="text-center mt-3">
                            <button type="button" class="btn btn-primary" id="uploadBtn" disabled>
                                <i class="fa-solid fa-upload me-2"></i>Upload & Enroll
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@* Success Overlay *@
<div id="successOverlay" class="fa-success-overlay d-none">
    <div class="fa-success-content">
        <div class="fa-success-icon">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <div class="fa-success-title">Enrollment Complete!</div>
        <div class="fa-success-message">
            Face biometric successfully enrolled for<br/>
            <strong>@fullName</strong>
        </div>
        <div class="fa-success-details" id="successDetails"></div>
        <div class="fa-success-actions">
            <a href="@Url.Action("Index", "Employees", new { area = "Admin" })" class="btn btn-primary">
                <i class="fa-solid fa-arrow-left me-2"></i>Back to Employee List
            </a>
            <a href="@Url.Action("Edit", "Employees", new { area = "Admin", id = Model.Id })" class="btn btn-outline-secondary">
                <i class="fa-solid fa-pen me-2"></i>Edit Employee
            </a>
        </div>
    </div>
</div>

@* Processing Modal *@
<div id="processingModal" class="fa-processing-modal d-none">
    <div class="fa-processing-content">
        <div class="fa-processing-spinner">
            <i class="fa-solid fa-circle-notch fa-spin"></i>
        </div>
        <div class="fa-processing-title">Processing Enrollment...</div>
        <div class="fa-processing-status" id="processingStatus">Initializing...</div>
        <div class="fa-processing-progress">
            <div class="fa-processing-bar" id="processingBar"></div>
        </div>
        <div class="fa-processing-percent" id="processingPercent">0%</div>
    </div>
</div>

@section scripts{
    <script src="~/Scripts/modules/enrollment-core.js"></script>
    <script src="~/Scripts/enrollment-ui.js"></script>
    
    <script>
    (function() {
        'use strict';
        
        var wizard = document.getElementById('enrollWizard');
        var livePane = document.getElementById('livePane');
        var uploadPane = document.getElementById('uploadPane');
        var stepEls = document.querySelectorAll('.fa-step');
        var divider1 = document.getElementById('divider1');
        var divider2 = document.getElementById('divider2');
        var successOverlay = document.getElementById('successOverlay');
        var processingModal = document.getElementById('processingModal');
        
        // Step indicator
        function setStep(n) {
            stepEls.forEach(function(s) {
                var sn = parseInt(s.getAttribute('data-step'), 10);
                s.classList.remove('active', 'done');
                if (sn < n) s.classList.add('done');
                if (sn === n) s.classList.add('active');
            });
            if (divider1) divider1.classList.toggle('done', n > 1);
            if (divider2) divider2.classList.toggle('done', n > 2);
        }
        
        // Show/hide panes
        function showWizard() {
            wizard.style.display = 'block';
            livePane.classList.remove('active');
            uploadPane.classList.remove('active');
            setStep(1);
            
            // Stop enrollment if running
            if (window.FaceAttendEnrollment) {
                window.FaceAttendEnrollment.stop();
            }
        }
        
        function showLive() {
            wizard.style.display = 'none';
            livePane.classList.add('active');
            uploadPane.classList.remove('active');
            setStep(2);
            
            // Initialize enrollment component
            if (window.FaceAttendEnrollment) {
                window.FaceAttendEnrollment.start();
            }
        }
        
        function showUpload() {
            wizard.style.display = 'none';
            livePane.classList.remove('active');
            uploadPane.classList.add('active');
            setStep(2);
        }
        
        function showSuccess(details) {
            setStep(3);
            document.getElementById('successDetails').textContent = details || '';
            successOverlay.classList.remove('d-none');
        }
        
        function updateProcessing(percent, status) {
            document.getElementById('processingBar').style.width = percent + '%';
            document.getElementById('processingPercent').textContent = percent + '%';
            if (status) document.getElementById('processingStatus').textContent = status;
        }
        
        // Method selection
        document.querySelectorAll('.fa-method-card').forEach(function(card) {
            card.addEventListener('click', function() {
                var mode = this.getAttribute('data-enroll-mode');
                if (mode === 'live') showLive();
                else showUpload();
            });
            card.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    this.click();
                }
            });
        });
        
        // Back buttons
        document.getElementById('backFromLive').addEventListener('click', showWizard);
        document.getElementById('backFromUpload').addEventListener('click', showWizard);
        
        // Enrollment callbacks
        window.enrollCallbacks = {
            onEnrollmentComplete: function(result) {
                updateProcessing(100, 'Complete!');
                setTimeout(function() {
                    processingModal.classList.add('d-none');
                    showSuccess(result.vectorsSaved + ' face sample(s) saved');
                }, 500);
            },
            onEnrollmentError: function(error) {
                processingModal.classList.add('d-none');
                Swal.fire({
                    icon: 'error',
                    title: 'Enrollment Failed',
                    text: error.message || 'Please try again.',
                    confirmButtonColor: '#0d6efd'
                });
            },
            onStatus: function(message, type) {
                if (type === 'uploading') {
                    processingModal.classList.remove('d-none');
                    updateProcessing(25, message);
                } else if (type === 'saving') {
                    processingModal.classList.remove('d-none');
                    updateProcessing(75, message);
                }
            }
        };
        
        // File upload handling
        var dropzone = document.getElementById('dropzone');
        var fileInput = document.getElementById('file');
        var fileStrip = document.getElementById('fileStrip');
        var uploadBtn = document.getElementById('uploadBtn');
        
        dropzone.addEventListener('click', function() { fileInput.click(); });
        
        dropzone.addEventListener('dragover', function(e) {
            e.preventDefault();
            this.classList.add('drag-over');
        });
        
        ['dragleave', 'dragend'].forEach(function(ev) {
            dropzone.addEventListener(ev, function() { this.classList.remove('drag-over'); });
        });
        
        dropzone.addEventListener('drop', function(e) {
            e.preventDefault();
            this.classList.remove('drag-over');
            if (e.dataTransfer.files.length) {
                fileInput.files = e.dataTransfer.files;
                updateFileList();
            }
        });
        
        fileInput.addEventListener('change', updateFileList);
        
        function updateFileList() {
            fileStrip.innerHTML = '';
            var files = Array.prototype.slice.call(fileInput.files || [], 0, 5);
            files.forEach(function(f) {
                var chip = document.createElement('div');
                chip.className = 'fa-file-chip';
                chip.innerHTML = '<i class="fa-solid fa-image"></i><span>' + 
                    f.name.replace(/(.{20})..+/, '$1...') + '</span>';
                fileStrip.appendChild(chip);
            });
            uploadBtn.disabled = files.length === 0;
        }
        
        // Upload submission
        uploadBtn.addEventListener('click', function() {
            if (!fileInput.files.length) return;
            
            processingModal.classList.remove('d-none');
            updateProcessing(10, 'Uploading images...');
            
            var formData = new FormData();
            formData.append('__RequestVerificationToken', document.querySelector('#hiddenForm input[name="__RequestVerificationToken"]').value);
            formData.append('id', '@Model.EmployeeId');
            Array.prototype.forEach.call(fileInput.files, function(f) {
                formData.append('files', f);
            });
            
            fetch('@Url.Content("~/Biometrics/UploadEnroll")', {
                method: 'POST',
                body: formData
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    updateProcessing(100, 'Complete!');
                    setTimeout(function() {
                        processingModal.classList.add('d-none');
                        showSuccess(data.vectorsSaved + ' face sample(s) saved');
                    }, 500);
                } else {
                    throw new Error(data.message || 'Upload failed');
                }
            })
            .catch(function(err) {
                processingModal.classList.add('d-none');
                Swal.fire({
                    icon: 'error',
                    title: 'Upload Failed',
                    text: err.message,
                    confirmButtonColor: '#0d6efd'
                });
            });
        });
        
        // Initial state
        setStep(1);
    })();
    </script>
}
