@model FaceAttend.Models.Visitor

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Enroll Visitor Face - " + Model.Name;

    var isEnrolled = !string.IsNullOrEmpty(Model.FaceEncodingBase64);
    var initials = "";
    if (!string.IsNullOrWhiteSpace(Model.Name)) { initials += Model.Name[0]; }
    initials = initials.ToUpperInvariant();
}

@section styles{
    @Styles.Render("~/Content/facescan-v2")
    <style>
        /* Page-specific styles */
        .fa-enroll-page { padding: 1.25rem 0; }
        
        .fa-hero {
            display: flex; align-items: center; gap: 1rem;
            background: #fff; border: 1px solid #e2e8f0; border-radius: 14px;
            padding: 1rem 1.25rem; margin-bottom: 1rem;
            box-shadow: 0 1px 3px rgba(0,0,0,.04);
        }
        
        .fa-avatar {
            width: 56px; height: 56px; border-radius: 50%;
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            color: #fff; font-size: 1.25rem; font-weight: 700;
            display: grid; place-items: center; flex-shrink: 0;
        }
        
        .fa-hero-info { flex: 1; min-width: 0; }
        .fa-hero-name { font-weight: 700; font-size: 1.15rem; margin-bottom: .25rem; }
        .fa-hero-meta { display: flex; flex-wrap: wrap; gap: .75rem; font-size: .85rem; color: #64748b; }
        .fa-hero-actions { display: flex; gap: .5rem; }
        
        .fa-status-badge {
            display: inline-flex; align-items: center; gap: .35rem;
            padding: .35rem .65rem; border-radius: 999px; font-size: .78rem; font-weight: 600;
        }
        .fa-status-badge.enrolled { background: #d1fae5; color: #065f46; }
        .fa-status-badge.not-enrolled { background: #fee2e2; color: #991b1b; }

        /* Theme overrides */
        .fa-wizard__step { background: #f1f5f9; }
        .fa-method-card { background: #fff; }
        .fa-uploader__dropzone { background: #f8fafc; }
    </style>
}

<div class="fa-enroll-page">
    <div class="container-xl" style="max-width:1100px;">

        @* Hero Section *@
        <div class="fa-hero">
            <div class="fa-avatar">@initials</div>
            <div class="fa-hero-info">
                <div class="fa-hero-name">@Model.Name</div>
                <div class="fa-hero-meta">
                    <span><i class="fa-solid fa-id-badge fa-xs me-1"></i>Visitor #@Model.Id</span>
                    @if (!string.IsNullOrWhiteSpace(Model.Company))
                    {
                        <span><i class="fa-solid fa-building fa-xs me-1"></i>@Model.Company</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Phone))
                    {
                        <span><i class="fa-solid fa-phone fa-xs me-1"></i>@Model.Phone</span>
                    }
                </div>
            </div>
            <div class="fa-hero-actions">
                <span class="fa-status-badge @(isEnrolled ? "enrolled" : "not-enrolled")">
                    <i class="fa-solid @(isEnrolled ? "fa-circle-check" : "fa-circle-exclamation") fa-xs"></i>
                    @(isEnrolled ? "Enrolled" : "Not Enrolled")
                </span>
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-pen"></i>
                </a>
                <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
            </div>
        </div>

        @* Step indicator - Using Unified Component *@
        @Html.Partial("~/Views/Shared/Components/_Wizard.cshtml", new FaceAttend.ViewModels.WizardViewModel {
            Id = "visitorWizard",
            Steps = new[] { "Method", "Capture", "Done" },
            CurrentStep = 1,
            Size = WizardSize.Medium,
            Variant = WizardVariant.Default
        })

        @* Main Card *@
        <div class="card shadow-sm">
            <div class="card-body p-4">
                @using (Html.BeginForm("", "", FormMethod.Post, new { id = "hiddenForm", @class = "d-none" }))
                {@Html.AntiForgeryToken()}

                <div id="enrollContainer">

                    @* Wizard: choose method - Using Unified Component *@
                    <div id="enrollWizardPane">
                        <div class="text-center mb-4">
                            <div class="fw-bold fs-5 mb-1">Select Enrollment Method</div>
                            <div class="text-muted" style="font-size:.86rem;">Choose how to capture the face biometric for this visitor.</div>
                        </div>

                        @Html.Partial("~/Views/Shared/Components/_MethodSelector.cshtml", new FaceAttend.ViewModels.MethodSelectorViewModel {
                            Id = "visitorMethods",
                            Methods = new List<FaceAttend.ViewModels.MethodOption> {
                                new FaceAttend.ViewModels.MethodOption { 
                                    Id = "live", 
                                    Icon = "fa-camera", 
                                    Title = "Live Camera", 
                                    Description = "Real-time face capture with automatic liveness detection.",
                                    Recommended = true 
                                },
                                new FaceAttend.ViewModels.MethodOption { 
                                    Id = "upload", 
                                    Icon = "fa-cloud-arrow-up", 
                                    Title = "Upload Photos", 
                                    Description = "Choose 1-5 clear existing photos. Auto-verified and enrolled." 
                                }
                            },
                            OnSelect = "onMethodSelect"
                        })
                    </div>

                    @* Live camera pane - using shared enrollment component *@
                    <div id="livePane" class="d-none">
                        <button class="btn btn-outline-secondary btn-sm mb-3" id="backFromLive" type="button">
                            <i class="fa-solid fa-chevron-left fa-xs me-1"></i> Choose another method
                        </button>

                        @Html.Partial("~/Views/Shared/_EnrollmentComponent.cshtml", new ViewDataDictionary
                        {
                            ["EmployeeId"] = Model.Id.ToString(),
                            ["ScanUrl"] = "/api/scan/frame",           // MIGRATED: Unified API
                            ["EnrollUrl"] = "/api/enrollment/enroll",  // MIGRATED: Unified API
                            ["RedirectUrl"] = Url.Action("Index", "Visitors", new { area = "Admin" }),
                            ["Mode"] = "admin",
                            ["MinFrames"] = 3,
                            ["MaxFrames"] = 5,
                            ["LivenessThreshold"] = 0.85f
                        })
                    </div>

                    @* Upload pane - Using Unified Component *@
                    <div id="uploadPane" class="d-none">
                        <button class="btn btn-outline-secondary btn-sm mb-3" id="backFromUpload" type="button">
                            <i class="fa-solid fa-chevron-left fa-xs me-1"></i> Choose another method
                        </button>

                        @Html.Partial("~/Views/Shared/Components/_FileUploader.cshtml", new FaceAttend.ViewModels.FileUploaderViewModel {
                            Id = "visitorUploader",
                            Accept = "image/*",
                            MaxFiles = 5,
                            MaxSizeMB = 10,
                            AllowedTypes = new[] { ".jpg", ".jpeg", ".png" },
                            OnFilesSelected = "onUploadFilesSelected",
                            Title = "Drop photos here or click to browse",
                            Description = "Select 1 to 5 clear, well-lit face photos."
                        })

                        <div id="upStatus" class="mt-3"></div>
                        <div class="text-center mt-3">
                            <button type="button" class="btn btn-primary" id="uploadBtn" disabled>
                                <i class="fa-solid fa-upload me-2"></i>Upload & Enroll
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@* Processing Modal - Using Unified Component *@
@Html.Partial("~/Views/Shared/Components/_ProcessingModal.cshtml", new FaceAttend.ViewModels.ProcessingModalViewModel {
    Id = "processingModal",
    Title = "Processing Enrollment...",
    InitialStatus = "Initializing...",
    ShowProgress = true
})

@* Success Overlay *@
<div id="successOverlay" class="fa-modal fa-modal--success d-none" role="dialog" aria-modal="true">
    <div class="fa-modal__backdrop"></div>
    <div class="fa-modal__content">
        <div class="fa-modal__success-icon">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <div class="fa-modal__title">Enrollment Complete!</div>
        <div class="fa-modal__message">Face biometric successfully enrolled for<br /><strong>@Model.Name</strong></div>
        <div class="fa-modal__actions">
            <a href="@Url.Action("Index", "Visitors", new { area = "Admin" })" class="btn btn-primary">
                <i class="fa-solid fa-arrow-left me-2"></i>Back to Visitor List
            </a>
            <a href="@Url.Action("Edit", "Visitors", new { area = "Admin", id = Model.Id })" class="btn btn-outline-secondary">
                <i class="fa-solid fa-pen me-2"></i>Edit Visitor
            </a>
        </div>
    </div>
</div>

@section scripts{
    @Scripts.Render("~/bundles/facescan-core")
    @Scripts.Render("~/bundles/facescan-ui")

    <script>
    (function() {
        'use strict';

        // DOM Elements
        var wizardPane = document.getElementById('enrollWizardPane');
        var livePane = document.getElementById('livePane');
        var uploadPane = document.getElementById('uploadPane');
        var uploadBtn = document.getElementById('uploadBtn');
        var selectedUploadFiles = [];

        // Initialize Wizard
        var wizard = FaceAttend.UI.Wizard.init('visitorWizard', {
            steps: ['Method', 'Capture', 'Done'],
            allowBack: true,
            onStepChange: function(step) {
                console.log('[Wizard] Step changed to:', step);
            }
        });

        // Initialize Uploader
        var uploader = FaceAttend.UI.Uploader.init('visitorUploader', {
            maxFiles: 5,
            maxSize: 10 * 1024 * 1024,
            allowedTypes: ['image/jpeg', 'image/png', 'image/jpg'],
            onFilesSelected: function(files) {
                selectedUploadFiles = files;
                uploadBtn.disabled = files.length === 0;
            },
            onError: function(errors) {
                console.error('[Uploader] Errors:', errors);
            }
        });

        // Method selection callback
        window.onMethodSelect = function(methodId) {
            if (methodId === 'live') {
                showLive();
            } else if (methodId === 'upload') {
                showUpload();
            }
        };

        // Upload files selected callback
        window.onUploadFilesSelected = function(files) {
            selectedUploadFiles = files;
            uploadBtn.disabled = files.length === 0;
        };

        // Show/hide panes
        function showWizard() {
            wizardPane.classList.remove('d-none');
            livePane.classList.add('d-none');
            uploadPane.classList.add('d-none');
            FaceAttend.UI.Wizard.goTo('visitorWizard', 1);

            if (window.FaceAttendEnrollment) {
                window.FaceAttendEnrollment.stop();
            }
        }

        function showLive() {
            wizardPane.classList.add('d-none');
            livePane.classList.remove('d-none');
            uploadPane.classList.add('d-none');
            FaceAttend.UI.Wizard.goTo('visitorWizard', 2);

            if (window.FaceAttendEnrollment) {
                window.FaceAttendEnrollment.start();
            }
        }

        function showUpload() {
            wizardPane.classList.add('d-none');
            livePane.classList.add('d-none');
            uploadPane.classList.remove('d-none');
            FaceAttend.UI.Wizard.goTo('visitorWizard', 2);
        }

        function showSuccess(details) {
            FaceAttend.UI.Wizard.goTo('visitorWizard', 3);
            document.getElementById('successOverlay').classList.remove('d-none');
            document.getElementById('successOverlay').classList.add('is-open');
        }

        // Back buttons
        document.getElementById('backFromLive').addEventListener('click', showWizard);
        document.getElementById('backFromUpload').addEventListener('click', showWizard);

        // Enrollment callbacks
        window.enrollCallbacks = {
            onEnrollmentComplete: function(result) {
                showSuccess(result.vectorsSaved + ' face sample(s) saved');
            },
            onEnrollmentError: function(error) {
                FaceAttend.UI.Modal.alert('Enrollment Failed', error.message || 'Please try again.', 'error');
            }
        };

        // Upload submission
        uploadBtn.addEventListener('click', function() {
            if (selectedUploadFiles.length === 0) return;

            FaceAttend.UI.Modal.showProcessing('processingModal', {
                title: 'Processing Enrollment...',
                status: 'Uploading images...',
                percent: 10
            });

            var formData = new FormData();
            formData.append('__RequestVerificationToken', 
                document.querySelector('#hiddenForm input[name="__RequestVerificationToken"]').value);
            formData.append('employeeId', '@Model.Id');
            
            selectedUploadFiles.forEach(function(file) {
                formData.append('images', file);
            });

            // MIGRATED: Use unified API endpoint
            fetch('/api/enrollment/enroll', {
                method: 'POST',
                body: formData
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.ok) {
                    FaceAttend.UI.Modal.update('processingModal', {
                        percent: 100,
                        status: 'Complete!'
                    });

                    setTimeout(function() {
                        FaceAttend.UI.Modal.hide('processingModal');
                        showSuccess(data.savedVectors + ' face sample(s) saved');
                    }, 500);
                } else {
                    throw new Error(data.error || 'Upload failed');
                }
            })
            .catch(function(err) {
                FaceAttend.UI.Modal.hide('processingModal');
                FaceAttend.UI.Modal.alert('Upload Failed', err.message, 'error');
            });
        });

        // Initialize
        FaceAttend.UI.Wizard.goTo('visitorWizard', 1);
    })();
    </script>
}
