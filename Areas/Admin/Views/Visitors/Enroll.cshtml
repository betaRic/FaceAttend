@model Visitor
@{
    ViewBag.Title = "Enroll Visitor Face";
}
@{
    var perFrame = (ViewBag.PerFrame ?? "0.75").ToString();
    var isEnrolled = !string.IsNullOrEmpty(Model.FaceEncodingBase64);
    var initials = "";
    if (!string.IsNullOrWhiteSpace(Model.Name)) { initials += Model.Name[0]; }
    initials = initials.ToUpperInvariant();
}

@section head {
    @Styles.Render("~/Content/admin-enroll")
    <link rel="stylesheet" href="@Url.Content("~/Scripts/vendor/sweetalert2/sweetalert2.min.css")" />
}

<div class="fa-enroll-page">
<div class="container-xl" style="max-width:1100px;">

    <div class="fa-hero">
        <div class="fa-avatar" aria-hidden="true">@initials</div>
        <div class="fa-hero-info">
            <div class="fa-hero-name">@Model.Name</div>
            <div class="fa-hero-meta">
                <span><i class="fa-solid fa-id-badge fa-xs me-1"></i>Visitor #@Model.Id</span>
                @if (!string.IsNullOrWhiteSpace(Model.Company))
                {
                    <span><i class="fa-solid fa-building fa-xs me-1"></i>@Model.Company</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Phone))
                {
                    <span><i class="fa-solid fa-phone fa-xs me-1"></i>@Model.Phone</span>
                }
            </div>
        </div>
        <div class="fa-hero-actions">
            <span class="fa-status-badge @(isEnrolled ? "enrolled" : "not-enrolled")">
                <i class="fa-solid @(isEnrolled ? "fa-circle-check" : "fa-circle-exclamation") fa-xs"></i>
                @(isEnrolled ? "Enrolled" : "Not Enrolled")
            </span>
            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-sm btn-outline-secondary" title="Edit visitor">
                <i class="fa-solid fa-pen"></i>
            </a>
            <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary" title="Back to list">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
        </div>
    </div>

    <div class="fa-steps" id="faSteps">
        <div class="fa-step active" data-step="1">
            <span class="fa-step-num">1</span>
            <span>Choose Method</span>
        </div>
        <div class="fa-step-divider" id="divider1"></div>
        <div class="fa-step" data-step="2">
            <span class="fa-step-num">2</span>
            <span>Capture</span>
        </div>
        <div class="fa-step-divider" id="divider2"></div>
        <div class="fa-step" data-step="3">
            <span class="fa-step-num"><i class="fa-solid fa-check fa-xs"></i></span>
            <span>Done</span>
        </div>
    </div>

    <div class="fa-card">
        @using (Html.BeginForm("", "", FormMethod.Post, new { id = "hiddenForm", @class = "d-none" }))
        { @Html.AntiForgeryToken() }

        <div id="enrollRoot"
             data-employee-id="@Model.Id"
             data-per-frame="@perFrame"
             data-scan-url="@Url.Action("ScanFrame", "Visitors", new { area = "Admin" })"
             data-enroll-url="@Url.Action("EnrollWizard", "Visitors", new { area = "Admin" })"
             data-redirect-url="@Url.Action("Index", "Visitors", new { area = "Admin" })"
             data-min-good-frames="3"
             data-max-keep-frames="5">

            <div id="enrollWizard">
                <div class="text-center mb-4">
                    <div class="fw-bold fs-5 mb-1">Select Enrollment Method</div>
                    <div class="text-muted" style="font-size:.86rem;">
                        Choose how to capture the face biometric for this visitor.
                    </div>
                </div>
                <div class="fa-method-grid">
                    <div class="fa-method-card" role="button" tabindex="0" data-enroll-mode="live" aria-label="Live camera enrollment">
                        <div class="fa-method-icon"><i class="fa-solid fa-camera" aria-hidden="true"></i></div>
                        <div class="fa-method-title">Live Camera</div>
                        <div class="fa-method-desc">Real-time face capture with automatic liveness detection.</div>
                        <span class="fa-method-rec"><i class="fa-solid fa-star fa-xs me-1"></i>Recommended</span>
                    </div>
                    <div class="fa-method-card" role="button" tabindex="0" data-enroll-mode="upload" aria-label="Upload photo enrollment">
                        <div class="fa-method-icon"><i class="fa-solid fa-cloud-arrow-up" aria-hidden="true"></i></div>
                        <div class="fa-method-title">Upload Photos</div>
                        <div class="fa-method-desc">Choose 1-5 clear existing photos. Auto-verified and enrolled.</div>
                    </div>
                </div>
            </div>

            <div id="successOverlay" class="fa-success-overlay d-none">
                <div class="fa-success-content">
                    <div class="fa-success-icon"><i class="fa-solid fa-circle-check"></i></div>
                    <div class="fa-success-title">Enrollment Complete!</div>
                    <div class="fa-success-message">Face biometric successfully enrolled for<br/><strong>@Model.Name</strong></div>
                    <div class="fa-success-details" id="successDetails"></div>
                    <div class="fa-success-actions">
                        <a href="@Url.Action("Index", "Visitors", new { area = "Admin" })" class="btn btn-primary"><i class="fa-solid fa-arrow-left me-2"></i>Back to Visitor List</a>
                        <a href="@Url.Action("Edit", "Visitors", new { area = "Admin", id = Model.Id })" class="btn btn-outline-secondary"><i class="fa-solid fa-pen me-2"></i>Edit Visitor</a>
                    </div>
                </div>
            </div>

            <div id="processingModal" class="fa-processing-modal d-none">
                <div class="fa-processing-content">
                    <div class="fa-processing-spinner"><i class="fa-solid fa-circle-notch fa-spin"></i></div>
                    <div class="fa-processing-title">Processing Enrollment...</div>
                    <div class="fa-processing-status" id="processingStatus">Uploading images...</div>
                    <div class="fa-processing-progress"><div class="fa-processing-bar" id="processingBar"></div></div>
                    <div class="fa-processing-percent" id="processingPercent">0%</div>
                </div>
            </div>

            <div id="livePane" class="fa-pane">
                <button class="fa-back-btn mb-3" id="backFromLive" type="button">
                    <i class="fa-solid fa-chevron-left fa-xs"></i> Choose another method
                </button>
                <div class="fa-cam-layout">
                    <div class="fa-video-wrap" id="videoWrap" aria-label="Camera preview">
                        <div class="fa-live-bar-wrap">
                            <div class="fa-live-bar-label">
                                <span><i class="fa-solid fa-shield-halved fa-xs me-1"></i>Liveness</span>
                                <span id="liveBarPct">---</span>
                            </div>
                            <div class="fa-live-bar-track"><div class="fa-live-bar-fill" id="liveBarFill"></div></div>
                        </div>
                        <div class="fa-cam-corner tl"></div><div class="fa-cam-corner tr"></div>
                        <div class="fa-cam-corner bl"></div><div class="fa-cam-corner br"></div>
                        <video id="cam" autoplay playsinline muted></video>
                        <canvas id="enrollOverlay" class="enroll-overlay"></canvas>
                        <div class="fa-progress-dots" id="progressDots" aria-label="Capture progress">
                            <div class="fa-dot" id="dot1"></div><div class="fa-dot" id="dot2"></div>
                            <div class="fa-dot" id="dot3"></div><div class="fa-dot" id="dot4"></div>
                            <div class="fa-dot" id="dot5"></div>
                        </div>
                        <div id="camStatus"></div>
                    </div>
                    <div class="fa-side-panel">
                        <div class="fa-side-card">
                            <div class="fa-side-card-title"><i class="fa-solid fa-waveform-lines fa-xs"></i>Liveness Score</div>
                            <div class="fa-live-score-num" id="sideScore">0</div>
                            <div class="fa-live-score-label" id="sideScoreLabel">Waiting for scan</div>
                            <div class="fa-pass-indicator mt-2" id="sidePassBadge" style="display:none;">
                                <span>Result</span><span class="badge-pass" id="sideBadgeText">PASS</span>
                            </div>
                        </div>
                        <div class="fa-side-card">
                            <div class="fa-side-card-title"><i class="fa-solid fa-images fa-xs"></i>Samples Collected</div>
                            <div style="font-size:1.8rem;font-weight:800;line-height:1;" id="sideCaptures">0</div>
                            <div style="font-size:.78rem;color:var(--ea-muted);margin-top:.15rem;">minimum 3, keeps up to 5</div>
                            <div class="progress mt-2" style="height:4px;border-radius:100px;">
                                <div class="progress-bar bg-primary" id="capProgressBar" style="width:0%;transition:width .4s ease;"></div>
                            </div>
                        </div>
                        <div class="fa-side-card">
                            <div class="fa-side-card-title"><i class="fa-solid fa-circle-info fa-xs"></i>Tips</div>
                            <ul class="fa-tips">
                                <li><i class="fa-solid fa-sun fa-xs"></i>Good, even lighting</li>
                                <li><i class="fa-solid fa-user fa-xs"></i>Main face closest to camera</li>
                                <li><i class="fa-solid fa-glasses fa-xs"></i>Remove sunglasses</li>
                                <li><i class="fa-solid fa-arrows-to-dot fa-xs"></i>Face centered, fill frame</li>
                                <li><i class="fa-solid fa-person-half-dress fa-xs"></i>Look directly at camera</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div id="uploadPane" class="fa-pane">
                <button class="fa-back-btn mb-3" id="backFromUpload" type="button">
                    <i class="fa-solid fa-chevron-left fa-xs"></i> Choose another method
                </button>
                @using (Html.BeginForm("", "", FormMethod.Post, new { id = "uploadForm", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="fa-dropzone" id="dropzone" role="button" aria-label="Upload photos">
                        <input type="file" id="file" accept="image/*" multiple />
                        <div class="fa-dropzone-icon" aria-hidden="true"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                        <div class="fa-dropzone-title">Drop photos here or click to browse</div>
                        <div class="fa-dropzone-desc">Select 1 to 5 clear, well-lit face photos.</div>
                        <div class="fa-dropzone-rules">
                            <span><i class="fa-solid fa-user-check"></i>Main face in photo</span>
                            <span><i class="fa-solid fa-images"></i>Up to 5 files</span>
                            <span><i class="fa-solid fa-file-image"></i>JPG / PNG</span>
                        </div>
                    </div>
                }
                <div class="fa-file-strip" id="fileStrip"></div>
                <div id="upStatus"></div>
            </div>
            <canvas id="cap" style="display:none;"></canvas>
        </div>
    </div>

</div>
</div>

@section scripts{
@Html.Raw("<script>")
(function () {
    'use strict';
    function el(id) { return document.getElementById(id); }
    var liveBarFill = el('liveBarFill');
    var liveBarPct = el('liveBarPct');
    var sideScore = el('sideScore');
    var sideLabel = el('sideScoreLabel');
    var sideBadge = el('sidePassBadge');
    var sideBadgeTx = el('sideBadgeText');
    var dots = [el('dot1'),el('dot2'),el('dot3'),el('dot4'),el('dot5')];
    var capBar = el('capProgressBar');
    var sideCapCount = el('sideCaptures');
    var videoWrap = el('videoWrap');
    var camStatusEl = el('camStatus');
    var upStatusEl = el('upStatus');
    var dropzone = el('dropzone');
    var fileInput = el('file');
    var fileStrip = el('fileStrip');
    var divider1 = el('divider1');
    var divider2 = el('divider2');
    var stepEls = document.querySelectorAll('.fa-step');
    var rootEl = el('enrollRoot');
    var CAPTURE_TARGET = parseInt((rootEl && rootEl.getAttribute('data-min-good-frames')) || '3', 10);
    if (!isFinite(CAPTURE_TARGET) || CAPTURE_TARGET < 1) CAPTURE_TARGET = 3;

    function setStep(n) {
        stepEls.forEach(function (s) {
            var sn = parseInt(s.getAttribute('data-step'), 10);
            s.classList.remove('active', 'done');
            if (sn < n) s.classList.add('done');
            if (sn === n) s.classList.add('active');
        });
        if (divider1) divider1.classList.toggle('done', n > 1);
        if (divider2) divider2.classList.toggle('done', n > 2);
    }

    function updateLiveness(pct, kind) {
        if (liveBarFill) {
            liveBarFill.style.width = pct + '%';
            liveBarFill.className = 'fa-live-bar-fill' + (kind === 'pass' ? ' live-pass' : kind === 'warn' ? ' live-warn' : kind === 'fail' ? ' live-fail' : '');
        }
        if (liveBarPct) liveBarPct.textContent = pct + '%';
        if (sideScore) {
            sideScore.textContent = pct + '%';
            sideScore.className = 'fa-live-score-num' + (kind === 'pass' ? ' pass' : kind === 'fail' ? ' fail' : '');
        }
        if (sideBadge && sideBadgeTx && kind) {
            sideBadge.style.display = 'flex';
            sideBadgeTx.className = kind === 'pass' ? 'badge-pass' : 'badge-fail';
            sideBadgeTx.textContent = kind === 'pass' ? 'PASS' : kind === 'fail' ? 'FAIL' : 'LOW';
        }
    }

    function setCaptures(n) {
        n = Math.max(0, parseInt(n, 10) || 0);
        var progressCount = Math.min(n, CAPTURE_TARGET);
        dots.forEach(function (d, i) {
            if (!d) return;
            d.classList.remove('filled', 'active');
            if (i >= CAPTURE_TARGET) { d.style.display = 'none'; return; }
            d.style.display = '';
            if (i < progressCount) d.classList.add('filled');
            else if (i === progressCount && progressCount < CAPTURE_TARGET) d.classList.add('active');
        });
        if (capBar) capBar.style.width = ((progressCount / CAPTURE_TARGET) * 100) + '%';
        if (sideCapCount) sideCapCount.textContent = n;
    }

    function setVideoGlow(kind) {
        if (!videoWrap) return;
        videoWrap.classList.remove('border-success-glow', 'border-danger-glow', 'pulse-border');
        if (kind === 'success') videoWrap.classList.add('border-success-glow');
        else if (kind === 'danger') videoWrap.classList.add('border-danger-glow');
        else if (kind === 'scan') videoWrap.classList.add('pulse-border');
    }

    function iconFor(k) {
        if (k === 'success') return '<i class="fa-solid fa-circle-check" aria-hidden="true"></i>';
        if (k === 'danger') return '<i class="fa-solid fa-circle-xmark" aria-hidden="true"></i>';
        if (k === 'warning') return '<i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>';
        return '<span class="fa-status-spinner" aria-hidden="true"></span>';
    }

    function parseLivenessFromText(text, kind) {
        var m = text.match(/liveness[:]\s]+([0-9]+\.?[0-9]*)/i);
        if (m) {
            var val = parseFloat(m[1]);
            var pct = val <= 1 ? Math.round(val * 100) : Math.round(val);
            var lvKind = kind === 'success' ? 'pass' : kind === 'warning' ? 'warn' : 'fail';
            updateLiveness(Math.min(100, pct), lvKind);
        }
        var good = text.match(/good frames:\s*(\d+)\s*\/\s*(\d+)/i);
        if (good) setCaptures(parseInt(good[1], 10));
        var coll = text.match(/saving enrollment\s*\((\d+)\s*frame/i);
        if (coll) setCaptures(parseInt(coll[1], 10));
        if (/enrollment saved/i.test(text)) {
            setStep(3);
            setCaptures(CAPTURE_TARGET);
            setVideoGlow('success');
            if (sideLabel) sideLabel.textContent = 'Enrollment complete!';
        }
    }

    var _origDescriptor = Object.getOwnPropertyDescriptor(Element.prototype, 'innerHTML');
    var _origSet = _origDescriptor.set;

    function renderCamStatus(text, kind) {
        var k = kind || 'info';
        var extraCls = (k !== 'info') ? ' is-' + k : '';
        var safeText = text.replace(/<[^>]+>/g, '');
        if (camStatusEl) {
            _origSet.call(camStatusEl, '<div class="fa-status-msg' + extraCls + '">' + iconFor(k) + '<span>' + safeText + '</span></div>');
        }
        setVideoGlow(k === 'success' ? 'success' : k === 'danger' ? 'danger' : 'scan');
        parseLivenessFromText(safeText, k);
        if (sideLabel && !/liveness/i.test(safeText)) sideLabel.textContent = safeText.substring(0, 60);
    }

    function renderUpStatus(text, kind) {
        var k = kind || 'info';
        var safeText = text.replace(/<[^>]+>/g, '');
        if (upStatusEl) {
            _origSet.call(upStatusEl, '<div class="fa-upstatus-box is-' + k + '">' + iconFor(k) + '<span>' + safeText + '</span></div>');
        }
    }

    function patchStatusEl(target, renderFn) {
        if (!target) return;
        Object.defineProperty(target, 'innerHTML', {
            get: function () { return _origDescriptor.get.call(this); },
            set: function (html) {
                var m = html ? html.match(/alert-(\w+)[^>]*>([\s\S]*?)(?:<\/div>|$)/) : null;
                if (m) { var kd = m[1] === 'primary' ? 'info' : m[1]; renderFn(m[2], kd); }
                else { _origSet.call(this, html || ''); }
            },
            configurable: true
        });
    }

    patchStatusEl(camStatusEl, renderCamStatus);
    patchStatusEl(upStatusEl, renderUpStatus);

    var wizardEl = el('enrollWizard');
    var livePane = el('livePane');
    var upPane = el('uploadPane');

    function syncStepFromPanes() {
        var wizHidden = wizardEl && wizardEl.classList.contains('d-none');
        var liveVisible = livePane && !livePane.classList.contains('d-none');
        var upVisible = upPane && !upPane.classList.contains('d-none');
        if (!wizHidden && !liveVisible && !upVisible) setStep(1);
        else if (liveVisible || upVisible) setStep(2);
    }

    var paneObs = new MutationObserver(syncStepFromPanes);
    [wizardEl, livePane, upPane].forEach(function (n) {
        if (n) paneObs.observe(n, { attributes: true, attributeFilter: ['class'] });
    });

    function bridgeClass(pane) {
        if (!pane) return;
        new MutationObserver(function () {
            pane.classList.toggle('active', !pane.classList.contains('d-none'));
        }).observe(pane, { attributes: true, attributeFilter: ['class'] });
    }
    bridgeClass(livePane);
    bridgeClass(upPane);

    function goBack() {
        if (wizardEl) { wizardEl.classList.remove('d-none'); wizardEl.style.display = ''; }
        if (livePane) { livePane.classList.add('d-none'); livePane.classList.remove('active'); }
        if (upPane) { upPane.classList.add('d-none'); upPane.classList.remove('active'); }
        document.dispatchEvent(new CustomEvent('fa:stopCam'));
        var camEl = el('cam');
        if (camEl && camEl.srcObject) {
            try { camEl.srcObject.getTracks().forEach(function (t) { t.stop(); }); } catch (_) { }
            camEl.srcObject = null;
        }
        if (fileInput) fileInput.value = '';
        if (fileStrip) _origSet.call(fileStrip, '');
        if (upStatusEl) _origSet.call(upStatusEl, '');
        setStep(1);
        setCaptures(0);
        setVideoGlow(null);
        if (liveBarFill) { liveBarFill.style.width = '0'; liveBarFill.className = 'fa-live-bar-fill'; }
        if (liveBarPct) liveBarPct.textContent = '---';
        if (sideScore) { sideScore.textContent = '---'; sideScore.className = 'fa-live-score-num'; }
        if (sideLabel) sideLabel.textContent = 'Waiting for scan...';
        if (sideBadge) sideBadge.style.display = 'none';
        if (camStatusEl) _origSet.call(camStatusEl, '');
    }

    var backL = el('backFromLive');
    var backU = el('backFromUpload');
    if (backL) backL.addEventListener('click', goBack);
    if (backU) backU.addEventListener('click', goBack);

    document.querySelectorAll('.fa-method-card').forEach(function (card) {
        card.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
        });
    });

    if (dropzone && fileInput) {
        dropzone.addEventListener('dragover', function (e) { e.preventDefault(); dropzone.classList.add('drag-over'); });
        ['dragleave', 'dragend'].forEach(function (ev) {
            dropzone.addEventListener(ev, function () { dropzone.classList.remove('drag-over'); });
        });
        dropzone.addEventListener('drop', function (e) {
            e.preventDefault();
            dropzone.classList.remove('drag-over');
            if (e.dataTransfer && e.dataTransfer.files.length) {
                try {
                    var dt = new DataTransfer();
                    Array.prototype.forEach.call(e.dataTransfer.files, function (f) { dt.items.add(f); });
                    fileInput.files = dt.files;
                } catch (_) { }
                fileInput.dispatchEvent(new Event('change', { bubbles: true }));
            }
        });
    }

    if (fileInput && fileStrip) {
        fileInput.addEventListener('change', function () {
            _origSet.call(fileStrip, '');
            Array.prototype.slice.call(fileInput.files || [], 0, 5).forEach(function (f) {
                var ext = (f.name.split('.').pop() || '').toLowerCase();
                var icon = (ext === 'png') ? 'fa-file-image' : 'fa-image';
                var chip = document.createElement('div');
                chip.className = 'fa-file-chip';
                chip.innerHTML = '<i class="fa-solid ' + icon + '" aria-hidden="true"></i><span>' + f.name.replace(/(.{20})..+/, '$1...') + '</span>';
                fileStrip.appendChild(chip);
            });
        });
    }

    var successOverlay = el('successOverlay');
    var processingModal = el('processingModal');
    var processingBar = el('processingBar');
    var processingStatus = el('processingStatus');
    var processingPercent = el('processingPercent');
    var successDetails = el('successDetails');

    function showProcessingModal(show) {
        if (!processingModal) return;
        processingModal.classList.toggle('d-none', !show);
        if (show) updateProcessingProgress(0, 'Initializing...');
    }

    function updateProcessingProgress(percent, status) {
        if (processingBar) processingBar.style.width = percent + '%';
        if (processingPercent) processingPercent.textContent = percent + '%';
        if (processingStatus && status) processingStatus.textContent = status;
    }

    function showSuccessOverlay(details) {
        if (!successOverlay) return;
        if (successDetails && details) successDetails.textContent = details;
        successOverlay.classList.remove('d-none');
        document.dispatchEvent(new CustomEvent('fa:stopCam'));
        var camEl = el('cam');
        if (camEl && camEl.srcObject) {
            try { camEl.srcObject.getTracks().forEach(function (t) { t.stop(); }); } catch (_) { }
            camEl.srcObject = null;
        }
    }

    var origRenderCamStatus = renderCamStatus;
    renderCamStatus = function(text, kind) {
        origRenderCamStatus(text, kind);
        if (/uploading/i.test(text)) { showProcessingModal(true); updateProcessingProgress(25, 'Uploading images...'); }
        if (/saving enrollment/i.test(text)) { showProcessingModal(true); updateProcessingProgress(75, 'Processing faces...'); }
        if (/enrollment saved/i.test(text)) {
            updateProcessingProgress(100, 'Complete!');
            setTimeout(function() {
                showProcessingModal(false);
                var match = text.match(/\[(\d+)\s*vector/i);
                showSuccessOverlay(match ? match[1] + ' face sample(s) saved' : '');
            }, 500);
        }
    };

    var origRenderUpStatus = renderUpStatus;
    renderUpStatus = function(text, kind) {
        origRenderUpStatus(text, kind);
        if (/uploading|processing/i.test(text)) { showProcessingModal(true); updateProcessingProgress(30, 'Uploading images...'); }
        if (/saved successfully/i.test(text)) {
            updateProcessingProgress(100, 'Complete!');
            setTimeout(function() {
                showProcessingModal(false);
                var match = text.match(/\[(\d+)\s*vector/i);
                showSuccessOverlay(match ? match[1] + ' face sample(s) saved' : '');
            }, 500);
        }
    };

    function showMultiFaceWarning(show) {
        var existing = document.querySelector('.fa-multi-face-warning');
        if (!show) { if (existing) existing.remove(); return; }
        if (existing) return;
        var warn = document.createElement('div');
        warn.className = 'fa-multi-face-warning';
        warn.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Multiple faces detected - using nearest person';
        if (videoWrap) videoWrap.appendChild(warn);
    }

    document.addEventListener('fa:multiFaceWarning', function(e) {
        showMultiFaceWarning(e.detail && e.detail.count > 1);
    });

    setStep(1);
    setCaptures(0);
})();
@Html.Raw("</script>")
