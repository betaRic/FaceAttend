@model FaceAttend.Models.Visitor

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Enroll Visitor Face - " + Model.Name;

    var initials = "";
    if (!string.IsNullOrWhiteSpace(Model.Name)) { initials += Model.Name[0]; }
    initials = initials.ToUpperInvariant();
}

@section styles{
    @Styles.Render("~/Content/enrollment")
}

<div class="fa-enroll-page">
    <div class="container-xl" style="max-width: 1000px;">

        @* Header *@
        <div class="d-flex align-items-center gap-3 mb-4">
            <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Visitors", new { area = "Admin" })">
                <i class="fa-solid fa-arrow-left me-2"></i>Back
            </a>
            <div>
                <h2 class="mb-0 fw-bold">Enroll Visitor</h2>
                <p class="text-muted mb-0">
                    @Model.Name 
                    <span class="badge bg-secondary ms-2">ID: @Model.Id</span>
                    @if (!string.IsNullOrWhiteSpace(Model.Company))
                    {
                        <span class="badge bg-info ms-1">@Model.Company</span>
                    }
                </p>
            </div>
        </div>

        @* Wizard Steps *@
        <div class="enroll-wizard-steps mb-4" id="wizardSteps">
            <div class="enroll-wizard-step is-active" data-step="1">
                <span class="enroll-wizard-step__num">1</span>
                <span>Method</span>
            </div>
            <div class="enroll-wizard-step__line"></div>
            <div class="enroll-wizard-step" data-step="2">
                <span class="enroll-wizard-step__num">2</span>
                <span>Capture</span>
            </div>
            <div class="enroll-wizard-step__line"></div>
            <div class="enroll-wizard-step" data-step="3">
                <span class="enroll-wizard-step__num">3</span>
                <span>Done</span>
            </div>
        </div>

        @* Main Content *@
        <div class="card shadow-sm">
            <div class="card-body p-4">

                @* Hidden CSRF *@
                @using (Html.BeginForm("", "", FormMethod.Post, new { id = "hiddenForm", @class = "d-none" }))
                {
                    @Html.AntiForgeryToken()
                }

                @* Method Selection Pane *@
                <div id="methodPane">
                    <h4 class="text-center mb-4">Select Enrollment Method</h4>
                    
                    <div class="fa-method-grid">
                        @* Live Camera *@
                        <div class="fa-method-card" onclick="showLive()">
                            <span class="fa-method__badge">Recommended</span>
                            <div class="fa-method__icon">
                                <i class="fa-solid fa-camera"></i>
                            </div>
                            <h5 class="fa-method__title">Live Camera</h5>
                            <p class="fa-method__desc">Real-time face capture with automatic liveness detection</p>
                        </div>

                        @* Upload Photos *@
                        <div class="fa-method-card" onclick="showUpload()">
                            <div class="fa-method__icon">
                                <i class="fa-solid fa-cloud-arrow-up"></i>
                            </div>
                            <h5 class="fa-method__title">Upload Photos</h5>
                            <p class="fa-method__desc">Upload 1-5 clear photos for quick enrollment</p>
                        </div>
                    </div>
                </div>

                @* Live Camera Pane *@
                <div id="livePane" class="enroll-hidden">
                    <button class="btn btn-outline-secondary mb-3" onclick="showMethod()">
                        <i class="fa-solid fa-chevron-left me-2"></i>Back
                    </button>

                    <div class="row g-4">
                        @* Camera Column *@
                        <div class="col-lg-8">
                            <div class="enroll-camera-wrap">
                                <video id="enrollVideo" class="enroll-video" autoplay playsinline muted></video>

                                @* Dynamic face bounding box — drawn by rAF loop below *@
                                <canvas id="enrollFaceCanvas" class="enroll-face-canvas"></canvas>

                                @* Status Badge *@
                                <div class="enroll-camera-status">
                                    <span class="enroll-camera-status__dot"></span>
                                    <span id="cameraStatusText">Camera Active</span>
                                </div>
                            </div>
                            <p class="enroll-guide-prompt" id="enrollGuidePrompt">
                                <i class="fa-solid fa-circle-dot"></i> Position your face in the oval
                            </p>
                        </div>

                        @* Stats Column *@
                        <div class="col-lg-4">
                            <div class="enroll-stats-panel">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="fw-semibold"><i class="fa-solid fa-bullseye me-2 text-primary"></i>Progress</span>
                                    <span class="fs-4 fw-bold text-primary"><span id="captureCount">0</span><small class="text-muted fs-6">/5</small></span>
                                </div>

                                @* Progress Bar *@
                                <div class="progress mb-3" style="height: 8px;">
                                    <div class="progress-bar" id="captureProgress" style="width: 0%"></div>
                                </div>


                                @* Liveness *@
                                <div class="enroll-liveness-mini">
                                    <div class="d-flex justify-content-between mb-1">
                                        <small class="fw-semibold">Liveness</small>
                                        <small id="livenessText">0%</small>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar bg-warning" id="livenessBar" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>

                            @* Action Buttons *@
                            <div class="d-grid gap-2 mt-3">
                                <button class="btn btn-success" id="saveBtn" onclick="saveEnrollment()" disabled>
                                    <i class="fa-solid fa-check me-2"></i>Save Enrollment
                                </button>
                                <button class="btn btn-outline-secondary" onclick="retake()">
                                    <i class="fa-solid fa-rotate-left me-2"></i>Retake
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                @* Upload Pane *@
                <div id="uploadPane" class="enroll-hidden">
                    <button class="btn btn-outline-secondary mb-3" onclick="showMethod()">
                        <i class="fa-solid fa-chevron-left me-2"></i>Back
                    </button>

                    @* Dropzone *@
                    <div class="enroll-dropzone" id="dropzone">
                        <input type="file" id="fileInput" multiple accept="image/*" class="d-none">
                        <div class="enroll-dropzone__icon">
                            <i class="fa-solid fa-cloud-arrow-up"></i>
                        </div>
                        <h5>Drop photos here or click to browse</h5>
                        <p class="text-muted mb-2">Upload 1 to 5 clear, well-lit face photos</p>
                        <span class="badge bg-light text-dark border">
                            <i class="fa-solid fa-file-image me-1"></i>JPG, PNG up to 10MB
                        </span>
                    </div>

                    @* File Grid *@
                    <div class="enroll-file-grid" id="fileGrid"></div>

                    @* Upload Button *@
                    <div class="text-center mt-4">
                        <button class="btn btn-primary btn-lg" id="uploadBtn" onclick="processUpload()" disabled>
                            <i class="fa-solid fa-upload me-2"></i>Upload & Enroll
                        </button>
                    </div>
                </div>

                @* Success Pane *@
                <div id="successPane" class="enroll-hidden text-center py-5">
                    <div class="enroll-success-icon mb-3">
                        <i class="fa-solid fa-check"></i>
                    </div>
                    <h3 class="fw-bold mb-2">Enrollment Complete!</h3>
                    <p class="text-muted mb-4">Face biometric successfully enrolled for <strong>@Model.Name</strong></p>
                    <div class="d-flex justify-content-center gap-2">
                        <a href="@Url.Action("Index", "Visitors", new { area = "Admin" })" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-arrow-left me-2"></i>Back to List
                        </a>
                        <a href="@Url.Action("Edit", "Visitors", new { area = "Admin", id = Model.Id })" class="btn btn-primary">
                            <i class="fa-solid fa-pen me-2"></i>Edit Visitor
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div id="visitorEnrollConfig" class="d-none"
     data-visitor-id="@Model.Id.ToString()"
     data-scan-url="@Url.Content("~/api/scan/frame")"
     data-enroll-url="@Url.Content("~/api/enrollment/enroll")"
     data-upload-url="@Url.Action("EnrollFace", "Visitors", new { area = "Admin" })"></div>

@section scripts{
    @Scripts.Render("~/bundles/fa-core")
    @Scripts.Render("~/bundles/enrollment")
    @Scripts.Render("~/bundles/visitor-enroll-page")

    <script>
    // Portrait orientation lock
    (function () {
        if (screen.orientation && screen.orientation.lock) {
            screen.orientation.lock('portrait-primary').catch(function () {});
        }
    })();
    </script>
}
