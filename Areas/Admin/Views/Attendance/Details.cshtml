@using FaceAttend.Services
@model FaceAttend.Models.ViewModels.Admin.AttendanceDetailsVm

@{
    ViewBag.Title = "Attendance Details";
    var backUrl = Url.Action("Index", "Attendance", new { area = "Admin" });
}

<div class="ea-page">

<div class="ea-page-header">
    <div>
        <h1 class="ea-page-title">
            <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
            Attendance Details
        </h1>
        <div class="ea-page-subtitle">ID: @Model.Id</div>
    </div>
    <div class="ea-page-actions">
        <a class="btn btn-outline-secondary btn-sm" href="@backUrl">
            <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>Back
        </a>

        @if (Model.IsVoided)
        {
            <span class="badge bg-danger">Voided</span>
        }
        else if (Model.NeedsReview || Model.ReviewStatus == "PENDING")
        {
            <span class="ea-badge review">
                <i class="fa-solid fa-triangle-exclamation fa-xs"></i>Needs review
            </span>
        }
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="ea-card">
            <div class="ea-card-body">
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <div class="text-muted small">Time (local)</div>
                        <div class="fw-semibold">@Model.TimestampLocal.ToString("yyyy-MM-dd HH:mm:ss")</div>
                    </div>

                    <div class="col-12 col-md-6">
                        <div class="text-muted small">Event</div>
                        <div class="fw-semibold">@Model.EventType</div>
                    </div>

                    <div class="col-12">
                        <hr />
                    </div>

                    <div class="col-12 col-md-6">
                        <div class="text-muted small">Employee</div>
                        <div class="fw-semibold">@Model.EmployeeFullName</div>
                        <div class="text-muted small">@Model.EmployeeId @(!string.IsNullOrWhiteSpace(Model.Department) ? ("· " + Model.Department) : "")</div>
                    </div>

                    <div class="col-12 col-md-6">
                        <div class="text-muted small">Office</div>
                        <div class="fw-semibold">@Model.OfficeName</div>
                        <div class="text-muted small">@Model.OfficeType</div>
                    </div>

                    <div class="col-12">
                        <hr />
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="text-muted small">Anti-spoof</div>
                        <div class="fw-semibold">@(Model.AntiSpoofScore.HasValue ? Model.AntiSpoofScore.Value.ToString("0.000") : "-")</div>
                        <div class="text-muted small">@Model.AntiSpoofResult @(!string.IsNullOrWhiteSpace(Model.AntiSpoofError) ? ("· " + Model.AntiSpoofError) : "")</div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="text-muted small">Distance</div>
                        <div class="fw-semibold">@(Model.FaceDistance.HasValue ? Model.FaceDistance.Value.ToString("0.000") : "-")</div>
                        <div class="text-muted small">Threshold: @(Model.MatchThreshold.HasValue ? Model.MatchThreshold.Value.ToString("0.000") : "-")</div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="text-muted small">Location</div>
                        <div class="fw-semibold">@(Model.LocationVerified ? "Verified" : "Not verified")</div>
                        <div class="text-muted small">Accuracy: @(Model.GPSAccuracy.HasValue ? Model.GPSAccuracy.Value.ToString("0.0") + "m" : "-")</div>
                    </div>

                    <div class="col-12">
                        <hr />
                    </div>

                    <div class="col-12">
                        <div class="text-muted small">Notes</div>
                        <div class="border rounded-3 p-2" style="min-height: 54px; white-space: pre-wrap;">@((Model.Notes ?? "").Trim())</div>
                    </div>

                    <div class="col-12">
                        <div class="text-muted small">Client</div>
                        <div class="small">IP: @Model.ClientIP</div>
                        <div class="small text-muted" style="word-break: break-word;">UA: @Model.UserAgent</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="ea-card">
            <div class="ea-card-body">
                <div class="ea-form-section-title">
                    <i class="fa-solid fa-flag fa-xs" aria-hidden="true"></i>Review
                </div>
                <div class="text-muted small mb-2">
                    Use this when a scan looks suspicious but you still want to keep the record.
                </div>
                <dl class="row small mb-3">
                    <dt class="col-5">Status</dt>
                    <dd class="col-7">@(!string.IsNullOrWhiteSpace(Model.ReviewStatus) ? Model.ReviewStatus : "NONE")</dd>
                    <dt class="col-5">Reasons</dt>
                    <dd class="col-7">@(!string.IsNullOrWhiteSpace(Model.ReviewReasonCodes) ? Model.ReviewReasonCodes.Replace(",", ", ") : "-")</dd>
                    @if (Model.IsVoided)
                    {
                        <dt class="col-5">Void reason</dt>
                        <dd class="col-7">@Model.VoidReason</dd>
                    }
                </dl>

                @if (!Model.IsVoided && (Model.NeedsReview || Model.ReviewStatus == "PENDING"))
                {
                    using (Html.BeginForm("MarkReviewed", "Attendance", new { area = "Admin" }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <label class="form-label">Note (optional)</label>
                        <input class="form-control mb-2" name="note" placeholder="What did you check?" />

                        <button type="submit" class="btn btn-success w-100">
                            <i class="fa-solid fa-check me-1"></i>Mark as reviewed
                        </button>
                    }

                    using (Html.BeginForm("Delete", "Attendance", new { area = "Admin" }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <label class="form-label mt-3">Void reason</label>
                        <input class="form-control mb-2" name="reason" placeholder="Required reason" required />
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="fa-solid fa-ban me-1"></i>Void record
                        </button>
                    }
                }
                else
                {
                    <div class="text-muted">This record is not in the review queue.</div>
                }

                <hr />

                <div class="text-muted small">
                    Source: @Model.Source
                </div>
            </div>
        </div>

        <div class="ea-card mt-3">
            <div class="ea-card-body">
                <div class="ea-form-section-title">
                    <i class="fa-solid fa-location-dot fa-xs" aria-hidden="true"></i>Raw GPS
                </div>
                <div class="small">Lat: @(Model.GPSLatitude.HasValue ? Model.GPSLatitude.Value.ToString("0.000000") : "-")</div>
                <div class="small">Lon: @(Model.GPSLongitude.HasValue ? Model.GPSLongitude.Value.ToString("0.000000") : "-")</div>
                <div class="small text-muted">Error: @Model.LocationError</div>
            </div>
        </div>
    </div>
</div>

</div>
