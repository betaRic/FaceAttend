@model FaceAttend.Models.ViewModels.Mobile.EmployeePortalVm
@{
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
    ViewBag.Title = "My Attendance";
}

@section styles {
    <style>
        .employee-header {
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .employee-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            font-size: 2rem;
            color: white;
        }

        .employee-name {
            font-size: 1.25rem;
            font-weight: 700;
            color: #f8fafc;
            margin-bottom: 0.25rem;
        }

        .employee-meta {
            font-size: 0.875rem;
            color: #94a3b8;
        }

        .clock-card {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(37, 99, 235, 0.1) 100%);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 16px;
            padding: 1.25rem;
            text-align: center;
            margin-bottom: 1rem;
        }

        .clock-time {
            font-size: 2.5rem;
            font-weight: 700;
            color: #3b82f6;
            font-variant-numeric: tabular-nums;
            line-height: 1;
        }

        .clock-date {
            font-size: 0.875rem;
            color: #94a3b8;
            margin-top: 0.25rem;
        }

        .status-card {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1rem;
            border-radius: 12px;
            margin-bottom: 1rem;
        }

        .status-card.in { background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3); }
        .status-card.out { background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.3); }
        .status-card.none { background: rgba(148, 163, 184, 0.1); border: 1px solid rgba(148, 163, 184, 0.3); }

        .status-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        .status-card.in .status-icon { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
        .status-card.out .status-icon { background: rgba(59, 130, 246, 0.2); color: #3b82f6; }
        .status-card.none .status-icon { background: rgba(148, 163, 184, 0.2); color: #94a3b8; }

        .status-text { flex: 1; }
        .status-label { font-size: 0.75rem; color: #94a3b8; text-transform: uppercase; }
        .status-value { font-size: 1rem; font-weight: 600; color: #f8fafc; }

        .device-card {
            background: rgba(15, 23, 42, 0.65);
            border: 1px solid rgba(148, 163, 184, 0.18);
            border-radius: 14px;
            padding: 1rem;
            margin-bottom: 1rem;
        }

        .device-card-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
        }

        .device-title {
            color: #f8fafc;
            font-weight: 700;
        }

        .device-pill {
            color: #38bdf8;
            background: rgba(56, 189, 248, 0.12);
            border: 1px solid rgba(56, 189, 248, 0.25);
            border-radius: 999px;
            padding: 0.25rem 0.55rem;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.04em;
        }

        .device-meta {
            color: #94a3b8;
            font-size: 0.82rem;
            line-height: 1.45;
        }

        .device-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: #f59e0b;
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 700;
            margin-top: 0.65rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .stat-card {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            padding: 1rem;
            text-align: center;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #f8fafc;
            line-height: 1;
        }

        .stat-label {
            font-size: 0.75rem;
            color: #94a3b8;
            margin-top: 0.25rem;
        }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 0.75rem;
        }

        .section-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: #f8fafc;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .history-list {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .history-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem;
            background: rgba(15, 23, 42, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }

        .history-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.875rem;
        }

        .history-icon.in { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
        .history-icon.out { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }

        .history-details { flex: 1; }
        .history-date { font-size: 0.875rem; font-weight: 500; color: #f8fafc; }
        .history-office { font-size: 0.75rem; color: #64748b; }
        .history-time { font-size: 0.875rem; font-weight: 600; color: #94a3b8; }

        .notification-card {
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.1) 0%, rgba(217, 119, 6, 0.05) 100%);
            border: 1px solid rgba(245, 158, 11, 0.3);
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1rem;
        }

        .notification-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
            color: #f59e0b;
            font-weight: 600;
        }

        .notification-text {
            font-size: 0.875rem;
            color: #cbd5e1;
            margin-bottom: 0.75rem;
        }

        .notification-btn {
            background: rgba(245, 158, 11, 0.2);
            border: 1px solid rgba(245, 158, 11, 0.4);
            color: #f59e0b;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .notification-btn:hover {
            background: rgba(245, 158, 11, 0.3);
        }

        .notification-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .export-btn {
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.3);
            color: #22c55e;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
        }

        .export-btn:hover {
            background: rgba(34, 197, 94, 0.2);
        }

        .back-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #94a3b8;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            font-size: 0.875rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
        }

        .action-bar {
            display: flex;
            gap: 0.75rem;
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        @@media (max-width: 640px) {
    .stats-grid {
        grid-template-columns: 1fr;
    }

    .action-bar {
        flex-direction: column;
    }

    .export-btn,
    .back-btn {
        width: 100%;
        justify-content: center;
    }

    .clock-time {
        font-size: 2rem;
    }

    .status-card,
    .history-item {
        align-items: flex-start;
    }

    .history-time {
        margin-left: auto;
    }

    .employee-name {
        font-size: 1.1rem;
    }

    /* Monthly Attendance Table */
    .attendance-table-container {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        overflow: hidden;
        margin-top: 1rem;
    }

    .attendance-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

    .attendance-table thead {
        background: rgba(30, 41, 59, 0.8);
        position: sticky;
        top: 0;
    }

    .attendance-table th {
        padding: 0.75rem 0.5rem;
        text-align: left;
        font-weight: 600;
        color: #94a3b8;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .attendance-table td {
        padding: 0.75rem 0.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        color: #f8fafc;
    }

    .attendance-table tr:last-child td {
        border-bottom: none;
    }

    .attendance-table tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .attendance-table .day-cell {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .attendance-table .day-name {
        font-size: 0.75rem;
        color: #64748b;
    }

    .attendance-table .day-date {
        font-weight: 600;
        color: #f8fafc;
    }

    .attendance-table .time-cell {
        font-family: 'SF Mono', monospace;
        font-variant-numeric: tabular-nums;
    }

    .attendance-table .status-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.5rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .status-badge.present {
        background: rgba(34, 197, 94, 0.15);
        color: #22c55e;
    }

    .status-badge.absent {
        background: rgba(239, 68, 68, 0.15);
        color: #ef4444;
    }

    .status-badge.weekend {
        background: rgba(100, 116, 139, 0.15);
        color: #64748b;
    }

    .status-badge.inprogress {
        background: rgba(59, 130, 246, 0.15);
        color: #3b82f6;
    }

    .status-badge.incomplete {
        background: rgba(245, 158, 11, 0.15);
        color: #f59e0b;
    }

    .attendance-table .hours-cell {
        font-weight: 600;
        color: #3b82f6;
    }

    .attendance-table .weekend-row {
        background: rgba(30, 41, 59, 0.3);
    }

    .attendance-summary-bar {
        display: flex;
        justify-content: space-around;
        padding: 1rem;
        background: rgba(30, 41, 59, 0.5);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .summary-item {
        text-align: center;
    }

    .summary-value {
        font-size: 1.25rem;
        font-weight: 700;
        color: #f8fafc;
    }

    .summary-label {
        font-size: 0.75rem;
        color: #64748b;
        margin-top: 0.25rem;
    }

    .table-scroll {
        max-height: 400px;
        overflow-y: auto;
    }

    .no-data {
        text-align: center;
        padding: 2rem;
        color: #64748b;
    }
}
    </style>
}

<!-- Employee Header -->
<div class="employee-header">
    <div class="employee-avatar">
        <i class="fa-solid fa-user"></i>
    </div>
    <div class="employee-name">@Model.FullName</div>
    <div class="employee-meta">
        @Model.Position @(string.IsNullOrEmpty(Model.Department) ? "" : "-") @Model.Department<br>
        @Model.OfficeName
    </div>
</div>

<!-- Live Clock -->
<div class="clock-card">
    <div class="clock-time" id="liveClock">--:--</div>
    <div class="clock-date" id="liveDate">Loading...</div>
</div>

<!-- Today's Status -->
<div class="status-card @(Model.TodayStatus.ToLower().Replace(" ", ""))">
    <div class="status-icon">
        @if (Model.TodayStatus == "Timed In")
        {
            <i class="fa-solid fa-door-open"></i>
        }
        else if (Model.TodayStatus == "Timed Out")
        {
            <i class="fa-solid fa-door-closed"></i>
        }
        else
        {
            <i class="fa-solid fa-circle-question"></i>
        }
    </div>
    <div class="status-text">
        <div class="status-label">Today's Status</div>
        <div class="status-value">
            @Model.TodayStatus
            @if (!string.IsNullOrEmpty(Model.LastScanTime))
            {
                <span style="font-size: 0.875rem; color: #64748b; font-weight: 400;">at @Model.LastScanTime</span>
            }
        </div>
    </div>
</div>

<div class="device-card">
    <div class="device-card-head">
        <div>
            <div class="status-label">Record Access</div>
            <div class="device-title">Fresh Face Scan Verified</div>
        </div>
        <span class="device-pill">SECURE</span>
    </div>
    <div class="device-meta">
        This page is available only from your latest successful attendance scan.
        @(Model.AccessExpiresAtUtc.HasValue ? "Access expires soon." : "")
    </div>
    <a class="device-link" href="/MobileRegistration/Identify">
        <i class="fa-solid fa-rotate"></i> Scan again to refresh access
    </a>
</div>

<!-- Monthly Stats -->
<div class="section-header">
    <span class="section-title">@Model.CurrentMonthDisplay Summary</span>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-value">@Model.TotalDaysPresent</div>
        <div class="stat-label">Days Present</div>
    </div>
    <div class="stat-card">
        <div class="stat-value">@Model.TotalHours</div>
        <div class="stat-label">Total Hours</div>
    </div>
    <div class="stat-card">
        <div class="stat-value">@Model.AverageHoursPerDay</div>
        <div class="stat-label">Avg Hours/Day</div>
    </div>
</div>

<!-- Notification Permission Card -->
<div class="notification-card" id="notificationCard" style="display: none;">
    <div class="notification-header">
        <i class="fa-solid fa-bell"></i>
        <span>Time Reminders</span>
    </div>
    <div class="notification-text">
        Get notified when it's time for morning check-in, lunch break, or afternoon check-out.
    </div>
    <button type="button" class="notification-btn" id="enableNotificationsBtn">
        <i class="fa-solid fa-bell-slash"></i> Enable Reminders
    </button>
</div>

<!-- Monthly Attendance Report -->
<div class="section-header">
    <span class="section-title">@Model.CurrentMonthDisplay Attendance</span>
</div>

<div class="attendance-table-container">
    <!-- Summary Bar -->
    <div class="attendance-summary-bar">
        <div class="summary-item">
            <div class="summary-value">@Model.TotalDaysPresent</div>
            <div class="summary-label">Days Present</div>
        </div>
        <div class="summary-item">
            <div class="summary-value">@Model.TotalHours</div>
            <div class="summary-label">Total Hours</div>
        </div>
        <div class="summary-item">
            <div class="summary-value">@(Model.AverageHoursPerDay > 0 ? Model.AverageHoursPerDay.ToString("F1") : "-")</div>
            <div class="summary-label">Avg Hours</div>
        </div>
    </div>

    <!-- Attendance Table -->
    <div class="table-scroll">
        <table class="attendance-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Time In</th>
                    <th>Time Out</th>
                    <th>Hours</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.MonthlyReport != null && Model.MonthlyReport.Any())
                {
                    foreach (var day in Model.MonthlyReport)
                    {
                        <tr class="@(day.IsWeekend ? "weekend-row" : "")">
                            <td>
                                <div class="day-cell">
                                    <span class="day-name">@day.DayOfWeek</span>
                                    <span class="day-date">@day.DateDisplay</span>
                                </div>
                            </td>
                            <td class="time-cell">@(day.TimeIn ?? "-")</td>
                            <td class="time-cell">@(day.TimeOut ?? "-")</td>
                            <td class="hours-cell">@(day.HoursWorked.HasValue ? day.HoursWorked.Value.ToString("F2") : "-")</td>
                            <td>
                                <span class="status-badge @day.Status.ToLower().Replace(" ", "")">
                                    @day.Status
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="no-data">
                            <i class="fa-solid fa-calendar-xmark" style="font-size: 2rem; margin-bottom: 0.5rem; opacity: 0.5;"></i>
                            <div>No attendance records for this month</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Actions -->
<div class="action-bar">
    <a href="/Attendance/ExportMyMonth" class="export-btn">
        <i class="fa-solid fa-file-csv"></i> Export CSV
    </a>
    <a href="/MobileRegistration/Identify" class="back-btn">
        <i class="fa-solid fa-arrow-left"></i> Back to Scanner
    </a>
</div>

@section scripts {
    <script>
        (function() {
            // Live clock
            function updateClock() {
                var now = new Date();
                var hours = String(now.getHours()).padStart(2, '0');
                var minutes = String(now.getMinutes()).padStart(2, '0');
                document.getElementById('liveClock').textContent = hours + ':' + minutes;
                
                var options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
                document.getElementById('liveDate').textContent = now.toLocaleDateString('en-US', options);
            }
            updateClock();
            setInterval(updateClock, 1000);
            
            // Notification permission handling
            var notificationCard = document.getElementById('notificationCard');
            var enableBtn = document.getElementById('enableNotificationsBtn');
            
            // Show card if notifications not yet decided
            if ('Notification' in window && Notification.permission === 'default') {
                notificationCard.style.display = 'block';
            }
            
            enableBtn.addEventListener('click', function() {
                if (!('Notification' in window)) {
                    MobileSwal.error('Not Supported', 'Your browser does not support notifications.');
                    return;
                }
                
                Notification.requestPermission().then(function(permission) {
                    if (permission === 'granted') {
                        notificationCard.style.display = 'none';
                        MobileSwal.success('Reminders Enabled', 'You will be notified when it\'s time to check in or out.');
                        
                        // Unlock audio for notification sound
                        if (window.FaceAttendAudio) {
                            FaceAttendAudio.unlock();
                        }
                        
                        // Start reminder checking
                        startReminderChecks();
                    } else {
                        MobileSwal.warning('Notifications Blocked', 'You can enable them later in your browser settings.');
                        notificationCard.style.display = 'none';
                    }
                });
            });
            
            // Reminder checker - runs every minute
            function startReminderChecks() {
                checkReminders(); // Check immediately
                setInterval(checkReminders, 60000); // Then every minute
            }
            
            function checkReminders() {
                var now = new Date();
                var hour = now.getHours();
                var minute = now.getMinutes();
                
                // Morning check-in: 7:30-8:30 AM
                if (hour === 7 && minute === 30) {
                    showReminder('Good Morning!', 'Time for morning check-in. Have a great day!', 'morning');
                }
                
                // Lunch break: 12:00 PM
                if (hour === 12 && minute === 0) {
                    showReminder('Lunch Time', 'Time for your lunch break. Enjoy your meal!', 'lunch');
                }
                
                // Afternoon check-out: 4:30-5:00 PM
                if (hour === 16 && minute === 30) {
                    showReminder('Almost Done', 'Time for afternoon check-out. Great work today!', 'evening');
                }
            }
            
            function showReminder(title, body, type) {
                // Play notification sound
                if (window.FaceAttendAudio) {
                    FaceAttendAudio.playNotification();
                }
                
                // Show web notification if permitted
                if (Notification.permission === 'granted') {
                    var icon = '/Content/images/icon-192.png'; // Default icon path
                    new Notification(title, {
                        body: body,
                        icon: icon,
                        badge: icon,
                        tag: 'attendance-reminder-' + type,
                        requireInteraction: true
                    });
                }
                
                // Also show in-app toast
                MobileSwal.toast('info', body);
            }
            
            // If already granted, start reminders
            if ('Notification' in window && Notification.permission === 'granted') {
                startReminderChecks();
            }
            
            // Unlock audio on first interaction
            document.addEventListener('click', function() {
                if (window.FaceAttendAudio && !FaceAttendAudio.isUnlocked()) {
                    FaceAttendAudio.unlock();
                }
            }, { once: true });
        })();
    </script>
}
