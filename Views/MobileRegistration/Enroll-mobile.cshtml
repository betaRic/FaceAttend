@*Views/MobileRegistration/Enroll.cshtml*@
@{
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
    ViewBag.Title = "Face Enrollment";
}

@section styles {
    @Styles.Render("~/Content/fa-system")
    @Styles.Render("~/Content/fa-mobile")
    @Styles.Render("~/Content/enrollment")
    <style>
        /* ── Step 1 & 3 wizard chrome ─────────────────────────────────── */
        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 8px;
        }
        .header h1 {
            margin: 0;
            font-size: 1.05rem;
            line-height: 1.15;
        }
        .header p { display: none; }
        .wizard-steps {
            display: flex; align-items: center; gap: 8px; margin-bottom: 8px;
        }
        .wizard-step {
            flex: 1; text-align: center; padding: 7px 6px; border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.12);
            background: rgba(255,255,255,0.04);
            color: var(--text-muted); font-size: 13px; font-weight: 600;
            transition: all .2s ease;
        }
        .wizard-step.active { background: rgba(59,130,246,0.16); border-color: rgba(59,130,246,0.45); color: #fff; }
        .wizard-step.done   { background: rgba(34,197,94,0.14);  border-color: rgba(34,197,94,0.4);   color: #dcfce7; }
        .wizard-pane        { display: none; }
        .wizard-pane.active { display: block; animation: slideIn .25s ease; }
        @@keyframes slideIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
        #step1.active, #step3.active {
            max-height: calc(100vh - 146px);
            max-height: calc(100dvh - 146px);
            overflow: auto;
            padding-right: 2px;
        }
        .wizard-actions {
            position: sticky;
            bottom: 0;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-top: 8px;
            padding-top: 8px;
            background: linear-gradient(to top, rgba(2,6,23,0.98) 75%, rgba(2,6,23,0));
        }
        .hint-box {
            background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);
            color: var(--text-secondary); border-radius: 8px; padding: 8px 10px;
            margin-bottom: 8px; font-size: 13px;
        }
        .form-section  { margin-bottom: 8px; }
        .form-row      { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .form-group    { margin-bottom: 8px; }
        .form-group label {
            display: block; font-size: 11px; font-weight: 700; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0; margin-bottom: 3px;
        }
        .form-group label .required { color: var(--color-error); }
        .form-group label .hint     { font-weight: 400; font-size: 11px; text-transform: none; letter-spacing: 0; }
        .form-group input, .form-group select {
            width: 100%; min-height: 38px; padding: 8px 10px;
            background: rgba(255,255,255,0.05); border: 1.5px solid rgba(255,255,255,0.12);
            border-radius: 8px; color: var(--text-primary); font-size: 14px;
            transition: border-color .2s;
        }
        .form-group input:focus, .form-group select:focus { outline: none; border-color: var(--color-primary); }
        .form-group input.valid   { border-color: var(--color-success); }
        .form-group input.invalid { border-color: var(--color-error); }
        .validation-message { font-size: 10px; color: var(--color-error); margin-top: 2px; min-height: 12px; }
        .security-badge {
            display: flex; align-items: center; gap: 8px; padding: 10px 14px;
            background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2);
            border-radius: 10px; font-size: 12px; color: #4ade80; margin-top: 4px;
        }
        .uppercase { text-transform: uppercase; }
        .review-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .review-item {
            padding: 8px 10px; border-radius: 8px;
            background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        }
        .review-label { font-size: 11px; color: var(--text-muted); margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0; }
        .review-value { font-size: 14px; color: var(--text-primary); word-break: break-word; }
        .status-bar {
            padding: 8px 10px; border-radius: 8px; text-align: center;
            font-size: 13px; font-weight: 500; margin-top: 8px;
        }
        .status-bar.success { background: rgba(34,197,94,0.1); color: #34d399; border: 1px solid rgba(34,197,94,0.2); }
        .status-bar.error   { background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }

        @@media (max-height: 720px) {
            .header { display: none; }
            #step1.active, #step3.active {
                max-height: calc(100vh - 98px);
                max-height: calc(100dvh - 98px);
            }
            .wizard-step { font-size: 12px; padding: 6px 4px; }
        }

        @@media (max-width: 360px) {
            .form-row,
            .review-grid,
            .wizard-actions {
                grid-template-columns: 1fr;
            }
        }

        /* ── Step 2: Full-screen camera ───────────────────────────────── */

        /* When step 2 is active, break it out of normal flow */
        #step2.active {
            position: fixed !important;
            inset: 0 !important;
            z-index: 1000 !important;
            background: #000 !important;
            overflow: hidden !important;
            animation: none !important;
        }

        .cam-fs-inner {
            position: relative;
            width: 100%;
            height: 100%;
            height: 100dvh;
            overflow: hidden;
        }

        /* Full-screen video — mirrors naturally */
        .cam-fs-video {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scaleX(-1);
        }

        /* Canvas overlay for face detection boxes */
        .cam-fs-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 2;
        }

        /* ── Top HUD ─────────────────────────────────────────────────── */
        .cam-fs-top {
            position: absolute;
            top: 0; left: 0; right: 0;
            z-index: 10;
            padding: calc(env(safe-area-inset-top, 12px) + 0.75rem) 1rem 2rem;
            background: linear-gradient(to bottom, rgba(0,0,0,0.72) 0%, transparent 100%);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .cam-fs-back-btn {
            flex-shrink: 0;
            width: 42px; height: 42px;
            display: flex; align-items: center; justify-content: center;
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 50%;
            color: #fff;
            font-size: 1rem;
            cursor: pointer;
        }

        .cam-fs-status-wrap {
            flex: 1;
            min-width: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .cam-fs-status-dot {
            flex-shrink: 0;
            width: 8px; height: 8px;
            background: #22c55e;
            border-radius: 50%;
            animation: camDotPulse 2s ease-in-out infinite;
        }

        .cam-fs-status-text {
            color: rgba(255,255,255,0.9);
            font-size: 0.8125rem;
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .cam-fs-counter {
            flex-shrink: 0;
            color: #fff;
            font-size: 1.375rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            line-height: 1;
        }

        .cam-fs-counter sub {
            font-size: 0.75rem;
            font-weight: 400;
            color: rgba(255,255,255,0.55);
            vertical-align: baseline;
        }

        @@keyframes camDotPulse {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.35; }
        }

        /* ── Center guide pill ───────────────────────────────────────── */
        .cam-fs-guide-pill {
            position: absolute;
            bottom: 38%;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            padding: 0.45rem 1.1rem;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 9999px;
            color: #fff;
            font-size: 0.875rem;
            font-weight: 500;
            white-space: nowrap;
            max-width: 88vw;
            overflow: hidden;
            text-overflow: ellipsis;
            text-align: center;
            pointer-events: none;
            transition: opacity 0.3s;
        }

        /* ── Bottom HUD ──────────────────────────────────────────────── */
        .cam-fs-bottom {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            z-index: 10;
            padding: 2.5rem 1.5rem calc(env(safe-area-inset-bottom, 16px) + 1.25rem);
            background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, transparent 100%);
        }

        /* Anti-spoof row */
        .cam-fs-antiSpoof {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.25rem;
        }

        .cam-fs-antiSpoof-label {
            font-size: 0.75rem;
            font-weight: 600;
            color: rgba(255,255,255,0.6);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            flex-shrink: 0;
            width: 4rem;
        }

        .cam-fs-antiSpoof-track {
            flex: 1;
            height: 5px;
            background: rgba(255,255,255,0.18);
            border-radius: 9999px;
            overflow: hidden;
        }

        .cam-fs-antiSpoof-fill {
            height: 100%;
            width: 0%;
            background: #22c55e;
            border-radius: 9999px;
            transition: width 0.35s ease, background-color 0.35s ease;
        }

        .cam-fs-antiSpoof-fill.low  { background: #ef4444; }
        .cam-fs-antiSpoof-fill.mid  { background: #f59e0b; }
        .cam-fs-antiSpoof-fill.high { background: #22c55e; }

        .cam-fs-antiSpoof-pct {
            font-size: 0.8125rem;
            font-weight: 700;
            color: #fff;
            min-width: 2.25rem;
            text-align: right;
            flex-shrink: 0;
        }

        /* Frame dots */
        .cam-fs-dots {
            display: flex;
            justify-content: center;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
        }

        .cam-fs-dot {
            width: 14px; height: 14px;
            border-radius: 50%;
            background: rgba(255,255,255,0.2);
            border: 2px solid rgba(255,255,255,0.3);
            transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .cam-fs-dot.captured {
            background: #22c55e;
            border-color: #22c55e;
            box-shadow: 0 0 10px rgba(34,197,94,0.7);
            transform: scale(1.15);
        }

        .cam-fs-hint {
            text-align: center;
            font-size: 0.75rem;
            color: rgba(255,255,255,0.45);
        }
    </style>
}

<div class="header">
    <h1><i class="fa-solid fa-camera-alt"></i> Face Enrollment</h1>
    <p>Complete your details, capture your face, then submit for approval</p>
</div>

@Html.AntiForgeryToken()

<div class="wizard-steps" id="wizardSteps">
    <div class="wizard-step active" data-step="1">1. Details</div>
    <div class="wizard-step"        data-step="2">2. Capture</div>
    <div class="wizard-step"        data-step="3">3. Review</div>
</div>

@* ═══════════════════════════════════════════════════════════
   STEP 1 — Employee details form  (unchanged)
   ═══════════════════════════════════════════════════════════ *@
<div class="wizard-pane active" id="step1">
    <div class="form-section">

        <div class="form-group">
            <label>Employee ID <span class="required">*</span> <span class="hint">(Format: DILG-YYYY-###)</span></label>
            <input type="text" id="employeeId" class="uppercase" placeholder="e.g., DILG-2024-001"
                   required maxlength="20" autocomplete="off" />
            <div class="validation-message" id="employeeIdValidation"></div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>First Name <span class="required">*</span></label>
                <input type="text" id="firstName" class="uppercase" required maxlength="50" autocomplete="given-name" />
                <div class="validation-message" id="firstNameValidation"></div>
            </div>
            <div class="form-group">
                <label>Last Name <span class="required">*</span></label>
                <input type="text" id="lastName" class="uppercase" required maxlength="50" autocomplete="family-name" />
                <div class="validation-message" id="lastNameValidation"></div>
            </div>
        </div>

        <div class="form-group">
            <label>Middle Name <span class="hint">(Optional)</span></label>
            <input type="text" id="middleName" class="uppercase" placeholder="Optional"
                   maxlength="50" autocomplete="additional-name" />
            <div class="validation-message" id="middleNameValidation"></div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Position <span class="required">*</span></label>
                <input type="text" id="position" class="uppercase" required maxlength="100" autocomplete="organization-title" />
                <div class="validation-message" id="positionValidation"></div>
            </div>
            <div class="form-group">
                <label>Department <span class="required">*</span></label>
                <input type="text" id="department" class="uppercase" required maxlength="100" autocomplete="organization" />
                <div class="validation-message" id="departmentValidation"></div>
            </div>
        </div>

        <div class="form-group">
            <label>Office <span class="required">*</span></label>
            <select id="officeId" required>
                <option value="">Select Office</option>
                @foreach (var office in ViewBag.Offices)
                {
                    <option value="@office.Id">@office.Name</option>
                }
            </select>
            <div class="validation-message" id="officeIdValidation"></div>
        </div>

    </div>

    <div class="wizard-actions">
        <button type="button" class="btn btn-primary" id="btnToCapture" disabled>
            <i class="fa-solid fa-camera me-2"></i>Continue to Face Capture
        </button>
        <a href="/MobileRegistration" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left me-2"></i>Back
        </a>
    </div>
</div>

@* ═══════════════════════════════════════════════════════════
   STEP 2 — Full-screen camera capture
   ═══════════════════════════════════════════════════════════ *@
<div class="wizard-pane" id="step2">
    <div class="cam-fs-inner">

        @* Video feed: object-fit cover fills the full screen *@
        <video id="enrollVideo" class="cam-fs-video" autoplay playsinline muted></video>

        @* Canvas: enrollment-tracker.js draws face detection boxes here *@
        <canvas id="enrollFaceCanvas" class="cam-fs-canvas"></canvas>

        @* ── Top HUD *@
        <div class="cam-fs-top">
            <button type="button" class="cam-fs-back-btn" id="btnBackToDetails" aria-label="Back">
                <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            </button>

            <div class="cam-fs-status-wrap">
                <div class="cam-fs-status-dot"></div>
                <span class="cam-fs-status-text" id="cameraStatusText">Starting camera…</span>
            </div>

            <div class="cam-fs-counter">
                <span id="captureCount">0</span><sub>/10</sub>
            </div>
        </div>

        @* ── Guide pill (center) *@
        <p class="cam-fs-guide-pill" id="enrollGuidePrompt">
            <i class="fa-solid fa-circle-dot"></i> Position your face in the frame
        </p>

        @* ── Bottom HUD *@
        <div class="cam-fs-bottom">

            @* Anti-spoof bar *@
            <div class="cam-fs-antiSpoof">
                <span class="cam-fs-antiSpoof-label">Anti-spoof</span>
                <div class="cam-fs-antiSpoof-track">
                    <div class="cam-fs-antiSpoof-fill" id="antiSpoofBar"></div>
                </div>
                <span class="cam-fs-antiSpoof-pct" id="antiSpoofText">0%</span>
            </div>

            @* 10 capture-progress dots (matches MAX_FRAMES = 10 in mobile-enroll-page.js) *@
            <div class="cam-fs-dots">
                <div class="cam-fs-dot" id="enDot0"></div>
                <div class="cam-fs-dot" id="enDot1"></div>
                <div class="cam-fs-dot" id="enDot2"></div>
                <div class="cam-fs-dot" id="enDot3"></div>
                <div class="cam-fs-dot" id="enDot4"></div>
                <div class="cam-fs-dot" id="enDot5"></div>
                <div class="cam-fs-dot" id="enDot6"></div>
                <div class="cam-fs-dot" id="enDot7"></div>
                <div class="cam-fs-dot" id="enDot8"></div>
                <div class="cam-fs-dot" id="enDot9"></div>
            </div>

            <p class="cam-fs-hint">Hold still &amp; look directly at the camera</p>
        </div>

        @* Hidden progress bar (kept for JS compatibility in enrollment-core.js) *@
        <div id="captureProgress" style="display:none"></div>

    </div>
</div>

@* ═══════════════════════════════════════════════════════════
   STEP 3 — Review and submit  (unchanged)
   ═══════════════════════════════════════════════════════════ *@
<div class="wizard-pane" id="step3">
    <div class="hint-box">Review your details before sending the enrollment request.</div>
    <div class="form-section">
        <div class="review-grid">
            <div class="review-item">
                <div class="review-label">Employee ID</div>
                <div class="review-value" id="reviewEmployeeId">-</div>
            </div>
            <div class="review-item">
                <div class="review-label">Full Name</div>
                <div class="review-value" id="reviewFullName">-</div>
            </div>
            <div class="review-item">
                <div class="review-label">Position / Department</div>
                <div class="review-value" id="reviewPositionDepartment">-</div>
            </div>
            <div class="review-item">
                <div class="review-label">Office</div>
                <div class="review-value" id="reviewOffice">-</div>
            </div>
            <div class="review-item">
                <div class="review-label">Face Samples</div>
                <div class="review-value" id="reviewSampleCount">0 / 10</div>
            </div>
        </div>
        <div class="status-bar success" id="reviewStatus">Ready to submit</div>
    </div>
    <div class="wizard-actions">
        <button type="button" class="btn btn-primary" id="submitBtn">
            <i class="fa-solid fa-paper-plane me-2"></i>Submit Enrollment
        </button>
        <button type="button" class="btn btn-secondary" id="btnBackToCapture">
            <i class="fa-solid fa-arrow-left me-2"></i>Re-capture Face
        </button>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/fa-core")
    @Scripts.Render("~/bundles/enrollment")
    @Scripts.Render("~/bundles/mobile-enroll-page")
}
