@{
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
    ViewBag.Title = "Device Registration";
}

@section styles {
    <style>
        .header { 
            text-align: center;
            margin-bottom: 40px; 
            margin-top: 40px;
        }
        .logo { 
            font-size: 48px; 
            color: var(--accent-primary); 
            margin-bottom: 16px; 
            text-align: center;
        }
        .title { 
            font-size: 24px; 
            font-weight: 600; 
            margin-bottom: 8px; 
            text-align: center;
        }
        .subtitle { 
            color: var(--text-secondary); 
            font-size: 14px; 
            text-align: center;
        }
        
        .choices { 
            display: flex; 
            flex-direction: column; 
            gap: 16px; 
        }
        
        .choice-card {
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid var(--border-subtle);
            border-radius: 16px;
            padding: 24px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            color: inherit;
            display: block;
        }
        
        .choice-card:hover, .choice-card:active {
            border-color: var(--accent-primary);
            background: rgba(59, 130, 246, 0.1);
            transform: translateY(-2px);
        }
        
        .choice-icon { 
            font-size: 48px; 
            margin-bottom: 16px; 
            display: block; 
            text-align: center;
        }
        .choice-card.new .choice-icon { color: var(--accent-success); }
        .choice-card.existing .choice-icon { color: var(--accent-warning); }
        .choice-title { 
            font-size: 18px; 
            font-weight: 600; 
            margin-bottom: 8px; 
            text-align: center;
        }
        .choice-desc { 
            color: var(--text-muted); 
            font-size: 14px; 
            line-height: 1.5; 
            text-align: center;
        }
        
        .footer { 
            margin-top: 40px; 
            color: var(--text-muted); 
            font-size: 12px; 
            text-align: center;
        }
        
        .back-link {
            color: var(--text-secondary);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 20px;
            font-size: 14px;
        }
        .back-link:hover { color: var(--accent-primary); }
    </style>
}

<div class="header">
    <div class="logo"><i class="fa-solid fa-mobile-screen-button"></i></div>
    <h1 class="title">Device Registration</h1>
    <p class="subtitle">Register your mobile device for Face Attendance</p>
</div>

<div class="choices">
    @* Use explicit route URLs to ensure they don't get routed to Admin area *@
    <a href="/MobileRegistration/Enroll" class="choice-card new">
        <span class="choice-icon"><i class="fa-solid fa-user-plus"></i></span>
        <div class="choice-title">New Employee</div>
        <div class="choice-desc">I'm a new employee and need to enroll my face first</div>
    </a>
    
    <a href="/MobileRegistration/Identify" class="choice-card existing">
        <span class="choice-icon"><i class="fa-solid fa-user-check"></i></span>
        <div class="choice-title">Existing Employee</div>
        <div class="choice-desc">I already work here and want to register this device</div>
    </a>
</div>

<a href="/" class="back-link">
    <i class="fa-solid fa-arrow-left"></i> Back to Kiosk
</a>

<div class="footer">One device per employee limit applies</div>
