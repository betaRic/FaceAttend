@{
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
    ViewBag.Title = "Public Attendance Scan";
}

@section styles {
    @Styles.Render("~/Content/fa-system")
    @Styles.Render("~/Content/fa-mobile")
    <style>
        .identify-camera {
            position: relative;
            width: 100%;
            aspect-ratio: 4/3;
            max-width: 480px;
            margin: 0 auto;
            border-radius: var(--radius-lg);
            overflow: hidden;
            background: #000;
            border: 3px solid var(--border-default);
            transition: border-color 0.3s ease;
        }
        
        .identify-camera video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scaleX(-1);
        }
        
        /* Face bounding box overlay */
        .face-overlay {
            position: absolute;
            border: 3px solid #3b82f6;
            border-radius: 8px;
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.5), inset 0 0 20px rgba(59, 130, 246, 0.2);
            transition: all 0.1s ease;
            pointer-events: none;
            display: none;
        }
        
        .face-overlay.active {
            display: block;
            animation: pulse-border 1.5s ease-in-out infinite;
        }
        
        .face-overlay.scanning {
            border-color: #f59e0b;
            box-shadow: 0 0 20px rgba(245, 158, 11, 0.5), inset 0 0 20px rgba(245, 158, 11, 0.2);
        }
        
        .face-overlay.success {
            border-color: #22c55e;
            box-shadow: 0 0 20px rgba(34, 197, 94, 0.5), inset 0 0 20px rgba(34, 197, 94, 0.2);
        }
        
        @@keyframes pulse-border {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.02); }
        }
        
        .identify-camera.scanning {
            border-color: var(--color-primary);
        }
        
        .identify-camera.success {
            border-color: var(--color-success);
        }
        
        .identify-camera.error {
            border-color: var(--color-error);
            animation: shake 0.5s ease-in-out;
        }
        
        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }
        
        .camera-status {
            position: absolute;
            top: 12px;
            left: 50%;
            transform: translateX(-50%);
            padding: 8px 16px;
            border-radius: 9999px;
            font-size: 0.875rem;
            font-weight: 600;
            text-transform: uppercase;
            background: rgba(0,0,0,0.7);
            color: white;
            backdrop-filter: blur(4px);
            transition: all 0.3s ease;
            z-index: 10;
        }
        
        .camera-status.ready { background: rgba(34, 197, 94, 0.9); }
        .camera-status.scanning { background: rgba(59, 130, 246, 0.9); }
        .camera-status.identified { background: rgba(34, 197, 94, 0.9); }
        .camera-status.error { background: rgba(239, 68, 68, 0.9); }
        .camera-status.retrying { background: rgba(245, 158, 11, 0.9); }
        
        .scan-overlay {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0,0,0,0.5);
            opacity: 0;
            transition: opacity 0.3s;
            z-index: 5;
        }
        
        .scan-overlay.active {
            opacity: 1;
        }
        
        .scan-spinner {
            width: 48px;
            height: 48px;
            border: 4px solid rgba(255,255,255,0.2);
            border-top-color: var(--color-primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        
        @@keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        .corner-markers {
            position: absolute;
            inset: 20px;
            pointer-events: none;
            z-index: 2;
        }
        
        .corner {
            position: absolute;
            width: 30px;
            height: 30px;
            border-color: rgba(255,255,255,0.5);
            border-style: solid;
            border-width: 0;
        }
        
        .corner.top-left { top: 0; left: 0; border-top-width: 3px; border-left-width: 3px; }
        .corner.top-right { top: 0; right: 0; border-top-width: 3px; border-right-width: 3px; }
        .corner.bottom-left { bottom: 0; left: 0; border-bottom-width: 3px; border-left-width: 3px; }
        .corner.bottom-right { bottom: 0; right: 0; border-bottom-width: 3px; border-right-width: 3px; }
        
        .result-section {
            margin-top: 1.5rem;
            animation: slideUp 0.3s ease;
        }
        
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .employee-details-list {
            margin-top: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .retry-counter {
            position: absolute;
            bottom: 12px;
            right: 12px;
            background: rgba(0,0,0,0.6);
            color: white;
            padding: 4px 10px;
            border-radius: 9999px;
            font-size: 0.75rem;
            z-index: 10;
        }
    </style>
}

<div class="text-center mb-4">
    <h1 class="mobile-title"><i class="fa-solid fa-fingerprint me-2"></i>Face Attendance</h1>
    <p class="mobile-subtitle">Scan once to record attendance</p>
</div>

@Html.AntiForgeryToken()

<!-- Camera Section -->
<div class="identify-camera" id="cameraContainer">
    <video id="cameraVideo" autoplay playsinline muted></video>
    
    <!-- Face bounding box overlay -->
    <div class="face-overlay" id="faceOverlay"></div>
    
    <!-- Corner markers -->
    <div class="corner-markers">
        <div class="corner top-left"></div>
        <div class="corner top-right"></div>
        <div class="corner bottom-left"></div>
        <div class="corner bottom-right"></div>
    </div>
    
    <div class="camera-status" id="cameraStatus">Initializing...</div>
    <div class="retry-counter" id="retryCounter" style="display: none;"></div>
    
    <div class="scan-overlay" id="scanOverlay">
        <div class="scan-spinner"></div>
    </div>
</div>

<!-- Result Section -->
<div class="result-section" id="resultSection" style="display: none;">
    <div class="mobile-card">
        <div class="card-body">
            <div class="mobile-employee-info">
                <div class="mobile-employee-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <div class="mobile-employee-name" id="employeeName"></div>
                <div class="employee-details-list" id="employeeDetails"></div>
            </div>
            
            <!-- Ready Message -->
            <div id="alreadyRegisteredMsg" style="display:none;" class="alert alert-success mt-3">
                <i class="fa-solid fa-circle-check me-2"></i>
                Attendance recorded. You may view your monthly record.
            </div>
            
            <!-- Actions -->
            <div class="d-grid gap-2 mt-4">
                <button type="button" class="mobile-btn mobile-btn-success" id="continueBtn">
                    <i class="fa-solid fa-arrow-right"></i> View Attendance
                </button>
                <button type="button" class="mobile-btn mobile-btn-secondary" id="retryBtn" style="display: none;">
                    <i class="fa-solid fa-rotate-right"></i> Try Again
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Back Link -->
<div class="text-center mt-4">
    <a href="/MobileRegistration" class="mobile-back-link">
        <i class="fa-solid fa-arrow-left"></i> Back
    </a>
</div>

@section scripts {
    @Scripts.Render("~/bundles/fa-core")
    
    <script>
        (function() {
            'use strict';
            
            const video = document.getElementById('cameraVideo');
            const cameraContainer = document.getElementById('cameraContainer');
            const cameraStatus = document.getElementById('cameraStatus');
            const scanOverlay = document.getElementById('scanOverlay');
            const faceOverlay = document.getElementById('faceOverlay');
            const retryCounter = document.getElementById('retryCounter');
            const resultSection = document.getElementById('resultSection');
            const continueBtn = document.getElementById('continueBtn');
            const retryBtn = document.getElementById('retryBtn');
            
            let identifiedEmployeeId = null;
            let scanAttempts = 0;
            const maxAttempts = 10;
            let isScanning = false;
            let detectionInterval = null;
            let stream = null;
            let locationFix = null;
            
            function setStatus(status, text) {
                cameraStatus.className = 'camera-status ' + status;
                cameraStatus.textContent = text;
            }
            
            function updateRetryCounter() {
                if (scanAttempts > 0) {
                    retryCounter.textContent = `Attempt ${scanAttempts}/${maxAttempts}`;
                    retryCounter.style.display = 'block';
                } else {
                    retryCounter.style.display = 'none';
                }
            }

            async function getLocationFix() {
                if (locationFix && locationFix.capturedAt && (Date.now() - locationFix.capturedAt) < 30000) {
                    return locationFix;
                }

                if (!navigator.geolocation) {
                    return null;
                }

                setStatus('ready', 'Checking location');

                return new Promise(resolve => {
                    navigator.geolocation.getCurrentPosition(function(pos) {
                        locationFix = {
                            lat: pos.coords.latitude,
                            lon: pos.coords.longitude,
                            accuracy: pos.coords.accuracy,
                            capturedAt: Date.now()
                        };
                        resolve(locationFix);
                    }, function() {
                        resolve(null);
                    }, {
                        enableHighAccuracy: true,
                        timeout: 10000,
                        maximumAge: 30000
                    });
                });
            }
            
            function renderEmployeeDetails(data) {
                const container = document.getElementById('employeeDetails');
                container.innerHTML = '';
                
                const items = [
                    { icon: 'fa-briefcase', text: data.position },
                    { icon: 'fa-building', text: data.department },
                    { icon: 'fa-location-dot', text: data.office }
                ].filter(item => item.text && String(item.text).trim());
                
                items.forEach(item => {
                    const row = document.createElement('div');
                    row.className = 'mobile-meta-row';
                    row.innerHTML = `<i class="fa-solid ${item.icon}"></i><span>${item.text}</span>`;
                    container.appendChild(row);
                });
            }
            
            // MIGRATED: Use FaceAttend.Camera instead of direct getUserMedia
            async function initCamera() {
                try {
                    // Use unified FaceAttend.Camera
                    FaceAttend.Camera.start(video, {
                        width: { ideal: 640 },
                        height: { ideal: 480 },
                        facingMode: 'user'
                    }, function(startedStream) {
                        stream = startedStream;
                        setStatus('ready', 'Look at camera');
                        
                        // Start scanning after short delay
                        setTimeout(startIdentification, 1000);
                    }, function(error) {
                        console.error('Camera error:', error);
                        setStatus('error', 'Camera failed');
                        if (typeof MobileSwal !== 'undefined') {
                            MobileSwal.error('Camera Access Required', 'Please allow camera access to identify yourself.');
                        }
                    });
                    
                } catch (err) {
                    console.error('Camera error:', err);
                    setStatus('error', 'Camera error');
                    if (typeof MobileSwal !== 'undefined') {
                        MobileSwal.error('Camera Error', 'Could not initialize camera. Please try again.');
                    }
                }
            }
            
            // SIMPLIFIED: Single-frame capture aligned with desktop kiosk
            // Uses same proven approach - let server handle face detection
            async function captureFrame() {
                const video = FaceAttend.Camera.getVideo ? FaceAttend.Camera.getVideo() : document.querySelector('video');
                const w = video ? video.videoWidth : 640;
                const h = video ? video.videoHeight : 480;
                const canvas = FaceAttend.Camera.capture(w, h);
                if (!canvas) return null;
                
                return new Promise(resolve => {
                    canvas.toBlob(blob => resolve(blob), 'image/jpeg', 0.90);
                });
            }
            
            async function startIdentification() {
                if (isScanning) return;
                
                // Check max attempts
                if (scanAttempts >= maxAttempts) {
                    setStatus('error', 'Max attempts reached');
                    cameraContainer.classList.add('error');
                    
                    const result = typeof MobileSwal !== 'undefined' 
                        ? await MobileSwal.confirm(
                            'Not Recognized',
                            'Could not identify after ' + maxAttempts + ' attempts. Try again?',
                            'Try Again',
                            'Back'
                        )
                        : { isConfirmed: confirm('Not recognized. Try again?') };
                    
                    if (result.isConfirmed) {
                        resetAndRetry();
                    } else {
                        retryBtn.style.display = 'block';
                    }
                    return;
                }
                
                isScanning = true;
                scanAttempts++;
                updateRetryCounter();
                
                cameraContainer.classList.add('scanning');
                faceOverlay.classList.add('scanning');
                scanOverlay.classList.add('active');
                setStatus('scanning', 'Scanning...');
                
                try {
                    const gps = await getLocationFix();
                    if (!gps) {
                        throw { code: 'GPS_REQUIRED' };
                    }

                    // SIMPLIFIED: Single frame capture - same as desktop kiosk
                    // Server uses FastScanPipeline for fast face detection
                    const blob = await captureFrame();
                    
                    if (!blob) {
                        throw new Error('No frame captured');
                    }
                    
                    const formData = new FormData();
                    formData.append('image', blob, 'frame.jpg');
                    formData.append('lat', gps.lat);
                    formData.append('lon', gps.lon);
                    formData.append('accuracy', gps.accuracy);
                    formData.append('__RequestVerificationToken', 
                        document.querySelector('input[name="__RequestVerificationToken"]').value);

                    const headers = window.FaceAttend && FaceAttend.Utils
                        ? FaceAttend.Utils.mergeRequestHeaders()
                        : {};

                    const response = await fetch('/Attendance/Scan', {
                        method: 'POST',
                        headers: headers,
                        body: formData
                    });
                    
                    const raw = await response.json();
                    const data = raw && raw.ok && raw.data ? 
                        Object.assign({ ok: raw.ok, message: raw.message || null }, raw.data) : raw;
                    
                    cameraContainer.classList.remove('scanning');
                    faceOverlay.classList.remove('scanning');
                    scanOverlay.classList.remove('active');
                    
                    if (data.ok) {
                        onAttendanceSuccess(data);
                    } else {
                        onIdentificationError(data);
                    }
                } catch (err) {
                    console.error('Scan error:', err);
                    onIdentificationError(err && err.code === 'GPS_REQUIRED'
                        ? { error: 'GPS_REQUIRED', message: 'Location access is required for public attendance.' }
                        : { error: 'NETWORK_ERROR' });
                } finally {
                    isScanning = false;
                }
            }
            
            function onAttendanceSuccess(data) {
                identifiedEmployeeId = data.employeeId;
                cameraContainer.classList.add('success');
                faceOverlay.classList.add('success');
                setStatus('identified', 'Recorded');
                
                document.getElementById('employeeName').textContent = data.displayName || data.name || data.employeeId || 'Employee';
                renderEmployeeDetails({
                    position: data.eventType ? ('Attendance: ' + data.eventType) : '',
                    department: data.message,
                    office: data.officeName
                });
                
                const alreadyRegistered   = document.getElementById('alreadyRegisteredMsg');
                const continueBtn         = document.getElementById('continueBtn');

                if (alreadyRegistered) alreadyRegistered.style.display = 'block';
                if (continueBtn) {
                    continueBtn.textContent = 'View Attendance';
                    continueBtn.onclick = function() {
                        const access = data.attendanceAccess || {};
                        window.location.href = access.recordUrl || '/Attendance/MyMonth';
                    };
                }
                
                resultSection.style.display = 'block';
                resultSection.scrollIntoView({ behavior: 'smooth' });
                
                if (typeof MobileSwal !== 'undefined') {
                    MobileSwal.success('Recorded!', data.message || 'Attendance recorded.');
                }
            }
            
            function onIdentificationError(data) {
                cameraContainer.classList.remove('scanning');
                faceOverlay.classList.remove('scanning');
                scanOverlay.classList.remove('active');
                
                const transientErrors = ['NOT_RECOGNIZED', 'NO_FACE', 'ENCODING_FAIL', 'NETWORK_ERROR', 'IMAGE_LOAD_FAIL'];
                if (transientErrors.includes(data.error)) {
                    // Silent retry — transient errors that are worth retrying automatically
                    cameraContainer.classList.add('error');
                    faceOverlay.classList.remove('active');
                    setStatus('retrying', 'Retrying...');

                    setTimeout(() => {
                        cameraContainer.classList.remove('error');
                        startIdentification();
                    }, 800);
                } else {
                    // Non-transient errors (INVALID_STATUS, SERVER_ERROR, etc.)
                    if (typeof MobileSwal !== 'undefined') {
                        MobileSwal.error('Identification Failed', data.message || 'Please try again.');
                    }
                    retryBtn.style.display = 'block';
                }
            }
            
            function resetAndRetry() {
                scanAttempts = 0;
                updateRetryCounter();
                retryBtn.style.display = 'none';
                cameraContainer.classList.remove('success', 'error');
                faceOverlay.classList.remove('success');
                resultSection.style.display = 'none';
                setStatus('ready', 'Look at camera');
                startIdentification();
            }
            
            retryBtn.addEventListener('click', resetAndRetry);
            
            continueBtn.addEventListener('click', () => {
                if (identifiedEmployeeId) {
                    window.location.href = '/Attendance/MyMonth';
                }
            });
            
            // Cleanup on page unload
            window.addEventListener('beforeunload', () => {
                FaceAttend.Camera.stop();
            });
            
            // Initialize
            initCamera();
        })();
    </script>
}
