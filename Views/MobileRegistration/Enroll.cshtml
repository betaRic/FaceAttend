@{
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
    ViewBag.Title = "Face Enrollment";
}

@section styles {
    @Styles.Render("~/Content/fa-system")
    @Styles.Render("~/Content/fa-mobile")
    <style>
        /* Mobile wizard styles */
        .wizard-steps {
            display: flex; align-items: center; gap: 10px; margin-bottom: 20px;
        }
        .wizard-step {
            flex: 1; text-align: center; padding: 10px 8px; border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.04);
            color: var(--text-muted); font-size: 13px; font-weight: 600;
        }
        .wizard-step.active { background: rgba(59,130,246,0.16); border-color: rgba(59,130,246,0.45); color: #fff; }
        .wizard-step.done { background: rgba(34,197,94,0.14); border-color: rgba(34,197,94,0.4); color: #dcfce7; }
        
        .wizard-pane { display: none; }
        .wizard-pane.active { display: block; animation: slideIn .25s ease; }
        @@keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .wizard-actions { display: grid; grid-template-columns: 1fr; gap: 12px; margin-top: 14px; }
        
        .hint-box {
            background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);
            color: var(--text-secondary); border-radius: 12px; padding: 12px 14px;
            margin-bottom: 16px; font-size: 14px;
        }
        .hint-box.security { background: rgba(34,197,94,0.08); border-color: rgba(34,197,94,0.2); }
        
        /* Form styles */
        .form-section { margin-bottom: 16px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        @@media (max-width: 480px) { .form-row { grid-template-columns: 1fr; } }
        
        .form-group { margin-bottom: 14px; }
        .form-group label { 
            display: block; font-size: 12px; font-weight: 600; 
            color: var(--text-secondary); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .4px;
        }
        .form-group input, .form-group select {
            width: 100%; padding: 12px 14px; border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05);
            color: var(--text-primary); font-size: 15px; transition: all .2s ease;
        }
        .form-group input:focus, .form-group select:focus {
            outline: none; border-color: rgba(59,130,246,0.5); background: rgba(255,255,255,0.08);
        }
        .form-group input.uppercase { text-transform: uppercase; }
        .form-group input.valid { border-color: var(--accent-success); }
        .form-group input.invalid { border-color: var(--accent-error); background: rgba(239,68,68,0.05); }
        
        .validation-message { font-size: 12px; margin-top: 6px; min-height: 16px; }
        .validation-message.error { color: var(--accent-error); }
        .validation-message.success { color: var(--accent-success); }
        
        .form-group label .required { color: var(--accent-error); }
        .form-group label .hint { color: var(--text-muted); font-size: 11px; font-weight: normal; text-transform: none; letter-spacing: 0; margin-left: 4px; }
        
        .security-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: var(--accent-success); margin-top: 8px; }
        
        /* Review grid */
        .review-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
        .review-item { padding: 12px 14px; border-radius: 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); }
        .review-label { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .4px; }
        .review-value { font-size: 15px; color: var(--text-primary); word-break: break-word; }
        
        /* Mobile enrollment component overrides */
        .enroll-container { max-width: 100%; }
        .enroll-camera-wrap { aspect-ratio: 4/3; border-radius: 16px; }
        .enroll-angle-guidance { font-size: 14px; padding: 10px 16px; }
        .enroll-diversity { gap: 8px; }
        .enroll-diversity-dot { width: 10px; height: 10px; }
        .enroll-progress-wrap { padding: 12px; }
        
        /* Status bar */
        .status-bar {
            padding: 12px 16px; border-radius: 12px; text-align: center;
            font-size: 14px; font-weight: 500; margin-top: 12px;
        }
        .status-bar.waiting { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
        .status-bar.success { background: rgba(34,197,94,0.1); color: #34d399; border: 1px solid rgba(34,197,94,0.2); }
        .status-bar.error { background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
    </style>
}

<div class="header">
    <h1><i class="fa-solid fa-camera"></i> Face Enrollment</h1>
    <p>Complete your details, capture your face, then submit for approval</p>
</div>

@Html.AntiForgeryToken()
<input type="hidden" id="successUrl" value="/MobileRegistration/Success" />

<div class="wizard-steps" id="wizardSteps">
    <div class="wizard-step active" data-step="1">1. Details</div>
    <div class="wizard-step" data-step="2">2. Capture</div>
    <div class="wizard-step" data-step="3">3. Review</div>
</div>

@* Step 1: Details *@
<div class="wizard-pane active" id="step1">
    <div class="form-section">
        <div class="form-group">
            <label>Employee ID <span class="required">*</span> <span class="hint">(Format: DILG-YYYY-###)</span></label>
            <input type="text" id="employeeId" class="uppercase" placeholder="e.g., DILG-2024-001" required maxlength="20" autocomplete="off" />
            <div class="validation-message" id="employeeIdValidation"></div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>First Name <span class="required">*</span> <span class="hint">(Letters only)</span></label>
                <input type="text" id="firstName" class="uppercase" required maxlength="50" autocomplete="given-name" />
                <div class="validation-message" id="firstNameValidation"></div>
            </div>
            <div class="form-group">
                <label>Last Name <span class="required">*</span> <span class="hint">(Letters only)</span></label>
                <input type="text" id="lastName" class="uppercase" required maxlength="50" autocomplete="family-name" />
                <div class="validation-message" id="lastNameValidation"></div>
            </div>
        </div>

        <div class="form-group">
            <label>Middle Name <span class="hint">(Optional, letters only)</span></label>
            <input type="text" id="middleName" class="uppercase" placeholder="Optional" maxlength="50" autocomplete="additional-name" />
            <div class="validation-message" id="middleNameValidation"></div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Position <span class="required">*</span></label>
                <input type="text" id="position" class="uppercase" required maxlength="100" autocomplete="organization-title" />
                <div class="validation-message" id="positionValidation"></div>
            </div>
            <div class="form-group">
                <label>Department <span class="required">*</span></label>
                <input type="text" id="department" class="uppercase" required maxlength="100" autocomplete="organization" />
                <div class="validation-message" id="departmentValidation"></div>
            </div>
        </div>

        <div class="form-group">
            <label>Office <span class="required">*</span></label>
            <select id="officeId" required>
                <option value="">Select Office</option>
                @foreach (var office in ViewBag.Offices)
                {
                    <option value="@office.Id">@office.Name</option>
                }
            </select>
            <div class="validation-message" id="officeIdValidation"></div>
        </div>

        <div class="form-group">
            <label>Device Name <span class="required">*</span> <span class="hint">(e.g., MY IPHONE 15)</span></label>
            <input type="text" id="deviceName" class="uppercase" value="MY PHONE" required maxlength="50" autocomplete="off" />
            <div class="validation-message" id="deviceNameValidation"></div>
        </div>

        <div class="security-badge">
            <i class="fa-solid fa-lock"></i> 
            <span>Form protected by anti-XSS validation</span>
        </div>
    </div>

    <div class="wizard-actions">
        <button type="button" class="btn btn-primary" id="btnToCapture" disabled>
            <i class="fa-solid fa-arrow-right"></i> Continue to Face Capture
        </button>
        <a href="/MobileRegistration" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back
        </a>
    </div>
</div>

@* Step 2: Capture - Using Unified Enrollment Component *@
<div class="wizard-pane" id="step2">
    <div class="hint-box">
        <i class="fa-solid fa-circle-info"></i> 
        <strong>10 Face Samples Required.</strong> Follow the angle prompts for best coverage: center, left, right, up, and back to center.
    </div>

    @Html.Partial("~/Views/Shared/_EnrollmentComponent.cshtml", new ViewDataDictionary {
        ["EmployeeId"]        = "",
        ["ScanUrl"]           = "/api/scan/frame",
        ["EnrollUrl"]         = "/api/enrollment/enroll",
        ["RedirectUrl"]       = "",
        ["Mode"]              = "mobile",
        ["MinFrames"]         = 10,
        ["MaxFrames"]         = 10,
        ["LivenessThreshold"] = 0.75f
    })

    <div class="wizard-actions">
        <button type="button" class="btn btn-primary" id="btnToReview" disabled>
            <i class="fa-solid fa-arrow-right"></i> Review and Submit
        </button>
        <button type="button" class="btn btn-secondary" id="btnBackToDetails">
            <i class="fa-solid fa-arrow-left"></i> Back to Details
        </button>
    </div>
</div>

@* Step 3: Review *@
<div class="wizard-pane" id="step3">
    <div class="hint-box">Review your details before sending the enrollment request.</div>

    <div class="form-section">
        <div class="review-grid">
            <div class="review-item">
                <div class="review-label">Employee ID</div>
                <div class="review-value" id="reviewEmployeeId">-</div>
            </div>
            <div class="review-item">
                <div class="review-label">Full Name</div>
                <div class="review-value" id="reviewFullName">-</div>
            </div>
            <div class="review-item">
                <div class="review-label">Position / Department</div>
                <div class="review-value" id="reviewPositionDepartment">-</div>
            </div>
            <div class="review-item">
                <div class="review-label">Office</div>
                <div class="review-value" id="reviewOffice">-</div>
            </div>
            <div class="review-item">
                <div class="review-label">Device Name</div>
                <div class="review-value" id="reviewDeviceName">-</div>
            </div>
            <div class="review-item">
                <div class="review-label">Face Samples</div>
                <div class="review-value" id="reviewSampleCount">0 / 10</div>
            </div>
        </div>

        <div class="status-bar success" id="reviewStatus">Ready to submit</div>
    </div>

    <div class="wizard-actions">
        <button type="button" class="btn btn-primary" id="submitBtn">
            <i class="fa-solid fa-paper-plane"></i> Submit Enrollment
        </button>
        <button type="button" class="btn btn-secondary" id="btnBackToCapture">
            <i class="fa-solid fa-arrow-left"></i> Back to Capture
        </button>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/enrollment")
    
    <script>
        (function () {
            'use strict';

            // Match CONSTANTS.CAPTURE_TARGET in enrollment-core.js.
            // Previously 10 — enrollment-core fires onReadyToConfirm at 8
            // (CAPTURE_TARGET), so requiring 10 here caused an infinite loop
            // where the component completed at 8 but the wizard rejected it.
            var MAX_FRAMES = 8;

            // Validation rules
            var ValidationRules = {
                employeeId: { pattern: /^[A-Z0-9 .\-]+$/, minLength: 2, maxLength: 50, message: 'Employee ID contains invalid characters' },
                name: { pattern: /^[A-Z .\-',]+$/, minLength: 1, maxLength: 100, message: 'Name contains invalid characters' },
                middleName: { pattern: /^[A-Z .\-',]*$/, maxLength: 100, message: 'Middle name contains invalid characters' },
                position: { pattern: /^[A-Z0-9 .\-/(),&#]+$/, minLength: 1, maxLength: 150, message: 'Position contains invalid characters' },
                department: { pattern: /^[A-Z0-9 .\-/(),&]+$/, minLength: 1, maxLength: 150, message: 'Department contains invalid characters' },
                deviceName: { pattern: /^[A-Z0-9 .@_-]+$/, minLength: 2, maxLength: 100, message: 'Device name contains invalid characters' }
            };

            // DOM refs
            var els = {
                btnToCapture: document.getElementById('btnToCapture'),
                btnToReview: document.getElementById('btnToReview'),
                btnBackToDetails: document.getElementById('btnBackToDetails'),
                btnBackToCapture: document.getElementById('btnBackToCapture'),
                submitBtn: document.getElementById('submitBtn'),
                employeeId: document.getElementById('employeeId'),
                firstName: document.getElementById('firstName'),
                middleName: document.getElementById('middleName'),
                lastName: document.getElementById('lastName'),
                position: document.getElementById('position'),
                department: document.getElementById('department'),
                officeId: document.getElementById('officeId'),
                deviceName: document.getElementById('deviceName'),
                reviewEmployeeId: document.getElementById('reviewEmployeeId'),
                reviewFullName: document.getElementById('reviewFullName'),
                reviewPositionDepartment: document.getElementById('reviewPositionDepartment'),
                reviewOffice: document.getElementById('reviewOffice'),
                reviewDeviceName: document.getElementById('reviewDeviceName'),
                reviewSampleCount: document.getElementById('reviewSampleCount'),
                reviewStatus: document.getElementById('reviewStatus'),
                submitUrl: '/MobileRegistration/SubmitEnrollment',
                successUrl: document.getElementById('successUrl').value
            };

            // State
            var state = {
                step: 1,
                capturedFrames: [],
                validationState: { employeeId: false, firstName: false, lastName: false, middleName: true, position: false, department: false, officeId: false, deviceName: false }
            };

            // Validation functions
            function validateField(element, rule, validationId) {
                var value = element.value.toUpperCase().trim();
                var validationEl = document.getElementById(validationId);
                if (element.value !== value) element.value = value;
                if (!value) {
                    element.classList.remove('valid', 'invalid');
                    if (validationEl) validationEl.textContent = '';
                    return rule !== ValidationRules.middleName;
                }
                if (rule.minLength && value.length < rule.minLength) {
                    element.classList.add('invalid'); element.classList.remove('valid');
                    if (validationEl) { validationEl.textContent = 'Too short (min ' + rule.minLength + ' chars)'; validationEl.className = 'validation-message error'; }
                    return false;
                }
                if (rule.maxLength && value.length > rule.maxLength) {
                    element.value = value.substring(0, rule.maxLength); value = element.value;
                }
                if (rule.pattern && !rule.pattern.test(value)) {
                    element.classList.add('invalid'); element.classList.remove('valid');
                    if (validationEl) { validationEl.textContent = rule.message || 'Invalid format'; validationEl.className = 'validation-message error'; }
                    return false;
                }
                element.classList.add('valid'); element.classList.remove('invalid');
                if (validationEl) { validationEl.textContent = ''; validationEl.className = 'validation-message'; }
                return true;
            }

            function validateEmployeeId() { state.validationState.employeeId = validateField(els.employeeId, ValidationRules.employeeId, 'employeeIdValidation'); }
            function validateFirstName() { state.validationState.firstName = validateField(els.firstName, ValidationRules.name, 'firstNameValidation'); }
            function validateLastName() { state.validationState.lastName = validateField(els.lastName, ValidationRules.name, 'lastNameValidation'); }
            function validateMiddleName() { 
                var value = els.middleName.value.toUpperCase().trim();
                els.middleName.value = value;
                if (!value) { els.middleName.classList.remove('valid', 'invalid'); document.getElementById('middleNameValidation').textContent = ''; state.validationState.middleName = true; return; }
                state.validationState.middleName = validateField(els.middleName, ValidationRules.middleName, 'middleNameValidation');
            }
            function validatePosition() { state.validationState.position = validateField(els.position, ValidationRules.position, 'positionValidation'); }
            function validateDepartment() { state.validationState.department = validateField(els.department, ValidationRules.department, 'departmentValidation'); }
            function validateOfficeId() { state.validationState.officeId = !!els.officeId.value; if (els.officeId.value) { els.officeId.classList.add('valid'); els.officeId.classList.remove('invalid'); } else { els.officeId.classList.remove('valid', 'invalid'); } document.getElementById('officeIdValidation').textContent = ''; }
            function validateDeviceName() { state.validationState.deviceName = validateField(els.deviceName, ValidationRules.deviceName, 'deviceNameValidation'); }

            function allFieldsValid() {
                return state.validationState.employeeId && state.validationState.firstName && state.validationState.lastName &&
                       state.validationState.middleName && state.validationState.position && state.validationState.department &&
                       state.validationState.officeId && state.validationState.deviceName;
            }

            function updateContinueButton() { els.btnToCapture.disabled = !allFieldsValid(); }

            function setStep(step) {
                state.step = step;
                [1, 2, 3].forEach(function (n) {
                    var pane = document.getElementById('step' + n);
                    var stepEl = document.querySelector('.wizard-step[data-step="' + n + '"]');
                    if (pane) pane.classList.toggle('active', n === step);
                    if (stepEl) { stepEl.classList.remove('active', 'done'); if (n === step) stepEl.classList.add('active'); if (n < step) stepEl.classList.add('done'); }
                });

                if (step === 2) {
                    // Start enrollment when entering step 2
                    if (window.FaceAttendEnrollment && typeof window.FaceAttendEnrollment.start === 'function') {
                        window.FaceAttendEnrollment.start();
                    }
                } else {
                    // Stop enrollment when leaving step 2
                    if (window.FaceAttendEnrollment && typeof window.FaceAttendEnrollment.stop === 'function') {
                        window.FaceAttendEnrollment.stop();
                    }
                }

                if (step === 3) refreshReview();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            function refreshReview() {
                els.reviewEmployeeId.textContent = els.employeeId.value.toUpperCase() || '-';
                els.reviewFullName.textContent = [els.firstName.value, els.middleName.value, els.lastName.value].filter(Boolean).join(' ').toUpperCase() || '-';
                els.reviewPositionDepartment.textContent = (els.position.value.toUpperCase() || '-') + ' / ' + (els.department.value.toUpperCase() || '-');
                els.reviewOffice.textContent = els.officeId.options[els.officeId.selectedIndex]?.text || '-';
                els.reviewDeviceName.textContent = els.deviceName.value.toUpperCase() || '-';
                
                // Get actual count from FaceAttendEnrollment
                var encodings = window.FaceAttendEnrollment && typeof window.FaceAttendEnrollment.getEncodings === 'function' 
                    ? window.FaceAttendEnrollment.getEncodings() 
                    : [];
                state.capturedFrames = encodings;
                
                els.reviewSampleCount.textContent = state.capturedFrames.length + ' / 10';
                if (state.capturedFrames.length >= MAX_FRAMES) { 
                    els.reviewStatus.textContent = 'All face samples collected'; 
                    els.reviewStatus.className = 'status-bar success'; 
                }
                else { 
                    els.reviewStatus.textContent = 'Face samples incomplete'; 
                    els.reviewStatus.className = 'status-bar error'; 
                }
            }

            // Enrollment callbacks (MIGRATED: Now uses unified FaceAttend system)
            window.enrollCallbacks = {
                onCaptureProgress: function(frameCount) {
                    state.capturedFrames = new Array(frameCount);
                    els.btnToReview.disabled = frameCount < MAX_FRAMES;
                    // No popup — status bar in the component shows progress already.
                    // A Swal here interrupts the user mid-capture.
                },
                onEnrollmentComplete: function(result) {
                    state.capturedFrames = new Array(result.vectorsSaved || 10);
                    els.btnToReview.disabled = false;
                },
                onEnrollmentError: function(error) {
                    // Silent — enrollment-ui.js already writes to the status bar.
                    // No MobileSwal here; popup interrupts capture and blocks the user.
                    // The user sees the error in the status bar and capture resumes automatically.
                    if (typeof FaceAttend !== 'undefined' && FaceAttend.Notify) {
                        FaceAttend.Notify.toast(error.message || 'Scan error, retrying...', 'warning', 2000);
                    }
                },

                // FIX-002: Intercept onReadyToConfirm for the mobile wizard.
                //
                // WHY THIS IS NEEDED:
                // enrollment-ui.js fires a Swal confirmation dialog when capture
                // completes. On the admin surface, Confirm  performEnrollment()
                // which hits /api/enrollment/enroll (requires existing employee).
                // On mobile, there is NO existing employee yet  the employee is
                // created by MobileRegistrationController.SubmitEnrollment() in
                // Step 3, which includes all the form fields (name, department etc).
                //
                // Calling performEnrollment() on mobile would fail with
                // EMPLOYEE_NOT_FOUND because no employee record exists yet.
                //
                // HOW IT WORKS:
                // By defining this interceptor, enrollment-ui.js detects it and
                // returns early WITHOUT showing the Swal. Instead, this function
                // runs and automatically advances the wizard to Step 3 (review).
                // setStep(3) calls FaceAttendEnrollment.stop() which stops the
                // camera stream. The user reviews their details in Step 3 and
                // submits via submitEnrollment() which posts all form fields +
                // face encodings to MobileRegistrationController.SubmitEnrollment.
                //
                // data.frames contains the captured frames. Encodings are retrieved
                // later via window.FaceAttendEnrollment.getEncodings() in
                // submitEnrollment()  they are stored on each goodFrame by
                // enrollment-core.js after each successful ScanFrame response.
                onReadyToConfirm: function(data) {
                    // Capture is complete. Automatically move to review step.
                    // setStep(3) handles stopping the camera (leaves step 2).
                    setStep(3);
                }
            };

            async function submitEnrollment() {
                if (!allFieldsValid()) { 
                    if (typeof MobileSwal !== 'undefined') MobileSwal.warning('Validation Error', 'Please correct all form fields.'); 
                    setStep(1); 
                    return; 
                }
                
                // Get actual encodings from FaceAttendEnrollment
                var encodings = window.FaceAttendEnrollment && typeof window.FaceAttendEnrollment.getEncodings === 'function' 
                    ? window.FaceAttendEnrollment.getEncodings() 
                    : [];
                    
                if (encodings.length < MAX_FRAMES) { 
                    if (typeof MobileSwal !== 'undefined') MobileSwal.warning('Incomplete', 'Please complete all 10 face samples.'); 
                    setStep(2); 
                    return; 
                }

                var confirmResult = typeof MobileSwal !== 'undefined' 
                    ? await MobileSwal.confirm('Submit Enrollment?', 'Your registration will be sent for admin approval.', 'Yes, Submit', 'Review Again') 
                    : { isConfirmed: confirm('Submit enrollment?') };
                    
                if (!confirmResult.isConfirmed) return;

                els.submitBtn.disabled = true;
                els.submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Submitting...';

                var formData = new FormData();
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                formData.append('EmployeeId', els.employeeId.value.toUpperCase().replace(/</g, '').replace(/>/g, ''));
                formData.append('FirstName', els.firstName.value.toUpperCase().replace(/</g, '').replace(/>/g, ''));
                formData.append('MiddleName', els.middleName.value.toUpperCase().replace(/</g, '').replace(/>/g, ''));
                formData.append('LastName', els.lastName.value.toUpperCase().replace(/</g, '').replace(/>/g, ''));
                formData.append('Position', els.position.value.toUpperCase().replace(/</g, '').replace(/>/g, ''));
                formData.append('Department', els.department.value.toUpperCase().replace(/</g, '').replace(/>/g, ''));
                formData.append('OfficeId', els.officeId.value);
                formData.append('DeviceName', els.deviceName.value.toUpperCase().replace(/</g, '').replace(/>/g, ''));

                // Get encodings from enrollment component
                formData.append('AllFaceEncodingsJson', JSON.stringify(encodings));
                formData.append('FaceEncoding', encodings[0] || '');

                try {
                    var response = await fetch(els.submitUrl, { method: 'POST', body: formData });
                    var data = await response.json();
                    if (!data.ok) throw new Error(data.message || 'Submission failed');
                    if (typeof MobileSwal !== 'undefined') await MobileSwal.success('Enrollment Submitted', 'Your registration is pending admin approval.');
                    window.location.href = '/MobileRegistration/Success?isNewEmployee=true&employeeDbId=' + encodeURIComponent(data.employeeDbId || '');
                } catch (err) {
                    console.error(err);
                    if (typeof MobileSwal !== 'undefined') MobileSwal.error('Network Error', 'Please check your connection.');
                    els.submitBtn.disabled = false;
                    els.submitBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Submit Enrollment';
                }
            }

            // Event listeners
            ['employeeId', 'firstName', 'lastName', 'middleName', 'position', 'department', 'deviceName'].forEach(function(id) {
                var el = els[id];
                if (el) {
                    el.addEventListener('input', function() { 
                        window['validate' + id.charAt(0).toUpperCase() + id.slice(1)](); 
                        updateContinueButton(); 
                    });
                    el.addEventListener('blur', window['validate' + id.charAt(0).toUpperCase() + id.slice(1)]);
                }
            });
            els.officeId.addEventListener('change', function() { validateOfficeId(); updateContinueButton(); });

            els.btnToCapture.addEventListener('click', function () { 
                if (!allFieldsValid()) { 
                    if (typeof MobileSwal !== 'undefined') MobileSwal.warning('Validation Error', 'Please correct all form fields.'); 
                    return; 
                } 
                setStep(2); 
            });
            els.btnBackToDetails.addEventListener('click', function () { setStep(1); });
            els.btnToReview.addEventListener('click', function () { 
                var encodings = window.FaceAttendEnrollment && typeof window.FaceAttendEnrollment.getEncodings === 'function' 
                    ? window.FaceAttendEnrollment.getEncodings() 
                    : [];
                if (encodings.length < MAX_FRAMES) { 
                    if (typeof MobileSwal !== 'undefined') MobileSwal.warning('Incomplete', 'Please wait until all 10 samples are collected.'); 
                    return; 
                } 
                setStep(3); 
            });
            els.btnBackToCapture.addEventListener('click', function () { setStep(2); });
            els.submitBtn.addEventListener('click', submitEnrollment);

            // Initial validation
            validateEmployeeId(); validateFirstName(); validateLastName(); validateMiddleName();
            validatePosition(); validateDepartment(); validateOfficeId(); validateDeviceName();
            updateContinueButton();
        })();
    </script>
}
