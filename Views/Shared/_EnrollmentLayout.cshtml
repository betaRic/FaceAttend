@*
    FaceAttend Unified Enrollment Layout
    New layout using the unified design system and core modules
*@

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    
    <title>@ViewBag.Title - FaceAttend Enrollment</title>
    
    @* Anti-forgery token for JS *@
    @Html.AntiForgeryToken()
    
    @* Base styles *@
    @Styles.Render("~/Content/css")
    
    @* FaceAttend Design System v3 *@
    @Styles.Render("~/Content/fa-system")      @* Design System Tokens (v3) *@
    
    @* Enrollment and Component styles *@
    @Styles.Render("~/Content/enrollment")
    @Styles.Render("~/Content/fa-components")
    @RenderSection("styles", required: false)
</head>
<body class="enrollment-layout" data-app-base="@Url.Content("~/")">
    
    <header class="enrollment-header">
        <div class="enrollment-header__brand">
            <div class="enrollment-header__logo">
                <i class="fa-solid fa-camera text-white"></i>
            </div>
            <div>
                <h1 class="enrollment-header__title">@ViewBag.Title</h1>
                <div class="enrollment-header__subtitle">FaceAttend Enrollment System</div>
            </div>
        </div>
    </header>
    
    <main class="enrollment-main">
        @RenderBody()
    </main>
    
    <footer class="enrollment-footer">
        <p>&copy; @DateTime.Now.Year DILG Region XII. All rights reserved.</p>
    </footer>
    
    @* jQuery (if needed by legacy code) *@
    @Scripts.Render("~/bundles/jquery")
    
    @* SweetAlert2 for notifications *@
    @Scripts.Render("~/bundles/sweetalert")
    
    @* New unified core modules *@
    @Scripts.Render("~/bundles/fa-core")

    @* Enrollment modules (enrollment-core.js + enrollment-ui.js) *@
    @* Required by _EnrollmentComponent.cshtml on all surfaces that use this layout *@
    @Scripts.Render("~/bundles/enrollment")
    
    @* Page-specific scripts *@
    @RenderSection("scripts", required: false)
    
</body>
</html>
