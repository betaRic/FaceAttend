@{
    // Partial view: Layout must be null to prevent nested layout rendering
    Layout = null;
}

@*
    FaceAttend Shared Face Progress Component
    Shows diversity capture progress with angle indicators
    
    Usage:
    @Html.Partial("~/Views/Shared/Components/_FaceProgress.cshtml", new FaceProgressViewModel {
        Id = "enrollProgress",
        Label = "Angles Captured",
        Current = 0,
        Target = 5,
        Max = 10,
        Buckets = new List<string>(),
        ShowAngles = true
    })
    
    CRITICAL: This partial must NOT contain inline <script> or <style> blocks
    with Razor expressions. It is designed to be rendered from inside @section
    blocks, and Razor forbids nested script/style blocks with expressions.
*@

@model FaceAttend.Models.ViewModels.Shared.FaceProgressViewModel

@{

    var containerId = Model.Id;
    var textId = containerId + "Text";
    var barId = containerId + "Bar";
    var dotsId = containerId + "Dots";
    var anglesId = containerId + "Angles";
    
    var percentage = Model.Target > 0 
        ? Math.Min(100, (int)((Model.Current / (double)Model.Target) * 100)) 
        : 0;
}

<div class="face-progress" 
     id="@containerId"
     data-container-id="@containerId"
     data-text-id="@textId"
     data-bar-id="@barId"
     data-dots-id="@dotsId"
     data-angles-id="@anglesId"
     data-target="@Model.Target"
     data-max="@Model.Max"
     data-current="@Model.Current">
    
    @* Header with label and count *@
    <div class="face-progress__header">
        <span class="face-progress__label">@Model.Label</span>
        <span class="face-progress__count" id="@textId">
            @Model.Current / @Model.Target
        </span>
    </div>
    
    @* Progress bar *@
    <div class="progress-bar" style="margin-bottom: var(--space-3);">
        <div class="progress-bar__fill @(Model.Current >= Model.Target ? "progress-bar__fill--success" : "")" 
             id="@barId" 
             style="width: @percentage%;"></div>
    </div>
    
    @* Dots indicator *@
    @if (Model.ShowDots)
    {
        <div class="progress-dots" id="@dotsId">
            @for (int i = 0; i < Model.Max; i++)
            {
                var isActive = i < Model.Current;
                var dotClass = isActive ? "progress-dots__dot--complete" : "";
                <div class="progress-dots__dot @dotClass" data-index="@i"></div>
            }
        </div>
    }
    
    @* Angle indicators *@
    @if (Model.ShowAngles)
    {
        <div class="progress-angles" id="@anglesId">
            @{
                var angleConfig = new Dictionary<string, (string Label, string Icon)>
                {
                    ["center"] = ("Center", "fa-circle-dot"),
                    ["left"] = ("Left", "fa-arrow-left"),
                    ["right"] = ("Right", "fa-arrow-right"),
                    ["up"] = ("Up", "fa-arrow-up"),
                    ["down"] = ("Down", "fa-arrow-down")
                };
            }
            
            @foreach (var angle in angleConfig)
            {
                var isCaptured = Model.Buckets != null && Model.Buckets.Contains(angle.Key);
                var itemClass = isCaptured ? "progress-angles__item--captured" : "";
                <span class="progress-angles__item @itemClass" data-bucket="@angle.Key">
                    <i class="fa-solid @angle.Value.Icon progress-angles__icon"></i>
                    @angle.Value.Label
                </span>
            }
        </div>
    }
    
    @* Next angle prompt *@
    @if (Model.ShowNextAngle && !string.IsNullOrEmpty(Model.NextAngleLabel))
    {
        <div class="face-progress__prompt" id="@containerId-prompt">
            <i class="fa-solid @Model.NextAngleIcon"></i>
            <span>@Model.NextAngleLabel</span>
        </div>
    }
</div>
