@{
    Layout = null;
    Response.Cache.SetCacheability(System.Web.HttpCacheability.NoCache);
    Response.Cache.SetNoStore();
}
<!doctype html>
<html lang="en" data-theme="kiosk">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>DILG Region XII Face Attendance Kiosk</title>

    @Styles.Render("~/Content/css")
    @Styles.Render("~/Content/fa-system")      @* Design System Tokens (v3) *@
    @Styles.Render("~/Content/kiosk-vendor")
    @Styles.Render("~/Content/kiosk")
</head>
<body
    class="kiosk-body"
    data-app-base="@Url.Content("~/")"
    data-nextgen="true"
    data-return-url="@ViewBag.ReturnUrl"
    data-unlock-hint="@ViewBag.UnlockHint"
    data-allow-unlock="@(((bool?)ViewBag.AllowUnlock ?? false) ? "true" : "false")"
    data-org-name="DILG Region XII"
    data-org-subtitle="Face Attendance Kiosk">

    @Html.AntiForgeryToken()

    <div id="kioskRoot" data-location-state="pending" style="display: none;">

        <!-- Video Background -->
        <video id="kioskVideo" playsinline autoplay muted></video>
        <canvas id="overlayCanvas"></canvas>

        <!-- Idle Overlay -->
        <div id="idleOverlay" class="hidden" aria-hidden="true">
            <div class="idle-wrapper">
                <!-- Brand Header -->
                <div class="idle-brand">
                    <div class="idle-logo-wrap">
                        <img class="idle-logo" src="@Url.Content("~/Content/images/dilg-logo.svg")" alt="DILG" />
                    </div>
                    <div class="idle-brand-text">
                        <div class="idle-eyebrow">Department of the Interior and Local Government</div>
                        <div id="idleOrgName" class="idle-title">DILG Region XII</div>
                        <div class="idle-subtitle">Face Attendance Kiosk</div>
                    </div>
                </div>

                <!-- Main Content: Status + Map -->
                <div class="idle-content">
                    <!-- Status Card -->
                    <div class="idle-status-card">
                        <div class="status-header">
                            <span id="idlePulse" class="status-pulse" aria-hidden="true"></span>
                            <span id="idleStatusBadge" class="status-badge pending">Checking location</span>
                        </div>
                        <div id="idleLocationTitle" class="status-title">Preparing kiosk</div>
                        <div id="idleLocationSub" class="status-desc">Please wait while we verify your location</div>
                    </div>

                    <!-- Map Container (shown when location invalid) -->
                    <div id="idleMapContainer" class="idle-map-container hidden">
                        <div class="map-header">
                            <i class="fa-solid fa-location-dot"></i>
                            <span>Nearby Offices</span>
                        </div>
                        <div id="idleMap" class="idle-map"></div>
                        <div class="map-legend">
                            <div class="legend-item">
                                <span class="legend-dot you"></span>
                                <span>You are here</span>
                            </div>
                            <div class="legend-item">
                                <span class="legend-dot office"></span>
                                <span>Allowed offices</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Clock Footer -->
                <div class="idle-footer">
                    <div id="idleClock" class="idle-clock" aria-live="off">--:--:--</div>
                    <div id="idleDate" class="idle-date" aria-live="off">---</div>
                    <div id="idleHint" class="idle-hint">Look at the camera to scan</div>
                    
                    <!-- MOBILE REGISTRATION BUTTON - Only shown on mobile devices -->
                    <div id="mobileRegisterBtn" class="mobile-register-container" style="display: none; margin-top: 20px;">
                        <a href="/MobileRegistration" class="mobile-register-btn">
                            <i class="fa-solid fa-mobile-screen"></i>
                            Register This Device
                        </a>
                        <div class="mobile-register-hint">New employee? First time on this phone?</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- HUD: Top Left -->
        <div id="topLeft" class="hud-panel">
            <div class="brand">FaceAttend</div>
            <div class="sub">DILG Region XII</div>
            <div id="officeLine">Checking location...</div>
        </div>

        <!-- HUD: Top Center -->
        <div id="topCenter" class="hud-panel">
            <div id="timeLine">--:--:--</div>
            <div id="dateLine">---</div>
        </div>

        <!-- HUD: Top Right -->
        <div id="topRight" class="hud-panel">
            <div id="livenessLine" class="live-unk">Waiting</div>
            <div id="livenessBarWrap">
                <div id="livenessBarFill" class="liveness-bar-fill"></div>
            </div>
        </div>

        <!-- Center: Status Messages -->
        <div id="center">
            <div id="centerBlock" class="hidden" aria-live="polite">
                <div class="blockTitle" id="centerBlockTitle">Location required</div>
                <div class="blockSub" id="centerBlockSub">Please wait while the kiosk verifies the assigned office.</div>
            </div>
        </div>

        <!-- Bottom: Main Prompt -->
        <div id="bottom">
            <div id="bottomCenter" class="hud-panel">
                <div id="mainPrompt">Preparing kiosk</div>
                <div id="subPrompt">Please wait while the location is verified</div>
            </div>
        </div>

        @if (ViewBag.AllowUnlock == true)
        {
        <!-- Unlock Modal - Only rendered on non-mobile devices -->
        <div id="unlockBackdrop" class="kiosk-backdrop hidden" aria-hidden="true" style="z-index: 2000;">
            <div id="unlockModal" class="modal-card" role="dialog" aria-modal="true" aria-labelledby="unlockTitle">
                <div class="modal-title" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                    <span id="unlockTitle">Admin Unlock</span>
                    <button id="unlockClose" type="button" style="background:none;border:none;color:var(--text-muted);font-size:1.5rem;cursor:pointer;" aria-label="Close">&times;</button>
                </div>
                <div style="color:var(--text-secondary);font-size:0.875rem;margin-bottom:1rem;">Enter your PIN to access admin functions</div>
                <input
                    id="unlockPin"
                    class="modal-input"
                    type="password"
                    inputmode="numeric"
                    autocomplete="off"
                    placeholder="Enter PIN..."
                    style="text-align:center;letter-spacing:0.5rem;font-size:1.5rem;" />
                <div id="unlockErr" class="modal-error" role="alert"></div>
                <div class="modal-actions" style="margin-top:1.5rem;">
                    <button id="unlockCancel" type="button" class="modal-btn secondary">Cancel</button>
                    <button id="unlockSubmit" type="button" class="modal-btn primary">Unlock</button>
                </div>
            </div>
        </div>

        <!-- Unlock Success Confirmation Modal -->
        <div id="unlockSuccessBackdrop" class="kiosk-backdrop hidden" aria-hidden="true" style="z-index: 3000;">
            <div id="unlockSuccessModal" class="modal-card" role="dialog" aria-modal="true" aria-labelledby="unlockSuccessTitle">
                <div class="modal-title" style="text-align:center;margin-bottom:1rem;">
                    <div style="font-size:3rem;color:var(--success-500);margin-bottom:0.5rem;">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <span id="unlockSuccessTitle" style="font-size:1.25rem;">Unlock Successful</span>
                </div>
                <div style="color:var(--text-secondary);font-size:0.875rem;margin-bottom:1.5rem;text-align:center;">
                    You have successfully unlocked admin access.<br>
                    What would you like to do?
                </div>
                <div class="modal-actions" style="margin-top:1rem;flex-direction:column;gap:0.75rem;">
                    <button id="unlockGoAdmin" type="button" class="modal-btn primary" style="width:100%;">
                        <i class="fa-solid fa-arrow-right me-2"></i>Go to Admin Panel
                    </button>
                    <button id="unlockStayKiosk" type="button" class="modal-btn secondary" style="width:100%;">
                        <i class="fa-solid fa-desktop me-2"></i>Stay in Kiosk
                    </button>
                </div>
            </div>
        </div>
        }

        <!-- Visitor Modal -->
        <div id="visitorBackdrop" class="kiosk-backdrop hidden" aria-hidden="true" style="z-index: 2000;">
            <div id="visitorModal" class="modal-card" role="dialog" aria-modal="true" aria-labelledby="visitorTitle">
                <div class="modal-title" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                    <span id="visitorTitle">Visitor Sign-In</span>
                    <button id="visitorClose" type="button" style="background:none;border:none;color:var(--text-muted);font-size:1.5rem;cursor:pointer;" aria-label="Close">&times;</button>
                </div>
                <div style="color:var(--text-secondary);font-size:0.875rem;margin-bottom:1rem;">Enter your details to sign in as a visitor</div>

                <input
                    id="visitorName"
                    class="modal-input"
                    type="text"
                    autocomplete="name"
                    placeholder="Full name"
                    style="margin-bottom:0.75rem;" />

                <input
                    id="visitorPurpose"
                    class="modal-input"
                    type="text"
                    autocomplete="off"
                    placeholder="Reason for visit" />

                <div id="visitorErr" class="modal-error" role="alert"></div>

                <div class="modal-actions" style="margin-top:1.5rem;">
                    <button id="visitorCancel" type="button" class="modal-btn secondary">Cancel</button>
                    <button id="visitorSubmit" type="button" class="modal-btn primary">Submit</button>
                </div>
            </div>
        </div>

    </div>

    @Scripts.Render("~/bundles/jquery")
    <script type="module" src="@Url.Content("~/Scripts/vendor/mediapipe/tasks-vision/vision_loader.mjs")"></script>
    @Scripts.Render("~/bundles/kiosk-vendor")
    @Scripts.Render("~/bundles/fa-core")
    @Scripts.Render("~/bundles/kiosk")
    
    <!-- Audio Manager for Success Sounds -->
    @FaceAttend.Services.AudioManager.GetAudioManagerScript(Context)
    
    <style>
        /* Mobile Registration Button Styles */
        .mobile-register-container { animation: fadeInUp 0.5s ease; }
        .mobile-register-btn {
            display: inline-flex; align-items: center; gap: 10px;
            padding: 14px 28px;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: white; border-radius: 30px; text-decoration: none;
            font-weight: 600; font-size: 16px;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
            transition: all 0.3s ease;
        }
        .mobile-register-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(59, 130, 246, 0.5); }
        .mobile-register-hint { margin-top: 10px; font-size: 13px; color: #94a3b8; }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
    
    <script>
        // Device detection and setup
        (function() {
            var kioskRoot = document.getElementById('kioskRoot');
            var mobileRegisterBtn = document.getElementById('mobileRegisterBtn');
            
            // Show kiosk UI
            if (kioskRoot) kioskRoot.style.display = '';
            
            var ua = navigator.userAgent.toLowerCase();
            var isPhone = /iphone|android.*mobile|windows phone|iemobile|blackberry/.test(ua);
            
            // Personal phone = mobile mode, so clear kiosk override
            if (isPhone) {
                document.cookie = 'ForceKioskMode=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';

                if (mobileRegisterBtn) {
                    mobileRegisterBtn.style.display = 'none';
                }
            } else {
                // Desktop / real kiosk
                document.cookie = 'ForceKioskMode=true; path=/';
            }
        })();
    </script>
</body>
</html>
