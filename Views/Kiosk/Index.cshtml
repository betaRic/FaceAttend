@{
    Layout = null;
    Response.Cache.SetCacheability(System.Web.HttpCacheability.NoCache);
    Response.Cache.SetNoStore();
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DILG Region XII Face Attendance Kiosk</title>

    @Styles.Render("~/Content/kiosk-base")
    @Styles.Render("~/Content/kiosk-vendor")
    @Styles.Render("~/Content/kiosk")
</head>
<body
    class="kiosk-body"
    data-app-base="@Url.Content("~/")"
    data-nextgen="true"
    data-return-url="@ViewBag.ReturnUrl"
    data-unlock-hint="@ViewBag.UnlockHint"
    data-org-name="DILG Region XII"
    data-org-subtitle="Face Attendance Kiosk">

    @Html.AntiForgeryToken()

    <div id="kioskRoot" data-location-state="pending">

        <video id="kioskVideo" playsinline autoplay muted></video>
        <canvas id="overlayCanvas"></canvas>

                <div id="idleOverlay" class="hidden" aria-hidden="true">
            <div class="idle-min-shell">
                <div class="idle-min-header">
                    <div class="idle-min-brand">
                        <div class="idle-min-logo-wrap">
                            <img class="idle-min-logo" src="@Url.Content("~/Content/images/dilg-logo.svg")" alt="DILG Region XII" />
                        </div>

                        <div class="idle-min-brand-copy">
                            <div class="idle-min-eyebrow">Department of the Interior and Local Government</div>
                            <div id="idleOrgName" class="idle-min-title">DILG Region XII</div>
                            <div class="idle-min-subtitle">Face attendance kiosk</div>
                        </div>
                    </div>
                </div>

                <div class="idle-min-panel">
                    <div class="idle-min-status-row">
                        <span class="idle-min-pulse" aria-hidden="true"></span>
                        <div id="idleStatusBadge" class="idle-status-badge is-pending">Checking location</div>
                    </div>

                    <div id="idleLocationTitle" class="idle-location-title">Preparing kiosk</div>
                    <div id="idleLocationSub" class="idle-location-sub">Please wait while the kiosk verifies the current office location.</div>

                    <div class="idle-min-clock-wrap">
                        <div id="idleClock" aria-live="off">--:--:--</div>
                        <div id="idleDate" aria-live="off">---</div>
                    </div>

                    <div class="idle-min-help">Look at the camera when location is verified.</div>
                </div>
            </div>
        </div>

        <div id="topLeft">
            <div class="brand">DILG Region XII</div>
            <div class="sub">Face attendance kiosk</div>
            <div class="sub" id="officeLine">Checking location...</div>
        </div>

        <div id="topCenter">
            <div id="timeLine">--:--:--</div>
            <div id="dateLine">---</div>
        </div>

        <div id="topRight">
            <div id="livenessLine" class="live-unk">Live: --</div>
            <div id="scanEtaLine">ETA: --</div>
        </div>

        <div id="centerBlock" class="hidden" aria-live="polite">
            <div class="blockTitle" id="centerBlockTitle">Location required.</div>
            <div class="blockSub" id="centerBlockSub">Please wait while the kiosk verifies the assigned office.</div>
        </div>

        <div id="bottomCenter">
            <div id="mainPrompt">Preparing kiosk.</div>
            <div id="subPrompt">Please wait while the location is verified.</div>
        </div>

        <div id="unlockBackdrop" class="kiosk-backdrop hidden" aria-hidden="true">
            <div id="unlockModal" class="kiosk-modal" role="dialog" aria-modal="true" aria-labelledby="unlockTitle">
                <div class="modal-header">
                    <div id="unlockTitle" class="modal-title">Admin Unlock</div>
                    <button id="unlockClose" type="button" class="modal-close-btn" aria-label="Close">X</button>
                </div>
                <div class="modal-hint">Enter PIN. Press Enter to unlock or Esc to cancel.</div>
                <input
                    id="unlockPin"
                    class="modal-input modal-input-mono"
                    type="password"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    placeholder="PIN" />
                <div id="unlockErr" class="modal-err" role="alert"></div>
                <div class="modal-actions">
                    <button id="unlockCancel" type="button" class="btn-ghost">Cancel</button>
                    <button id="unlockSubmit" type="button" class="btn-primary">Unlock</button>
                </div>
            </div>
        </div>

        <div id="visitorBackdrop" class="kiosk-backdrop hidden" aria-hidden="true">
            <div id="visitorModal" class="kiosk-modal" role="dialog" aria-modal="true" aria-labelledby="visitorTitle">
                <div class="modal-header">
                    <div id="visitorTitle" class="modal-title">Visitor Sign-In</div>
                    <button id="visitorClose" type="button" class="modal-close-btn" aria-label="Close">X</button>
                </div>
                <div class="modal-hint">Fill in the details below. Press Enter to submit.</div>

                <div id="visitorNameRow">
                    <input
                        id="visitorName"
                        class="modal-input"
                        type="text"
                        autocomplete="name"
                        placeholder="Full name" />
                </div>

                <input
                    id="visitorPurpose"
                    class="modal-input"
                    type="text"
                    autocomplete="off"
                    placeholder="Reason for visit" />

                <div id="visitorErr" class="modal-err" role="alert"></div>

                <div class="modal-actions">
                    <button id="visitorCancel" type="button" class="btn-ghost">Cancel</button>
                    <button id="visitorSubmit" type="button" class="btn-primary">Submit</button>
                </div>
            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    <script type="module" src="@Url.Content("~/Scripts/vendor/mediapipe/tasks-vision/vision_loader.mjs")"></script>
    @Scripts.Render("~/bundles/kiosk-vendor")
    @Scripts.Render("~/bundles/kiosk")
</body>
</html>