@{
    Layout = null;
    Response.Cache.SetCacheability(System.Web.HttpCacheability.NoCache);
    Response.Cache.SetNoStore();
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>FaceAttend - Kiosk</title>
    <link href="~/Content/kiosk.css?v=@DateTime.UtcNow.Ticks" rel="stylesheet" />
    <link rel="stylesheet" href="@Url.Content("~/Scripts/vendor/toastify/toastify.min.css")" />
</head>
<body
    data-app-base="@Url.Content("~/")"
    data-nextgen="true"
    data-return-url="@ViewBag.ReturnUrl"
    data-unlock-hint="@ViewBag.UnlockHint">

    @Html.AntiForgeryToken()

    <div id="kioskRoot">

        <!-- Camera feed - always running, visible through idle overlay -->
        <video id="kioskVideo" playsinline autoplay muted></video>

        <!-- Face detection bounding box canvas -->
        <canvas id="overlayCanvas"></canvas>

        <!-- ==============================================================
             IDLE OVERLAY
             Semi-transparent so the camera feed is visible underneath.
             idleClock and idleDate are updated by kiosk.js every second.
             ============================================================== -->
        <div id="idleOverlay" class="hidden" aria-hidden="true">

            <!-- Moving scan line across the full screen -->
            <div class="idle-scanline" aria-hidden="true"></div>

            <!-- Sonar / pulse rings radiating from center -->
            <div class="idle-sonar" aria-hidden="true">
                <div class="idle-sonar-ring sr1"></div>
                <div class="idle-sonar-ring sr2"></div>
                <div class="idle-sonar-ring sr3"></div>
                <div class="idle-sonar-ring sr4"></div>
            </div>

            <!-- Center card -->
            <div class="idle-card">

                <div class="idle-brand-label">FaceAttend</div>

                <!-- Animated face scan ring SVG -->
                <div class="idle-face-ring" aria-hidden="true">
                    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">

                        <!-- Outer slowly rotating dashed ring -->
                        <circle class="ifr-spin"     cx="100" cy="100" r="94" stroke-width="1.0" fill="none"/>

                        <!-- Counter-rotating inner ring -->
                        <circle class="ifr-spin-ccw" cx="100" cy="100" r="78" stroke-width="0.8" fill="none"/>

                        <!-- Glow ring -->
                        <circle class="ifr-glow"     cx="100" cy="100" r="70" stroke-width="1.2" fill="none"/>

                        <!-- Corner brackets: top-left -->
                        <path class="ifr-bracket" stroke-width="2.5" d="M46 66 L46 46 L66 46"/>
                        <!-- top-right -->
                        <path class="ifr-bracket" stroke-width="2.5" d="M134 46 L154 46 L154 66"/>
                        <!-- bottom-left -->
                        <path class="ifr-bracket" stroke-width="2.5" d="M46 134 L46 154 L66 154"/>
                        <!-- bottom-right -->
                        <path class="ifr-bracket" stroke-width="2.5" d="M154 134 L154 154 L134 154"/>

                        <!-- Stylised face: head oval -->
                        <ellipse class="ifr-face" cx="100" cy="96" rx="24" ry="28" stroke-width="1.0" fill="none"/>
                        <!-- eyes -->
                        <circle class="ifr-eye" cx="91"  cy="90" r="2.5"/>
                        <circle class="ifr-eye" cx="109" cy="90" r="2.5"/>
                        <!-- mouth line -->
                        <path class="ifr-face" d="M93 104 Q100 109 107 104" stroke-width="1.2" stroke-linecap="round" fill="none"/>

                    </svg>
                    <!-- Pulsing center dot -->
                    <div class="idle-center-dot" aria-hidden="true"></div>
                </div>

                <!-- Live clock synced by kiosk.js every second -->
                <div id="idleClock" aria-live="off">--:--:--</div>
                <div id="idleDate"  aria-live="off">---</div>

                <!-- CTA -->
                <div class="idle-cta-row">
                    <div class="idle-cta-pip" aria-hidden="true"></div>
                    <div class="idle-cta-text">Look at the camera to begin</div>
                </div>

            </div>

        </div>
        <!-- end #idleOverlay -->

        <!-- ---- HUD: top left - brand and office ----------------------- -->
        <div id="topLeft">
            <div class="brand">FaceAttend</div>
            <div class="sub" id="officeLine">Locating...</div>
        </div>

        <!-- ---- HUD: top center - clock -------------------------------- -->
        <div id="topCenter">
            <div id="timeLine">--:--:--</div>
            <div id="dateLine">---</div>
        </div>

        <!-- ---- HUD: top right - liveness and scan ETA ----------------- -->
        <div id="topRight">
            <div id="livenessLine" class="live-unk">Live: --</div>
            <div id="scanEtaLine">ETA: --</div>
        </div>

        <!-- ---- Center block: out of allowed area ---------------------- -->
        <div id="centerBlock" class="hidden" aria-live="polite">
            <div class="blockTitle">Not in allowed area.</div>
            <div class="blockSub">Move closer to a designated office.</div>
        </div>

        <!-- ---- Bottom center - scan prompt ---------------------------- -->
        <div id="bottomCenter">
            <div id="mainPrompt">Ready.</div>
            <div id="subPrompt">Stand still. One face only.</div>
        </div>

        <!-- ==============================================================
             ADMIN UNLOCK MODAL
             ============================================================== -->
        <div id="unlockBackdrop" class="kiosk-backdrop hidden" aria-hidden="true">
            <div id="unlockModal" class="kiosk-modal" role="dialog" aria-modal="true" aria-labelledby="unlockTitle">
                <div class="modal-header">
                    <div id="unlockTitle" class="modal-title">Admin Unlock</div>
                    <button id="unlockClose" type="button" class="modal-close-btn" aria-label="Close">X</button>
                </div>
                <div class="modal-hint">Enter PIN -- press Enter to unlock or Esc to cancel</div>
                <input
                    id="unlockPin"
                    class="modal-input modal-input-mono"
                    type="password"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    placeholder="PIN" />
                <div id="unlockErr" class="modal-err" role="alert"></div>
                <div class="modal-actions">
                    <button id="unlockCancel" type="button" class="btn-ghost">Cancel</button>
                    <button id="unlockSubmit" type="button" class="btn-primary">Unlock</button>
                </div>
            </div>
        </div>

        <!-- ==============================================================
             VISITOR MODAL
             ============================================================== -->
        <div id="visitorBackdrop" class="kiosk-backdrop hidden" aria-hidden="true">
            <div id="visitorModal" class="kiosk-modal" role="dialog" aria-modal="true" aria-labelledby="visitorTitle">
                <div class="modal-header">
                    <div id="visitorTitle" class="modal-title">Visitor Sign-In</div>
                    <button id="visitorClose" type="button" class="modal-close-btn" aria-label="Close">X</button>
                </div>
                <div class="modal-hint">Fill in the details below -- press Enter to submit</div>

                <div id="visitorNameRow">
                    <input
                        id="visitorName"
                        class="modal-input"
                        type="text"
                        autocomplete="name"
                        placeholder="Full name" />
                </div>

                <input
                    id="visitorPurpose"
                    class="modal-input"
                    type="text"
                    autocomplete="off"
                    placeholder="Reason for visit" />

                <div id="visitorErr" class="modal-err" role="alert"></div>

                <div class="modal-actions">
                    <button id="visitorCancel" type="button" class="btn-ghost">Cancel</button>
                    <button id="visitorSubmit" type="button" class="btn-primary">Submit</button>
                </div>
            </div>
        </div>

    </div><!-- end #kioskRoot -->

    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script type="module" src="@Url.Content("~/Scripts/vendor/mediapipe/tasks-vision/vision_loader.mjs")"></script>
    <script src="@Url.Content("~/Scripts/vendor/toastify/toastify.min.js")"></script>
    <script src="~/Scripts/kiosk.js?v=@DateTime.UtcNow.Ticks"></script>

</body>
</html>
