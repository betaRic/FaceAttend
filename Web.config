<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- ===================================================== -->
  <!-- CONFIG SECTIONS                                        -->
  <!-- ===================================================== -->
  <configSections>
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>

  <!-- ===================================================== -->
  <!-- CONNECTION STRINGS                                     -->
  <!-- Production must supply FACEATTEND_ENTITY_CONNECTION_STRING or FACEATTEND_DB_PROVIDER_CONNECTION_STRING in IIS. -->
  <!-- ===================================================== -->
  <connectionStrings>
    <add name="FaceAttendDBEntities"
         connectionString="metadata=res://*/FaceAttendDBEntities.csdl|res://*/FaceAttendDBEntities.ssdl|res://*/FaceAttendDBEntities.msl;provider=System.Data.SqlClient;provider connection string=&quot;Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=FaceAttendDB;Integrated Security=True;Pooling=True;Min Pool Size=5;Max Pool Size=100;MultipleActiveResultSets=True;Encrypt=True;TrustServerCertificate=False;Connect Timeout=5;App=EntityFramework;&quot;"
         providerName="System.Data.EntityClient" />
  </connectionStrings>

  <!-- ===================================================== -->
  <!-- APP SETTINGS - CLEANED UP                              -->
  <!-- ===================================================== -->
  <appSettings>
    <!-- ==================== CORE ==================== -->
    <add key="App:TimeZoneId" value="Asia/Manila" />
    <add key="BundleTable:EnableOptimizations" value="true" />
    
    <!-- ==================== ADMIN SECURITY ==================== -->
    <add key="Admin:SessionMinutes" value="30" />
    <add key="Admin:PinMaxAttempts" value="5" />
    <add key="Admin:PinLockoutSeconds" value="300" />
    <add key="Admin:UnlockCookieSeconds" value="120" />
    <add key="Admin:BypassCookieHours" value="8" />
    <add key="Admin:TotpEnabled" value="false" />
    <add key="Admin:AllowedIpRanges" value="" />
    <add key="Admin:BindUnlockCookieToIp" value="false" />

    <!-- ==================== BIOMETRICS - IN-PROCESS ENGINE ==================== -->
    <add key="Biometrics:ModelDir" value="~/App_Data/models/onnx" />
    <add key="Biometrics:OnnxModelsDir" value="~/App_Data/models/onnx" />
    <add key="Biometrics:Engine:Enabled" value="true" />
    <add key="Biometrics:Engine:Runtime" value="ONNX_RUNTIME_CPU" />
    <add key="Biometrics:Engine:AnalyzeTimeoutMs" value="5000" />
    <add key="Biometrics:Engine:IntraOpThreads" value="4" />
    <add key="Biometrics:Engine:InterOpThreads" value="1" />
    <add key="Biometrics:Engine:DetectorPath" value="face-detector.onnx" />
    <add key="Biometrics:Engine:RecognizerPath" value="face-recognizer.onnx" />
    <add key="Biometrics:Engine:AntiSpoofPath" value="anti-spoof.onnx" />
    <add key="Biometrics:Recognizer:Normalize127" value="false" />
    <add key="Biometrics:Detect:ScoreThreshold" value="0.75" />
    <add key="Biometrics:Detect:NmsThreshold" value="0.30" />
    <add key="Biometrics:Detect:TopK" value="50" />

    <!-- ==================== BIOMETRICS - MATCHING ==================== -->
    <!-- HIGH = instant accept, MEDIUM = need 2nd scan, LOW = reject -->
    <add key="Biometrics:Match:HighDistThreshold" value="0.40" />
    <add key="Biometrics:Match:MedDistThreshold" value="0.55" />
    <add key="Biometrics:AttendanceTolerance" value="0.60" />
    <add key="Biometrics:EnrollmentRiskTolerance" value="0.55" />
    <add key="Biometrics:RiskAudit:CriticalDistance" value="0.40" />
    <add key="Biometrics:RiskAudit:UnsafeDistance" value="0.55" />
    <add key="Biometrics:RiskAudit:WatchDistance" value="0.60" />
    <add key="Biometrics:RiskAudit:MaxRows" value="100" />

    <!-- ==================== BIOMETRICS - ANTI-SPOOF ==================== -->
    <add key="Biometrics:DetectorModel" value="opencv-yunet-2023mar" />
    <add key="Biometrics:LandmarkModel" value="yunet-5pt-integrated" />
    <add key="Biometrics:RecognizerModel" value="opencv-sface-2021dec" />
    <add key="Biometrics:AntiSpoofModel" value="anti-spoof-mn3-onnx" />
    <add key="Biometrics:AntiSpoof:Mode" value="REVIEW_FIRST" />
    <add key="Biometrics:AntiSpoof:ClearThreshold" value="0.45" />
    <add key="Biometrics:AntiSpoof:MobileClearThreshold" value="0.45" />
    <add key="Biometrics:AntiSpoof:ReviewThreshold" value="0.30" />
    <add key="Biometrics:AntiSpoof:BlockThreshold" value="0.15" />
    <add key="Biometrics:AntiSpoof:ModelFailureAction" value="REVIEW" />
    <add key="Biometrics:Face:DominantFaceRatio" value="1.8" />
    <add key="Biometrics:Match:AmbiguityRelativeGap" value="0.25" />

    <!-- ==================== BIOMETRICS - ENROLLMENT ==================== -->
    <add key="Biometrics:Enroll:MinFrames" value="5" />
    <add key="Biometrics:Enroll:CaptureTarget" value="25" />
    <add key="Biometrics:Enroll:MaxStoredVectors" value="25" />
    <add key="Biometrics:Enroll:SharpnessThreshold" value="35" />
    <add key="Biometrics:Enroll:SharpnessThreshold:Mobile" value="28" />
    <add key="Biometrics:Enroll:MinFaceAreaRatio" value="0.08" />
    <add key="Biometrics:Enroll:MinFaceAreaRatio:Mobile" value="0.06" />
    <add key="Biometrics:Enroll:MaxPoseYaw" value="35" />
    <add key="Biometrics:Enroll:MaxPosePitch" value="40" />
    <add key="Biometrics:Enroll:EnrollmentTolerance" value="0.50" />
    <add key="Biometrics:EnrollmentStrictTolerance" value="0.45" />

    <!-- ==================== BIOMETRICS - IMAGE ==================== -->
    <add key="Biometrics:MaxUploadBytes" value="10485760" />
    <add key="Biometrics:MaxImageDimension" value="1280" />
    <add key="Biometrics:PreprocessJpegQuality" value="85" />

    <!-- ==================== BIOMETRICS - BALLTREE ==================== -->
    <add key="Biometrics:BallTreeThreshold" value="50" />
    <add key="Biometrics:BallTreeLeafSize" value="16" />

    <!-- ==================== BIOMETRICS - CRYPTO ==================== -->
    <add key="Biometrics:Crypto:Enabled" value="true" />
    <add key="Biometrics:ModelVersion" value="yunet-sface-antispoofmn3-v1-pending-calibration" />
    <add key="Biometrics:DistanceMetric" value="euclidean_l2_normalized" />
    <add key="Biometrics:EmbeddingDim" value="128" />
    <add key="Biometrics:RequireModelReadOnlyAcl" value="false" />

    <!-- ==================== KIOSK ==================== -->
    <add key="Kiosk:RequestTimeoutMs" value="30000" />
    <add key="Kiosk:MaxConcurrentScans" value="4" />
    <add key="Kiosk:FallbackOfficeId" value="0" />
    <add key="Kiosk:VisitorScanTtlSeconds" value="180" />
    <add key="Kiosk:VisitorEnabled" value="false" />
    <add key="Kiosk:EnablePerfTimings" value="false" />

    <!-- ==================== LOCATION ==================== -->
    <add key="Location:GPSAccuracyRequired" value="50" />
    <add key="Location:GPSRadiusDefault" value="100" />

    <!-- ==================== ATTENDANCE ==================== -->
    <add key="Attendance:MinGapSeconds" value="180" />
    <add key="Attendance:MinGap:InToOutSeconds" value="1800" />
    <add key="Attendance:MinGap:OutToInSeconds" value="300" />
    <add key="Attendance:WorkStart" value="08:00" />
    <add key="Attendance:WorkEnd" value="17:00" />
    <add key="Attendance:LunchStart" value="12:00" />
    <add key="Attendance:LunchEnd" value="13:00" />
    <add key="Attendance:GraceMinutes" value="10" />
    <add key="Attendance:FullDayHours" value="8" />
    <add key="Attendance:HalfDayHours" value="4" />
    <add key="AttendanceAccess:ReceiptMinutes" value="10" />
    <add key="AttendanceAccess:BindIp" value="true" />

    <!-- ==================== REVIEW ==================== -->
    <add key="NeedsReview:NearMatchRatio" value="0.85" />
    <add key="NeedsReview:AntiSpoofMargin" value="0.03" />
    <add key="NeedsReview:GPSAccuracyMargin" value="20" />

    <!-- ==================== VISITORS ==================== -->
    <add key="Visitors:MaxRecords" value="200" />
    <add key="Visitors:RetentionYears" value="3" />
    <add key="Visitors:RecognitionTolerance" value="0.65" />

    <!-- ==================== TEMP FILES ==================== -->
    <add key="TempFile:MaxAgeMinutes" value="30" />
    <add key="TempFile:CleanupIntervalMinutes" value="60" />

    <!-- ==================== RATE LIMITING ==================== -->
    <add key="RateLimit:XffHardCapPerMinute" value="60" />
    <add key="RateLimit:TrustedProxyCidrs" value="" />

    <!-- ==================== SECURITY ==================== -->
    <add key="Security:RequireHttps" value="true" />
    <add key="Security:HstsEnabled" value="true" />
    <add key="Security:AuditPublicScanEvents" value="true" />
    <add key="Database:RequireStabilizationMigrations" value="false" />
    <add key="Security:CspReportOnly" value="false" />
    <add key="Biometrics:Debug" value="false" />
    <add key="Security:Csp" value="default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: blob: https://a.tile.openstreetmap.org https://b.tile.openstreetmap.org https://c.tile.openstreetmap.org https://*.basemaps.cartocdn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; connect-src 'self' https://router.project-osrm.org; worker-src blob:; media-src 'self' blob:;" />

    <!-- ==================== MISC / LEGACY ==================== -->
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
  </appSettings>

  <!-- ===================================================== -->
  <!-- SYSTEM.WEB                                             -->
  <!-- ===================================================== -->
  <system.web>
    <compilation debug="false" targetFramework="4.8">
      <buildProviders>
        <remove extension=".edmx" />
      </buildProviders>
    </compilation>
    <httpRuntime targetFramework="4.8" maxRequestLength="10240" executionTimeout="300" />
    <sessionState mode="InProc" timeout="30" />
    <customErrors mode="RemoteOnly" redirectMode="ResponseRewrite">
      <error statusCode="404" redirect="/Error/NotFound" />
      <error statusCode="500" redirect="/Error/Index" />
    </customErrors>
    <pages validateRequest="true" />
  </system.web>

  <!-- ===================================================== -->
  <!-- ENTITY FRAMEWORK                                       -->
  <!-- ===================================================== -->
  <entityFramework>
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
    <defaultConnectionFactory type="System.Data.Entity.Infrastructure.SqlConnectionFactory, EntityFramework" />
  </entityFramework>

  <!-- ===================================================== -->
  <!-- RUNTIME BINDING REDIRECTS                              -->
  <!-- ===================================================== -->
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Antlr3.Runtime" publicKeyToken="eb42632606e9261f" />
        <bindingRedirect oldVersion="0.0.0.0-3.5.0.2" newVersion="3.5.0.2" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Web.Infrastructure" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-2.0.0.0" newVersion="2.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.ML.OnnxRuntime" publicKeyToken="f27f157f0a5b7bb6" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-1.25.1.0" newVersion="1.25.1.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Optimization" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="1.0.0.0-1.1.0.0" newVersion="1.1.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="WebGrease" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-1.6.5135.21930" newVersion="1.6.5135.21930" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Helpers" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.WebPages" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Mvc" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-5.3.0.0" newVersion="5.3.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Drawing.Common" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-10.0.0.0" newVersion="10.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Buffers" culture="neutral" publicKeyToken="cc7b13ffcd2ddd51" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Memory" culture="neutral" publicKeyToken="cc7b13ffcd2ddd51" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Numerics.Vectors" culture="neutral" publicKeyToken="b03f5f7f11d50a3a" />
        <bindingRedirect oldVersion="0.0.0.0-4.1.6.0" newVersion="4.1.6.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" culture="neutral" publicKeyToken="b03f5f7f11d50a3a" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.3.0" newVersion="6.0.3.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Text.Encodings.Web" culture="neutral" publicKeyToken="cc7b13ffcd2ddd51" />
        <bindingRedirect oldVersion="0.0.0.0-10.0.0.2" newVersion="10.0.0.2" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Bcl.AsyncInterfaces" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-8.0.0.0" newVersion="8.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Extensions.Logging.Abstractions" publicKeyToken="adb9793829ddae60" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-8.0.0.2" newVersion="8.0.0.2" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Extensions.DependencyInjection.Abstractions" publicKeyToken="adb9793829ddae60" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-8.0.0.2" newVersion="8.0.0.2" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Extensions.Options" publicKeyToken="adb9793829ddae60" culture="neutral" />
