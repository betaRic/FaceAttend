<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- ===================================================== -->
  <!-- CONFIG SECTIONS                                        -->
  <!-- ===================================================== -->
  <configSections>
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>

  <!-- ===================================================== -->
  <!-- CONNECTION STRINGS                                     -->
  <!-- ===================================================== -->
  <connectionStrings>
    <add name="FaceAttendDBEntities" connectionString="metadata=res://*/FaceAttendDBEntities.csdl|res://*/FaceAttendDBEntities.ssdl|res://*/FaceAttendDBEntities.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=localhost\SQLEXPRESS;initial catalog=FaceAttendDB;integrated security=True;trustservercertificate=True;MultipleActiveResultSets=True;App=EntityFramework;Max Pool Size=50;&quot;" providerName="System.Data.EntityClient" />
    <!--
      PHASE 2 FIX (P-04 / S-04):
      Nadagdagan ng "Max Pool Size=50" — ginawang mas maliit kaysa sa default na 100
      para maiwasang ma-exhaust ang SQL Express connection limit ng 32767.
      Kapag nag-upgrade na sa full SQL Server, pwede itaas sa 200.
    -->
  </connectionStrings>

  <!-- ===================================================== -->
  <!-- APP SETTINGS                                           -->
  <!-- ===================================================== -->
  <appSettings>

    <!-- MVC / WebPages -->
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <add key="App:TimeZoneId" value="Asia/Manila" />

    <!-- Attendance gap: minimum na 3 minuto bago pwedeng mag-scan ulit -->
    <add key="Attendance:MinGapSeconds" value="180" />

    <!-- ==========================================================
         PHASE 1 FIX (S-03): TINANGGAL ANG PIN HASH DITO.
         Ang hash ay kinakalikala na ngayon mula sa IIS Environment Variable
         para hindi makita sa source control.

         PAANO MAG-SET NG ENVIRONMENT VARIABLE SA IIS:
           IIS Manager > Sites > [iyong site] > Configuration Editor
           > system.webServer/aspNetCore o kaya:
           Server Manager > Tools > IIS > Application Pools >
           [iyong pool] > Advanced Settings > Environment Variables.

         O kaya sa PowerShell (i-run bilang Admin):
           [System.Environment]::SetEnvironmentVariable(
             "FACEATTEND_ADMIN_PIN_HASH",
             "PBKDF2$120000$...",
             "Machine")

         Pagkatapos ay basahin sa code gamit ang:
           Environment.GetEnvironmentVariable("FACEATTEND_ADMIN_PIN_HASH")

         PANSAMANTALA: kung hindi pa kaya mag-set ng env var, gamitin
         ang IIS Manager > Sites > [site] > Application Settings
         (hindi ito kasama sa source control kapag ginawa sa IIS Manager directly).
         ========================================================== -->
    <!-- HUWAG IBALIK ANG Admin:PinHash DITO — gamitin ang IIS env var -->
    <add key="Admin:SessionMinutes" value="30" />
    <add key="Admin:PinMaxAttempts" value="5" />
    <add key="Admin:PinLockoutSeconds" value="300" />
    <add key="Admin:UnlockCookieSeconds" value="120" />

    <!--
      Admin IP allowlist — PHASE 1 FIX (S-06):
      Dahil dynamic ang IP ng ibang offices, WALANG nilista dito.
      Proteksyon ng admin panel ay ang PIN + rate limiting na lang.
      Kapag may VPN na (Phase 3), i-set dito ang VPN subnet:
        value="10.8.0.0/24"
    -->
    <add key="Admin:AllowedIpRanges" value="" />

    <!-- ==========================================================
         PHASE 1 FIX (S-05, S-01): Security headers — ENFORCED na ngayon
         ========================================================== -->
    <add key="Security:HstsEnabled" value="true" />
    <add key="Security:HstsValue" value="max-age=31536000; includeSubDomains" />
    <!--
      CSP: hindi na Report-Only — ENFORCED na.
      'unsafe-inline' ay kailangan pa rin ng ilang Razor partials at kiosk scripts.
      Palakasin pa ito sa Phase 3 gamit ang nonces.
    -->
    <add key="Security:CspReportOnly" value="false" />
    <add key="Security:Csp" value="default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; worker-src blob:; media-src blob:;" />

    <!-- ==========================================================
         PHASE 1 FIX (S-07): I-enable na ang NextGen attendance pipeline.
         Dati ay false — kaya walang nare-record na attendance!
         ========================================================== -->
    <add key="Kiosk:UseNextGen" value="true" />
    <add key="Kiosk:EnablePerfTimings" value="false" />
    <add key="Kiosk:FallbackOfficeId" value="0" />
    <add key="Kiosk:VisitorScanTtlSeconds" value="180" />

    <!-- ==========================================================
         PHASE 2 FIX (P-01/P-02): Dlib pool size
         Gaano karaming concurrent na face scan ang papayagan.
         Default: 4 — pwedeng itaas depende sa CPU cores ng server.
         (I-check: Get-WmiObject Win32_Processor | Select NumberOfCores)
         ========================================================== -->
    <add key="Biometrics:DlibPoolSize" value="4" />
    <add key="Biometrics:DlibPoolTimeoutMs" value="30000" />

    <!-- Biometrics — model paths -->
    <add key="Biometrics:DlibModelsDir" value="~/App_Data/models/dlib" />
    <add key="Biometrics:DlibTolerance" value="0.60" />
    <add key="Biometrics:DlibDetector" value="hog" />

    <add key="Biometrics:LivenessModelPath" value="~/App_Data/models/liveness/minifasnet.onnx" />
    <add key="Biometrics:LivenessInputSize" value="128" />
    <add key="Biometrics:LivenessThreshold" value="0.75" />

    <add key="Biometrics:Liveness:CropScale" value="2.7" />
    <add key="Biometrics:Liveness:Normalize" value="0_1" />
    <add key="Biometrics:Liveness:OutputType" value="logits" />
    <add key="Biometrics:Liveness:RealIndex" value="1" />
    <add key="Biometrics:Liveness:Decision" value="max" />
    <add key="Biometrics:Liveness:MultiCropScales" value="2.7" />
    <add key="Biometrics:Liveness:ChannelOrder" value="RGB" />

    <add key="Biometrics:Liveness:CircuitFailStreak" value="3" />
    <add key="Biometrics:Liveness:CircuitDisableSeconds" value="30" />
    <add key="Biometrics:Liveness:SlowMs" value="1200" />
    <add key="Biometrics:Liveness:RunTimeoutMs" value="1500" />
    <!-- GateWaitMs: tinanggal na — hindi na ginagamit ng bagong thread-safe OnnxLiveness -->

    <add key="Biometrics:MaxUploadBytes" value="10485760" />
    <add key="Biometrics:EmployeeIdMaxLen" value="20" />
    <add key="Biometrics:EmployeeIdPattern" value="^[A-Z0-9_-]{1,20}$" />
    <add key="Biometrics:Enroll:MaxImages" value="5" />

    <add key="Biometrics:BallTreeThreshold" value="50" />
    <add key="Biometrics:BallTreeLeafSize" value="16" />
    <add key="Biometrics:MaxImageDimension" value="1280" />
    <add key="Biometrics:PreprocessJpegQuality" value="85" />
    <add key="Biometrics:FaceMatchTuner:Enabled" value="false" />
    <add key="Biometrics:Debug" value="false" />

    <!-- Location / GPS -->
    <add key="Location:GPSAccuracyRequired" value="50" />
    <add key="Location:GPSRadiusDefault" value="100" />

    <!-- Attendance timing -->
    <add key="Attendance:WorkStart" value="08:00" />
    <add key="Attendance:WorkEnd" value="17:00" />
    <add key="Attendance:LunchStart" value="12:00" />
    <add key="Attendance:LunchEnd" value="13:00" />
    <add key="Attendance:FlexiRequiredHours" value="8.0" />
    <add key="Attendance:NoGracePeriod" value="true" />
    <add key="Attendance:GraceMinutes" value="10" />
    <add key="Attendance:FullDayHours" value="8" />
    <add key="Attendance:HalfDayHours" value="4" />
    <add key="Attendance:LunchMinutes" value="60" />
    <add key="Attendance:LunchDeductAfterHours" value="5.5" />

    <!-- Review queue thresholds -->
    <add key="NeedsReview:NearMatchRatio" value="0.15" />
    <add key="NeedsReview:LivenessMargin" value="0.10" />
    <add key="NeedsReview:GPSAccuracyMargin" value="20" />

    <!-- Visitors -->
    <add key="Visitor:MaxRecords" value="200" />
    <add key="Visitor:RetentionYears" value="3" />

  </appSettings>

  <!-- ===================================================== -->
  <!-- ENTITY FRAMEWORK                                       -->
  <!-- ===================================================== -->
  <entityFramework>
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
    <defaultConnectionFactory type="System.Data.Entity.Infrastructure.SqlConnectionFactory, EntityFramework" />
  </entityFramework>

  <!-- ===================================================== -->
  <!-- RUNTIME BINDING REDIRECTS                              -->
  <!-- ===================================================== -->
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Antlr3.Runtime" publicKeyToken="eb42632606e9261f" />
        <bindingRedirect oldVersion="0.0.0.0-3.5.0.2" newVersion="3.5.0.2" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Web.Infrastructure" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-2.0.0.0" newVersion="2.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Optimization" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="1.0.0.0-1.1.0.0" newVersion="1.1.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="WebGrease" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-1.6.5135.21930" newVersion="1.6.5135.21930" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Helpers" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="1.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.WebPages" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="1.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Mvc" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="1.0.0.0-5.3.0.0" newVersion="5.3.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Drawing.Common" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-10.0.0.0" newVersion="10.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>

  <!-- ===================================================== -->
  <!-- IIS (system.webServer)                                 -->
  <!-- ===================================================== -->
  <system.webServer>

    <!-- Upload size limit: 10 MB -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>

    <!--
      PHASE 1 FIX (S-01): HTTP → HTTPS redirect — NAKA-ENABLE NA.
      Kapag may SSL certificate na (mula sa 01_CreateInternalCA.ps1),
      lahat ng HTTP request ay ire-redirect sa HTTPS awtomatiko.
      Kailangan ang URL Rewrite module ng IIS para gumana ito.
      I-install: https://www.iis.net/downloads/microsoft/url-rewrite
    -->
    <rewrite>
      <rules>
        <rule name="HTTP to HTTPS redirect" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <!--
          PHASE 1 FIX (S-01): HSTS — aktibo na ngayon.
          Sasabihin sa browser na HTTPS lang ang gagamitin para sa domain na ito
          sa susunod na 1 taon (31536000 seconds).
          BABALA: Kapag naka-on na ito at nawala ang SSL cert, hindi maa-access
          ang site sa browser hanggang hindi nare-renew ang cert.
        -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
      </customHeaders>
    </httpProtocol>

    <!-- Static content MIME types para sa MediaPipe / WASM / fonts -->
    <staticContent>
      <remove fileExtension=".tflite" />
      <remove fileExtension=".binarypb" />
      <remove fileExtension=".data" />
      <remove fileExtension=".wasm" />
      <remove fileExtension=".mjs" />
      <remove fileExtension=".map" />
      <remove fileExtension=".woff2" />
      <remove fileExtension=".woff" />

      <mimeMap fileExtension=".tflite" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".binarypb" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".data" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
      <mimeMap fileExtension=".mjs" mimeType="text/javascript" />
      <mimeMap fileExtension=".map" mimeType="application/json" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
    </staticContent>

    <!-- Custom error pages -->
    <httpErrors existingResponse="PassThrough">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" path="/Error/NotFound" responseMode="ExecuteURL" />
      <remove statusCode="403" subStatusCode="-1" />
      <error statusCode="403" path="/Error/Forbidden" responseMode="ExecuteURL" />
      <remove statusCode="400" subStatusCode="-1" />
      <error statusCode="400" path="/Error/BadRequest" responseMode="ExecuteURL" />
    </httpErrors>

  </system.webServer>

  <!-- ===================================================== -->
  <!-- CODEDOM                                                -->
  <!-- ===================================================== -->
  <system.codedom>
    <compilers>
      <compiler language="c#;cs;csharp" extension=".cs" warningLevel="4" compilerOptions="/langversion:default /nowarn:1659;1699;1701;612;618" type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.CSharpCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=4.1.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
      <compiler language="vb;vbs;visualbasic;vbscript" extension=".vb" warningLevel="4" compilerOptions="/langversion:default /nowarn:41008,40000,40008 /define:_MYTYPE=\&quot;Web\&quot; /optionInfer+" type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.VBCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=4.1.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
    </compilers>
  </system.codedom>

</configuration>
