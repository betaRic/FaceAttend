      <!-- ── BAGONG redirects — mula sa MSB3247 warnings ───────────────── -->
      <!-- Microsoft.ML.OnnxRuntime 1.23.2.0 -->
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.ML.OnnxRuntime" culture="neutral" publicKeyToken="f27f157f0a5b7bb6" />
